@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="ra-page">
    <div class="ra-bg"></div>

    <div class="container ra-container">

        @* ── LEFT SIDE ── *@
        <div class="ra-left">
            <div class="ra-left-inner">
                <span class="ra-eyebrow">Welcome Back</span>
                <h1 class="ra-headline">Good to<br><span class="ra-headline-gold">See You</span></h1>
                <p class="ra-tagline">
                    Sign in to manage your bookings, explore artists, and continue your beauty journey.
                </p>
                <div class="ra-perks">
                    <div class="ra-perk">
                        <div class="ra-perk-icon">✦</div>
                        <span>View and manage your appointments</span>
                    </div>
                    <div class="ra-perk">
                        <div class="ra-perk-icon">✦</div>
                        <span>Book your favourite artists</span>
                    </div>
                    <div class="ra-perk">
                        <div class="ra-perk-icon">✦</div>
                        <span>Track your beauty history</span>
                    </div>
                </div>
            </div>
        </div>

        @* ── RIGHT SIDE: FORM ── *@
        <div class="ra-right">
            <div class="ra-card">

                <div class="ra-card-header">
                    <span class="ra-card-eyebrow">Member Login</span>
                    <h2 class="ra-card-title">Sign In</h2>
                </div>

                @if (TempData["RegisterSuccess"] != null)
                {
                    <div class="ra-alert-success">✓ @TempData["RegisterSuccess"]</div>
                }

                <div asp-validation-summary="ModelOnly" class="ra-error-summary"></div>

                <form id="account" method="post" class="ra-form">

                    @* ── KEY FIX: keeps returnUrl through the POST ── *@
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                    <div class="ra-field">
                        <label asp-for="Input.Email" class="ra-label">Email Address</label>
                        <input asp-for="Input.Email" class="ra-input"
                               autocomplete="username" placeholder="yourname@email.com" />
                        <span asp-validation-for="Input.Email" class="ra-field-error"></span>
                    </div>

                    <div class="ra-field">
                        <label asp-for="Input.Password" class="ra-label">Password</label>
                        <div class="ra-input-wrap">
                            <input asp-for="Input.Password" class="ra-input"
                                   type="password" id="passwordField"
                                   autocomplete="current-password"
                                   placeholder="Enter your password" />
                            <button type="button" class="ra-eye-btn"
                                    onclick="togglePass('passwordField', this)">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="ra-field-error"></span>
                    </div>

                    <div class="ra-remember-row">
                        <label class="ra-remember-label">
                            <input class="ra-checkbox" asp-for="Input.RememberMe" type="checkbox" />
                            <span>Remember me</span>
                        </label>
                        <a asp-page="./ForgotPassword" class="ra-forgot-link">Forgot password?</a>
                    </div>

                    <button id="login-submit" type="submit" class="ra-submit-btn">
                        <span>Sign In</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5">
                            <line x1="5" y1="12" x2="19" y2="12" />
                            <polyline points="12,5 19,12 12,19" />
                        </svg>
                    </button>

                    <div class="ra-divider"><span>Don't have an account?</span></div>

                    <div class="ra-register-options">
                        <a asp-page="./RegisterClient"
                           asp-route-returnUrl="@Model.ReturnUrl"
                           class="ra-register-btn ra-register-client">
                            Register as Client
                        </a>
                        <a asp-page="./RegisterArtist"
                           asp-route-returnUrl="@Model.ReturnUrl"
                           class="ra-register-btn ra-register-artist">
                            Register as Artist
                        </a>
                    </div>

                    <p class="ra-resend-link">
                        <a asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                    </p>

                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .ra-page {
        background: #000;
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

    .ra-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        background: radial-gradient(ellipse at 20% 50%, rgba(179,0,0,0.12) 0%, transparent 50%), radial-gradient(ellipse at 80% 50%, rgba(255,215,0,0.05) 0%, transparent 50%);
        pointer-events: none;
    }

    .ra-container {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 60px;
        min-height: 100vh;
        padding: 60px 20px;
    }

    @@media (max-width: 992px) {
        .ra-container {
            flex-direction: column;
            gap: 40px;
            padding: 40px 20px;
        }

        .ra-left {
            display: none;
        }
    }

    .ra-left {
        flex: 1;
    }

    .ra-left-inner {
        max-width: 420px;
    }

    .ra-eyebrow {
        display: inline-block;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 5px;
        text-transform: uppercase;
        color: rgba(255,215,0,0.4);
        margin-bottom: 16px;
    }

    .ra-headline {
        color: #fff;
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1.05;
        margin: 0 0 16px;
    }

    .ra-headline-gold {
        color: #FFD700;
        text-shadow: 0 0 40px rgba(255,215,0,0.3);
    }

    .ra-tagline {
        color: rgba(255,255,255,0.35);
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 32px;
    }

    .ra-perks {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .ra-perk {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.5);
        font-size: 0.85rem;
    }

    .ra-perk-icon {
        color: #FFD700;
        font-size: 0.7rem;
        flex-shrink: 0;
    }

    .ra-right {
        flex: 0 0 480px;
    }

    @@media (max-width: 992px) {
        .ra-right {
            flex: 1;
            width: 100%;
            max-width: 480px;
        }
    }

    .ra-card {
        background: #0b0b0b;
        border: 1px solid rgba(255,215,0,0.12);
        border-radius: 24px;
        padding: 40px;
    }

    .ra-card-header {
        margin-bottom: 28px;
    }

    .ra-card-eyebrow {
        display: block;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(255,215,0,0.35);
        margin-bottom: 8px;
    }

    .ra-card-title {
        color: #FFD700;
        font-size: 1.5rem;
        font-weight: 800;
        margin: 0;
        text-shadow: 0 0 20px rgba(255,215,0,0.2);
    }

    .ra-alert-success {
        background: rgba(0,200,83,0.08);
        border: 1px solid rgba(0,200,83,0.25);
        border-radius: 10px;
        padding: 12px 16px;
        color: #00c853;
        font-size: 0.82rem;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .ra-error-summary {
        background: rgba(255,50,50,0.08);
        border: 1px solid rgba(255,50,50,0.2);
        border-radius: 10px;
        padding: 12px 16px;
        color: #ff5555;
        font-size: 0.82rem;
        margin-bottom: 20px;
    }

        .ra-error-summary:empty {
            display: none;
        }

    .ra-form {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .ra-field {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .ra-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
    }

    .ra-input-wrap {
        position: relative;
    }

        .ra-input-wrap .ra-input {
            padding-right: 44px;
            width: 100%;
        }

    .ra-input {
        width: 100%;
        background: #111;
        border: 1.5px solid rgba(255,215,0,0.1);
        border-radius: 10px;
        color: #fff;
        padding: 13px 16px;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s, background 0.2s;
    }

        .ra-input:focus {
            border-color: rgba(255,215,0,0.4);
            background: #131300;
        }

        .ra-input::placeholder {
            color: rgba(255,255,255,0.18);
        }

    .ra-eye-btn {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: rgba(255,255,255,0.25);
        padding: 4px;
        transition: color 0.2s;
    }

        .ra-eye-btn:hover {
            color: #FFD700;
        }

    .ra-field-error {
        color: #ff5555;
        font-size: 0.75rem;
        min-height: 16px;
    }

    .ra-remember-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .ra-remember-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: rgba(255,255,255,0.35);
        font-size: 0.8rem;
        cursor: pointer;
    }

    .ra-checkbox {
        width: 16px;
        height: 16px;
        accent-color: #FFD700;
        cursor: pointer;
    }

    .ra-forgot-link {
        color: rgba(255,215,0,0.5);
        font-size: 0.78rem;
        text-decoration: none;
        transition: color 0.2s;
    }

        .ra-forgot-link:hover {
            color: #FFD700;
        }

    .ra-submit-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 16px;
        background: linear-gradient(135deg, #b30000, #FFD700);
        color: #000;
        font-weight: 800;
        font-size: 0.95rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
    }

        .ra-submit-btn:hover {
            background: linear-gradient(135deg, #FFD700, #b30000);
            box-shadow: 0 0 30px rgba(255,215,0,0.3);
            transform: translateY(-2px);
        }

    .ra-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.15);
        font-size: 0.75rem;
    }

        .ra-divider::before, .ra-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.08);
        }

    .ra-register-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .ra-register-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px;
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.2s ease;
        text-align: center;
    }

    .ra-register-client {
        background: rgba(255,215,0,0.06);
        border: 1px solid rgba(255,215,0,0.2);
        color: #FFD700;
    }

        .ra-register-client:hover {
            background: rgba(255,215,0,0.12);
            color: #FFD700;
            border-color: rgba(255,215,0,0.4);
        }

    .ra-register-artist {
        background: rgba(179,0,0,0.1);
        border: 1px solid rgba(179,0,0,0.25);
        color: rgba(255,100,100,0.8);
    }

        .ra-register-artist:hover {
            background: rgba(179,0,0,0.18);
            color: #ff6666;
            border-color: rgba(179,0,0,0.4);
        }

    .ra-resend-link {
        text-align: center;
        font-size: 0.72rem;
        margin: 0;
    }

        .ra-resend-link a {
            color: rgba(255,255,255,0.2);
            text-decoration: none;
            transition: color 0.2s;
        }

            .ra-resend-link a:hover {
                color: rgba(255,255,255,0.4);
            }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(fieldId, btn) {
            const field = document.getElementById(fieldId);
            const isPass = field.type === 'password';
            field.type = isPass ? 'text' : 'password';
            btn.style.color = isPass ? '#FFD700' : 'rgba(255,255,255,0.25)';
        }
    </script>
}
