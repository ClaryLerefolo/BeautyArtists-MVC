@model BeautyArtists.Models.ApplicationUser

@{
    ViewData["Title"] = "Delete User";
}

<div class="container mt-5">
    <h2 class="text-danger">Delete User</h2>
    <div class="alert alert-warning">
        Are you sure you want to delete this user: <strong>@Model.FirstName @Model.LastName (@Model.Email)</strong>?
    </div>

    <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-action="Users" class="btn btn-secondary">Cancel</a>
    </form>
</div>
