@model List<BeautyArtists.Models.ViewModels.UserManagementViewModel>

@{
    ViewData["Title"] = "Manage Users";
    var searchTerm = Context.Request.Query["search"];
    var roleFilter = Context.Request.Query["role"];
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .badge-admin {
            background-color: #8B0000;
            color: white;
        }

        .badge-artist {
            background-color: #000;
            color: gold;
        }

        .badge-client {
            background-color: #333;
            color: white;
        }

        .search-box {
            position: relative;
        }

            .search-box i {
                position: absolute;
                top: 50%;
                left: 15px;
                transform: translateY(-50%);
                color: #6c757d;
            }

            .search-box input {
                padding-left: 40px;
            }

        .filter-select {
            border-radius: 50px;
            border: 1px solid #ced4da;
        }

        .page-title {
            color: #ffc107;
            font-weight: bold;
            border-bottom: 3px solid #8B0000;
            padding-bottom: 10px;
            margin-bottom: 30px;
        }

        .btn-warning.text-dark {
            font-weight: 600;
        }

        .btn-red {
            background-color: #8B0000;
            color: white;
        }

            .btn-red:hover {
                background-color: #a00;
                color: white;
            }

        .btn-gold {
            background-color: gold;
            color: black;
            font-weight: bold;
        }

            .btn-gold:hover {
                background-color: #e6c200;
                color: black;
            }

        .table-responsive {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.2);
        }

        .table thead {
            background: linear-gradient(to right, #000, #8B0000);
            color: gold;
        }

        .table-dark tbody tr:hover {
            background-color: #2a2a2a;
        }
    </style>
}

<div class="container-fluid py-4">
    <h1 class="page-title">User Management</h1>

    <!-- Action Buttons -->
    <div class="d-flex justify-content-between mb-4">
        <form asp-action="DeletePromotedAdmins" method="post" class="d-inline">
            <button type="submit" class="btn btn-red">
                <i class="fas fa-trash-alt me-2"></i>Delete All Promoted Admins
            </button>
        </form>
    </div>

    <!-- Filter Form -->
    <form method="get" class="row g-3 mb-4 bg-dark text-light p-4 rounded">
        <div class="col-md-5">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" name="search" value="@searchTerm" class="form-control" placeholder="Search by name or email..." />
            </div>
        </div>
        <div class="col-md-4">
            <select name="role" class="form-select filter-select">
                <option value="">All Roles</option>
                <option value="Admin" selected="@(roleFilter == "Admin")">Admin</option>
                <option value="Artist" selected="@(roleFilter == "Artist")">Artist</option>
                <option value="Client" selected="@(roleFilter == "Client")">Client</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-red w-100">
                <i class="fas fa-filter me-2"></i>Filter
            </button>
        </div>
    </form>

    <!-- User Table -->
    <div class="table-responsive">
        <table class="table table-dark table-hover">
            <thead>
                <tr>
                    <th><i class="fas fa-user me-2"></i>Full Name</th>
                    <th><i class="fas fa-envelope me-2"></i>Email</th>
                    <th><i class="fas fa-user-tag me-2"></i>Role</th>
                    <th><i class="fas fa-cogs me-2"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model
                .Where(u => string.IsNullOrEmpty(searchTerm) ||
                u.FullName.ToLower().Contains(searchTerm.ToString().ToLower()) ||
                u.Email.ToLower().Contains(searchTerm.ToString().ToLower()))
                .Where(u => string.IsNullOrEmpty(roleFilter) || u.Role == roleFilter)
                .OrderBy(u => u.Role))
                {
                    <tr>
                        <td class="text-warning fw-semibold">@user.FullName</td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge badge-admin p-2"><i class="fas fa-crown me-1"></i>@user.Role</span>
                            }
                            else if (user.Role == "Artist")
                            {
                                <span class="badge badge-artist p-2"><i class="fas fa-paint-brush me-1"></i>@user.Role</span>
                            }
                            else
                            {
                                <span class="badge badge-client p-2"><i class="fas fa-user me-1"></i>@user.Role</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-sm btn-warning text-dark" asp-action="UserDetails" asp-route-id="@user.Id">
                                    <i class="fas fa-eye"></i> Details
                                </a>

                                @if (user.Role != "Admin")
                                {
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-red"
                                                onclick="return confirm('Are you sure you want to delete this user?');">
                                            <i class="fas fa-trash-alt"></i> Delete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary" disabled>
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
