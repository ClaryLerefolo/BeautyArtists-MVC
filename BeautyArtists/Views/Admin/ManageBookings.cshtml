@model IEnumerable<BeautyArtists.Models.Booking>
@using static BeautyArtists.Models.Booking
@{
    ViewData["Title"] = "Manage Bookings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var bookingsList = Model.ToList();
    var pending = bookingsList.Count(b => b.Status == BookingStatus.Pending);
    var confirmed = bookingsList.Count(b => b.Status == BookingStatus.Confirmed);
    var completed = bookingsList.Count(b => b.Status == BookingStatus.Completed);
    var cancelled = bookingsList.Count(b => b.Status == BookingStatus.Cancelled);
    var rejected = bookingsList.Count(b => b.Status == BookingStatus.Rejected);
    var topService = bookingsList
        .GroupBy(b => b.UserService?.Service?.Name ?? "Unknown")
        .OrderByDescending(g => g.Count())
        .Select(g => g.Key).FirstOrDefault() ?? "—";
    var topArtist = bookingsList
        .GroupBy(b => !string.IsNullOrEmpty(b.UserService?.Artist?.FirstName)
            ? $"{b.UserService.Artist.FirstName} {b.UserService.Artist.LastName}".Trim()
            : "Unknown")
        .OrderByDescending(g => g.Count())
        .Select(g => g.Key).FirstOrDefault() ?? "—";
}

@section Styles {
    <style>
        .mb-eyebrow {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: rgba(255,215,0,0.35);
            display: block;
            margin-bottom: 4px;
        }

        .mb-heading {
            font-size: 1.5rem;
            font-weight: 900;
            color: #FFD700;
            margin: 0 0 24px;
        }

        /* ── STATS GRID ── */
        .bk-stats {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 12px;
            margin-bottom: 24px;
        }

        @@media (max-width: 1200px) {
            .bk-stats {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        @@media (max-width: 768px) {
            .bk-stats {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        .bk-stat {
            background: #0b0b0b;
            border: 1px solid rgba(255,215,0,0.1);
            border-radius: 12px;
            padding: 14px 16px;
        }

        .bk-stat-num {
            display: block;
            font-size: 1.5rem;
            font-weight: 900;
            color: #FFD700;
            line-height: 1;
            margin-bottom: 3px;
        }

        .bk-stat-label {
            display: block;
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.25);
        }

        .bk-stat.pending .bk-stat-num {
            color: #f0c808;
        }

        .bk-stat.confirmed .bk-stat-num {
            color: #00c853;
        }

        .bk-stat.completed .bk-stat-num {
            color: #2979ff;
        }

        .bk-stat.cancelled .bk-stat-num {
            color: #ff5555;
        }

        .bk-stat.rejected .bk-stat-num {
            color: #ff8c00;
        }

        .bk-stat.top {
            border-color: rgba(255,215,0,0.2);
        }

            .bk-stat.top .bk-stat-num {
                font-size: 0.82rem;
                font-weight: 700;
                color: #FFD700;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

        /* ── TABLE PANEL ── */
        .bk-panel {
            background: #0b0b0b;
            border: 1px solid rgba(255,215,0,0.1);
            border-radius: 16px;
            overflow: hidden;
        }

        .bk-panel-header {
            padding: 14px 20px;
            border-bottom: 1px solid rgba(255,215,0,0.07);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .bk-panel-title {
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
        }

            .bk-panel-title i {
                color: #FFD700;
                margin-right: 7px;
            }

        .bk-count {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.25);
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 2px 10px;
        }

        /* ── TABLE ── */
        .bk-table-wrap {
            overflow-x: auto;
        }

        .bk-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 760px;
        }

            .bk-table thead tr {
                background: rgba(255,215,0,0.04);
            }

            .bk-table th {
                padding: 11px 16px;
                font-size: 0.65rem;
                font-weight: 700;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: rgba(255,215,0,0.4);
                border-bottom: 1px solid rgba(255,215,0,0.07);
                white-space: nowrap;
            }

            .bk-table td {
                padding: 12px 16px;
                font-size: 0.82rem;
                color: rgba(255,255,255,0.65);
                border-bottom: 1px solid rgba(255,255,255,0.04);
                vertical-align: middle;
            }

            .bk-table tr:last-child td {
                border-bottom: none;
            }

            .bk-table tbody tr:hover td {
                background: rgba(255,215,0,0.02);
            }

        .bk-date {
            color: rgba(255,255,255,0.4);
            font-size: 0.78rem;
        }

        .bk-client {
            color: #fff;
            font-weight: 600;
        }

        .bk-artist {
            color: rgba(255,215,0,0.7);
            font-weight: 600;
        }

        .bk-service {
            color: rgba(255,255,255,0.55);
            font-size: 0.8rem;
        }

        /* Status badges */
        .bk-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            letter-spacing: 1px;
            text-transform: uppercase;
            white-space: nowrap;
        }

            .bk-badge.Pending {
                background: rgba(240,200,8,0.15);
                color: #f0c808;
                border: 1px solid rgba(240,200,8,0.25);
            }

            .bk-badge.Confirmed {
                background: rgba(0,200,83,0.12);
                color: #00c853;
                border: 1px solid rgba(0,200,83,0.25);
            }

            .bk-badge.Completed {
                background: rgba(41,121,255,0.12);
                color: #2979ff;
                border: 1px solid rgba(41,121,255,0.25);
            }

            .bk-badge.Cancelled {
                background: rgba(255,85,85,0.1);
                color: #ff5555;
                border: 1px solid rgba(255,85,85,0.2);
            }

            .bk-badge.Rejected {
                background: rgba(255,140,0,0.1);
                color: #ff8c00;
                border: 1px solid rgba(255,140,0,0.2);
            }

        /* Override select */
        .bk-override-select {
            background: rgba(255,255,255,0.04) !important;
            border: 1px solid rgba(255,215,0,0.15) !important;
            border-radius: 8px !important;
            color: rgba(255,255,255,0.6) !important;
            padding: 5px 10px !important;
            font-size: 0.75rem;
            cursor: pointer;
            transition: border-color 0.2s;
            min-width: 150px;
        }

            .bk-override-select:focus {
                outline: none !important;
                border-color: rgba(255,215,0,0.4) !important;
            }

            .bk-override-select option {
                background: #111;
                color: #fff;
            }

        /* Empty */
        .bk-empty {
            padding: 56px 20px;
            text-align: center;
            color: rgba(255,255,255,0.25);
            font-size: 0.85rem;
        }

            .bk-empty i {
                font-size: 2rem;
                color: rgba(255,215,0,0.12);
                display: block;
                margin-bottom: 12px;
            }
    </style>
}

<span class="mb-eyebrow">Administration</span>
<h1 class="mb-heading">Booking Management</h1>

@* ── STATS ── *@
<div class="bk-stats">
    <div class="bk-stat">
        <span class="bk-stat-num">@bookingsList.Count</span>
        <span class="bk-stat-label">Total</span>
    </div>
    <div class="bk-stat pending">
        <span class="bk-stat-num">@pending</span>
        <span class="bk-stat-label">Pending</span>
    </div>
    <div class="bk-stat confirmed">
        <span class="bk-stat-num">@confirmed</span>
        <span class="bk-stat-label">Confirmed</span>
    </div>
    <div class="bk-stat completed">
        <span class="bk-stat-num">@completed</span>
        <span class="bk-stat-label">Completed</span>
    </div>
    <div class="bk-stat cancelled">
        <span class="bk-stat-num">@cancelled</span>
        <span class="bk-stat-label">Cancelled</span>
    </div>
    <div class="bk-stat top">
        <span class="bk-stat-num" title="@topService">@topService</span>
        <span class="bk-stat-label">Top Service</span>
    </div>
    <div class="bk-stat top">
        <span class="bk-stat-num" title="@topArtist">@topArtist</span>
        <span class="bk-stat-label">Top Artist</span>
    </div>
</div>

@* ── TABLE ── *@
<div class="bk-panel">
    <div class="bk-panel-header">
        <span class="bk-panel-title">
            <i class="bi bi-calendar-check-fill"></i> All Bookings
        </span>
        <span class="bk-count">
            @bookingsList.Count booking@(bookingsList.Count != 1 ? "s" : "")
        </span>
    </div>

    @if (!bookingsList.Any())
    {
        <div class="bk-empty">
            <i class="bi bi-calendar-x"></i>
            No bookings yet.
        </div>
    }
    else
    {
        <div class="bk-table-wrap">
            <table class="bk-table">
                <thead>
                    <tr>
                        <th>Date &amp; Time</th>
                        <th>Client</th>
                        <th>Artist</th>
                        <th>Service</th>
                        <th>Status</th>
                        <th>Override</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in bookingsList.OrderByDescending(b => b.AppointmentDate))
                    {
                        string statusName = item.Status.ToString();
                        string artistName = !string.IsNullOrEmpty(item.UserService?.Artist?.FirstName)
                        ? $"{item.UserService.Artist.FirstName} {item.UserService.Artist.LastName}".Trim()
                        : item.UserService?.Artist?.UserName ?? "—";

                        <tr>
                            <td class="bk-date">
                                @item.AppointmentDate.ToString("dd MMM yyyy")<br />
                                <span style="font-size:0.72rem;color:rgba(255,255,255,0.3)">
                                    @item.AppointmentDate.ToString("HH:mm")
                                </span>
                            </td>
                            <td class="bk-client">
                                @item.Customer?.FirstName @item.Customer?.LastName
                            </td>
                            <td class="bk-artist">@artistName</td>
                            <td class="bk-service">
                                @(item.UserService?.Service?.Name ?? "—")
                            </td>
                            <td>
                                <span class="bk-badge @statusName">
                                    @statusName
                                </span>
                            </td>
                            <td>
                                <form asp-action="AdminOverride" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="bookingId" value="@item.Id" />
                                    <select name="newStatus" class="bk-override-select"
                                            onchange="this.form.submit()">
                                        <option selected disabled>Override...</option>
                                        <option value="Pending">Set Pending</option>
                                        <option value="Confirmed">Confirm</option>
                                        <option value="Cancelled">Cancel</option>
                                        <option value="Rejected">Reject</option>
                                        <option value="Completed">Complete</option>
                                    </select>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
