@model BeautyArtists.Models.ViewModels.PortfolioItemViewModel
@{
    ViewData["Title"] = "Edit Portfolio Item";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

<div class="container mt-5">
    <div class="card bg-dark text-white border-warning" style="border-radius: 15px; background-color: #121212 !important;">
        <div class="card-header border-0 mt-2">
            <h3 class="text-warning">Edit Work: "@Model.Title"</h3>
        </div>
        <div class="card-body">
            <form asp-action="EditPortfolioItem" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-5 border-end border-secondary">
                        <div class="mb-4">
                            <label class="text-warning fw-bold">Current Media</label>
                            <div class="upload-box border border-warning border-dashed p-3 text-center"
                                 style="border-style: dashed !important; cursor: pointer; min-height: 280px; display: flex; flex-direction: column; justify-content: center; align-items: center;"
                                 onclick="document.getElementById('mediaInput').click();">

                                <div id="previewContainer">
                                    @if (!string.IsNullOrEmpty(Model.ExistingMediaUrl))
                                    {
                                        @if (Model.MediaType == "Video")
                                        {
                                            <video id="mediaPreview" src="@Model.ExistingMediaUrl" controls style="max-height: 200px; max-width: 100%;"></video>
                                        }
                                        else
                                        {
                                            <img id="mediaPreview" src="@Model.ExistingMediaUrl" style="max-height: 200px; max-width: 100%; border-radius: 10px;" />
                                        }
                                    }
                                    else
                                    {
                                        <i class="fas fa-upload text-warning fa-3x mb-2"></i>
                                        <p>Click to upload media</p>
                                    }
                                </div>
                            </div>
                            <input type="file" id="mediaInput" asp-for="MediaFile" class="d-none" onchange="updatePreview(this)" />
                            <small class="text-muted d-block mt-2">Upload a new file to replace the current one (optional)</small>
                        </div>
                    </div>

                    <div class="col-md-7">
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="text-warning fw-bold">Title</label>
                                <input asp-for="Title" class="form-control bg-dark text-white border-secondary" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="text-warning fw-bold">Display Order</label>
                                <input asp-for="DisplayOrder" class="form-control bg-dark text-white border-secondary" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="text-warning fw-bold">Description</label>
                            <textarea asp-for="Description" rows="4" class="form-control bg-dark text-white border-secondary"></textarea>
                        </div>

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsFeatured" id="featuredSwitch" />
                            <label class="form-check-label text-white" for="featuredSwitch">Featured Item</label>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning w-100 fw-bold py-3 text-uppercase">Update Portfolio Item</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updatePreview(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const container = document.getElementById('previewContainer');
                    const fileType = input.files[0].type;

                    if (fileType.includes('video')) {
                        container.innerHTML = `<video src="${e.target.result}" controls style="max-height: 200px; max-width: 100%;"></video>`;
                    } else {
                        container.innerHTML = `<img src="${e.target.result}" style="max-height: 200px; max-width: 100%; border-radius: 10px;" />`;
                    }
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}