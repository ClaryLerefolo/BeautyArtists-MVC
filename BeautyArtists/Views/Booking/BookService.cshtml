@using BeautyArtists.Models
@model BeautyArtists.Models.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Book Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />

<div class="book-page">

    @* ── HERO ── *@
    <div class="book-hero">
        <div class="book-hero-glow"></div>
        <div class="container book-hero-inner">
            <div class="book-service-info">
                <span class="book-eyebrow">You're booking</span>
                <h1 class="book-service-name">@Model.ServiceName</h1>
                <div class="book-artist-line">
                    <span class="book-artist-label">with</span>
                    <span class="book-artist-name">@Model.ArtistName</span>
                </div>
            </div>
            <div class="book-price-block">
                <span class="book-price-label">Total</span>
                <span class="book-price">R @Model.Price.ToString("N0")</span>
            </div>
        </div>
    </div>

    <div class="container book-body">

        @* ── SERVER-SIDE VALIDATION SUMMARY ── *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="book-server-errors">
                <strong>Please fix the following:</strong>
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-controller="Booking" asp-action="ConfirmBooking" method="post" id="bookingForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UserServiceId" value="@Model.UserServiceId" />
            <input type="hidden" name="ArtistId" value="@Model.ArtistId" />
            <input type="hidden" name="Price" value="@Model.Price" />
            <input type="hidden" name="ServiceName" value="@Model.ServiceName" />
            <input type="hidden" name="ArtistName" value="@Model.ArtistName" />
            <input type="hidden" name="AvailabilitySlotId" id="selectedSlotId" value="0" />
            <input type="hidden" name="PreferredDate" id="selectedDate" value="" />

            @* Form explicitly targets the exact names expected by your backend model *@
            <input type="hidden" name="Latitude" id="latOutput" value="@Model.Latitude" />
            <input type="hidden" name="Longitude" id="lngOutput" value="@Model.Longitude" />

            @* ── STEP 1: CALENDAR ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">1</div>
                    <div>
                        <h2 class="book-step-title">Choose a Date &amp; Time</h2>
                        <p class="book-step-sub">Gold dates have available slots — click to see times</p>
                    </div>
                </div>

                <div id="calLoading" class="slots-loading">
                    <div class="slots-spinner"></div>
                    <span>Loading availability...</span>
                </div>

                <div id="calEmpty" class="slots-empty" style="display:none">
                    <div class="slots-empty-icon">📅</div>
                    <p>This artist has no available slots right now.</p>
                    <small>Check back soon or contact them directly.</small>
                </div>

                <div id="calendarWrap" style="display:none">
                    <div class="cal-nav">
                        <button type="button" class="cal-nav-btn" id="prevMonth">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.5">
                                <polyline points="15,18 9,12 15,6" />
                            </svg>
                        </button>
                        <span class="cal-month-label" id="monthLabel"></span>
                        <button type="button" class="cal-nav-btn" id="nextMonth">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.5">
                                <polyline points="9,18 15,12 9,6" />
                            </svg>
                        </button>
                    </div>

                    <div class="cal-grid cal-headers">
                        <div class="cal-day-header">Sun</div>
                        <div class="cal-day-header">Mon</div>
                        <div class="cal-day-header">Tue</div>
                        <div class="cal-day-header">Wed</div>
                        <div class="cal-day-header">Thu</div>
                        <div class="cal-day-header">Fri</div>
                        <div class="cal-day-header">Sat</div>
                    </div>

                    <div class="cal-grid" id="calDays"></div>

                    <div id="timeSlotSection" style="display:none">
                        <div class="cal-time-header">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                 stroke="#FFD700" stroke-width="2">
                                <circle cx="12" cy="12" r="10" />
                                <polyline points="12,6 12,12 16,14" />
                            </svg>
                            Available times for <strong id="selectedDateLabel"></strong>
                        </div>
                        <div class="time-slots-grid" id="timeSlotsGrid"></div>
                    </div>
                </div>

                <div id="slotError" class="book-field-error" style="display:none">
                    ⚠ Please select a date and time to continue.
                </div>
            </div>

            @* ── STEP 2: LOCATION TYPE ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">2</div>
                    <div>
                        <h2 class="book-step-title">Select Appointment Location</h2>
                        <p class="book-step-sub">Choose between a salon studio visit or mobile home service</p>
                    </div>
                </div>

                <div class="location-options-container">
                    <div class="location-card" id="cardWalkIn">
                        @* FIXED: name changed from SelectedLocationType to SelectLocationType *@
                        <input type="radio" name="SelectedLocationType" id="locWalkIn"
                               value="WalkIn"
                               @(Model.SelectedLocationType == LocationType.WalkIn ? "checked" : "")
                               class="location-radio" />
                        <div class="card-content">
                            <div class="card-icon">🏢</div>
                            <div class="card-text">
                                <h3>Walk-In</h3>
                                <p>At the artist's studio/salon.</p>
                            </div>
                        </div>
                        <div class="radio-indicator"></div>
                    </div>

                    <div class="location-card" id="cardHouseCall">
                        @* FIXED: name changed from SelectedLocationType to SelectLocationType *@
                        <input type="radio" name="SelectedLocationType" id="locHouseCall"
                               value="HouseCall"
                               @(Model.SelectedLocationType == LocationType.HouseCall ? "checked" : "")
                               class="location-radio" />
                        <div class="card-content">
                            <div class="card-icon">📍</div>
                            <div class="card-text">
                                <h3>House Call</h3>
                                <p>Artist travels out to your doorstep.</p>
                            </div>
                        </div>
                        <div class="radio-indicator"></div>
                    </div>
                </div>
                @* FIXED: asp-validation updated to track SelectLocationType *@
                <span asp-validation-for="SelectedLocationType" class="text-danger small"></span>

                <div id="houseCallWrapper" class="housecall-container"
                     style="display:none; margin-top:20px;">

                    <div class="map-instruction">
                        📍 Search your address below or tap directly on the map to drop your pin:
                    </div>

                    <div id="leafletMap" class="map-frame"></div>

                    <div class="address-input-wrapper">
                        <label class="book-field-label">
                            Descriptive Street Address / Complex Unit No:
                        </label>
                        <textarea name="HouseCallAddress" id="textAddress"
                                  class="book-textarea" rows="2"
                                  placeholder="e.g. Unit 42, Serengeti Estates, 12 Mockingbird Lane...">@Model.HouseCallAddress</textarea>
                        <span asp-validation-for="HouseCallAddress" class="text-danger small"></span>
                    </div>

                    <div id="mapValidationError" class="book-field-error" style="display:none">
                        ⚠ Please pinpoint your location on the map and enter an address.
                    </div>
                </div>
            </div>

            @* ── STEP 3: NOTES ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">3</div>
                    <div>
                        <h2 class="book-step-title">Any Special Requests?</h2>
                        <p class="book-step-sub">Optional — tell the artist anything they should know</p>
                    </div>
                </div>
                <textarea name="Notes" class="book-textarea"
                          placeholder="e.g. I prefer natural looks, I have sensitive skin..."
                          maxlength="1000" rows="3">@Model.Notes</textarea>
            </div>

            @* ── STEP 4: SUMMARY ── *@
            <div class="book-section book-summary" id="bookSummary" style="display:none">
                <div class="book-summary-row">
                    <span>Service</span>
                    <strong>@Model.ServiceName</strong>
                </div>
                <div class="book-summary-row">
                    <span>Artist</span>
                    <strong>@Model.ArtistName</strong>
                </div>
                <div class="book-summary-row">
                    <span>Appointment Type</span>
                    <strong id="summaryLocationType">Walk-In</strong>
                </div>
                <div class="book-summary-row">
                    <span>Date &amp; Time</span>
                    <strong id="summarySlot">—</strong>
                </div>
                <div class="book-summary-row book-summary-total">
                    <span>Base Service Total</span>
                    <strong>R @Model.Price.ToString("N0")</strong>
                </div>
                <div class="travel-cost-disclaimer" id="travelDisclaimer" style="display:none">
                    ℹ️ <em>
                        Transport costs for house calls are calculated and added by your artist
                        when reviewing the request.
                    </em>
                </div>
            </div>

            <button type="submit" class="book-confirm-btn">
                <span>Confirm Booking Request</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5">
                    <polyline points="20,6 9,17 4,12" />
                </svg>
            </button>
        </form>
    </div>
</div>

<style>
    /* (Styles remain entirely unchanged to keep your design exactly as it is) */
    .book-page {
        background: #000;
        min-height: 100vh;
        padding-bottom: 80px;
    }

    .book-hero {
        position: relative;
        padding: 50px 0 40px;
        overflow: hidden;
    }

    .book-hero-glow {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg,#100000 0%,#1a0900 50%,#050505 100%);
    }

        .book-hero-glow::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%,rgba(179,0,0,0.2) 0%,transparent 55%),radial-gradient(ellipse at 80% 50%,rgba(255,215,0,0.06) 0%,transparent 55%);
        }

    .book-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .book-eyebrow {
        display: block;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(255,215,0,0.4);
        margin-bottom: 8px;
    }

    .book-service-name {
        color: #FFD700;
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 8px;
        text-shadow: 0 0 30px rgba(255,215,0,0.25);
        line-height: 1.1;
    }

    .book-artist-line {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .book-artist-label {
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
    }

    .book-artist-name {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .book-price-block {
        text-align: right;
    }

    .book-price-label {
        display: block;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.25);
        margin-bottom: 4px;
    }

    .book-price {
        display: block;
        font-size: 2.4rem;
        font-weight: 800;
        color: #FFD700;
        text-shadow: 0 0 20px rgba(255,215,0,0.3);
    }

    .book-server-errors {
        background: rgba(255,0,0,0.08);
        border: 1px solid rgba(255,0,0,0.3);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        color: #ff6666;
        font-size: 0.85rem;
    }

        .book-server-errors ul {
            margin: 8px 0 0 16px;
        }

        .book-server-errors li {
            margin-bottom: 4px;
        }

    .book-body {
        padding-top: 40px;
        max-width: 720px;
    }

    .book-section {
        margin-bottom: 36px;
        background: #0b0b0b;
        border: 1px solid rgba(255,215,0,0.1);
        border-radius: 18px;
        padding: 28px;
    }

    .book-step-header {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 24px;
    }

    .book-step-num {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg,#b30000,#FFD700);
        color: #000;
        font-size: 0.95rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .book-step-title {
        color: #FFD700;
        font-size: 1.1rem;
        font-weight: 800;
        margin: 0 0 4px;
    }

    .book-step-sub {
        color: rgba(255,255,255,0.3);
        font-size: 0.78rem;
        margin: 0;
    }

    .location-options-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        margin-top: 16px;
    }

    .location-card {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #121212;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.25s ease;
        -webkit-tap-highlight-color: transparent;
    }

    .card-content {
        display: flex;
        align-items: center;
        gap: 16px;
        flex: 1;
        padding-right: 32px;
    }

    .card-icon {
        font-size: 1.5rem;
        line-height: 1;
    }

    .card-text h3 {
        color: #ffffff;
        font-size: 1.1rem;
        margin: 0 0 4px;
        font-weight: 600;
    }

    .card-text p {
        color: #8a8a8a;
        font-size: 0.85rem;
        margin: 0;
        line-height: 1.3;
    }

    .location-radio {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }

    .radio-indicator {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        width: 18px;
        height: 18px;
        border: 2px solid #555;
        border-radius: 50%;
        background: transparent;
        transition: all 0.2s;
    }

    .location-card.active {
        border-color: #FFD700;
        background: #161204;
        box-shadow: 0 0 15px rgba(255,215,0,0.15);
    }

        .location-card.active .radio-indicator {
            border-color: #FFD700;
            background: #FFD700;
            box-shadow: inset 0 0 0 3px #121212;
        }

    .housecall-container {
        animation: fadeIn 0.3s ease-in-out;
    }

    .map-instruction {
        font-size: 0.8rem;
        color: rgba(255,215,0,0.8);
        margin-bottom: 10px;
    }

    .map-frame {
        height: 380px;
        width: 100%;
        background: #151515;
        border-radius: 12px;
        border: 1px solid rgba(255,215,0,0.2);
        margin-bottom: 20px;
        position: relative;
    }

    .book-field-label {
        display: block;
        color: rgba(255,255,255,0.6);
        font-size: 0.82rem;
        margin-bottom: 8px;
    }

    .leaflet-control-geocoder {
        background: #111 !important;
        border: 1.5px solid #FFD700 !important;
        border-radius: 8px !important;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5) !important;
        color: #fff !important;
    }

    .leaflet-control-geocoder-form input {
        background: #111 !important;
        color: #fff !important;
        font-size: 0.85rem !important;
        padding: 8px 12px !important;
        border: none !important;
        outline: none !important;
        width: 240px !important;
    }

    .leaflet-control-geocoder-alternatives {
        background-color: #fff !important;
        border: 1px solid #ccc !important;
        list-style: none !important;
        padding: 0 !important;
        margin: 0 !important;
        max-height: 180px !important;
        overflow-y: auto !important;
        width: 100% !important;
        box-sizing: border-box !important;
        position: relative !important;
        z-index: 99999 !important;
        border-radius: 0 0 8px 8px !important;
    }

        .leaflet-control-geocoder-alternatives li {
            padding: 10px 12px !important;
            cursor: pointer !important;
            color: #222 !important;
            font-weight: 500 !important;
            border-bottom: 1px solid #eee !important;
            font-size: 0.85rem !important;
        }

            .leaflet-control-geocoder-alternatives li:hover {
                background-color: #f5f5f5 !important;
            }

    .slots-loading {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.4);
        font-size: 0.85rem;
        padding: 20px 0;
    }

    .slots-spinner {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid rgba(255,215,0,0.2);
        border-top-color: #FFD700;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(4px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .slots-empty {
        text-align: center;
        padding: 32px 0;
        color: rgba(255,255,255,0.3);
    }

    .slots-empty-icon {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .slots-empty p {
        margin: 0 0 4px;
        font-size: 0.9rem;
    }

    .slots-empty small {
        font-size: 0.75rem;
    }

    .cal-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .cal-nav-btn {
        background: rgba(255,215,0,0.08);
        border: 1px solid rgba(255,215,0,0.15);
        color: rgba(255,215,0,0.7);
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }

        .cal-nav-btn:hover {
            background: rgba(255,215,0,0.18);
            color: #FFD700;
        }

    .cal-month-label {
        color: #FFD700;
        font-size: 0.95rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .cal-grid {
        display: grid;
        grid-template-columns: repeat(7,1fr);
        gap: 6px;
        margin-bottom: 6px;
    }

    .cal-headers {
        margin-bottom: 2px;
    }

    .cal-day-header {
        text-align: center;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
        padding: 6px 0;
    }

    .cal-day {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        position: relative;
        transition: all 0.2s;
    }

        .cal-day.empty {
            background: transparent;
            pointer-events: none;
        }

        .cal-day.past {
            color: rgba(255,255,255,0.12);
            pointer-events: none;
        }

        .cal-day.no-slot {
            color: rgba(255,255,255,0.2);
            pointer-events: none;
        }

        .cal-day.today {
            color: rgba(255,255,255,0.45);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .cal-day.has-slot {
            background: linear-gradient(135deg,#b30000,#FFD700);
            color: #000;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(255,215,0,0.2);
        }

            .cal-day.has-slot:hover {
                transform: scale(1.1);
                box-shadow: 0 0 20px rgba(255,215,0,0.45);
            }

        .cal-day.selected {
            background: #FFD700 !important;
            color: #000 !important;
            font-weight: 900 !important;
            transform: scale(1.15) !important;
            box-shadow: 0 0 28px rgba(255,215,0,0.6) !important;
        }

    .cal-slot-dot {
        position: absolute;
        bottom: 4px;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgba(0,0,0,0.35);
    }

    .cal-time-header {
        display: flex;
        align-items: center;
        gap: 7px;
        color: rgba(255,255,255,0.4);
        font-size: 0.8rem;
        margin: 20px 0 12px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,215,0,0.08);
    }

        .cal-time-header strong {
            color: #FFD700;
        }

    .time-slots-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .time-slot-btn {
        background: #111;
        border: 1.5px solid rgba(255,215,0,0.15);
        border-radius: 10px;
        color: #fff;
        padding: 10px 20px;
        font-size: 0.82rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .time-slot-btn:hover {
            border-color: rgba(255,215,0,0.4);
            background: #1a1000;
            transform: translateY(-2px);
        }

        .time-slot-btn.selected {
            background: rgba(255,215,0,0.1);
            border-color: #FFD700;
            color: #FFD700;
            box-shadow: 0 0 14px rgba(255,215,0,0.2);
        }

    .book-textarea {
        width: 100%;
        background: #111;
        border: 1.5px solid rgba(255,215,0,0.1);
        border-radius: 12px;
        color: #fff;
        padding: 14px 16px;
        font-size: 0.9rem;
        resize: vertical;
        outline: none;
        transition: border-color 0.2s;
    }

        .book-textarea:focus {
            border-color: rgba(255,215,0,0.4);
            background: #131300;
        }

        .book-textarea::placeholder {
            color: rgba(255,255,255,0.2);
        }

    .book-summary {
        border-color: rgba(255,215,0,0.2);
    }

    .book-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 0.88rem;
    }

        .book-summary-row:last-child {
            border-bottom: none;
        }

        .book-summary-row span {
            color: rgba(255,255,255,0.4);
        }

        .book-summary-row strong {
            color: #fff;
        }

    .book-summary-total span {
        color: rgba(255,215,0,0.6) !important;
        font-weight: 700;
    }

    .book-summary-total strong {
        color: #FFD700 !important;
        font-size: 1.1rem;
    }

    .travel-cost-disclaimer {
        font-size: 0.75rem;
        color: rgba(255,215,0,0.6);
        background: rgba(255,215,0,0.04);
        padding: 10px;
        border-radius: 8px;
        margin-top: 10px;
        line-height: 1.4;
    }

    .book-confirm-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 18px;
        background: linear-gradient(135deg,#b30000,#FFD700);
        color: #000;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .book-confirm-btn:hover {
            background: linear-gradient(135deg,#FFD700,#b30000);
            box-shadow: 0 0 30px rgba(255,215,0,0.35);
            transform: translateY(-2px);
        }

    .book-field-error {
        color: #ff4444;
        font-size: 0.8rem;
        margin-top: 10px;
        padding: 8px 12px;
        background: rgba(255,0,0,0.08);
        border-radius: 8px;
        border-left: 3px solid #ff4444;
    }
    @@media (min-width:600px) {
        .location-options-container

    {
        flex-direction: row;
    }

    .location-card {
        flex: 1;
    }

    }
</style>
@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>

    <script>
        const artistId = '@Model.ArtistId';

        // FIX: Read initial location type from the server model so that
        //      on a validation-fail return the correct card is pre-selected
        const initialLocationType = '@Model.SelectedLocationType.ToString()';

        let allSlots     = [];
        let selectedSlot = null;
        let currentYear, currentMonth;
        let map          = null;
        let mapMarker    = null;

        // ── DOM READY ──
        document.addEventListener('DOMContentLoaded', function () {

            // Location card click handlers
            document.getElementById('cardWalkIn').addEventListener('click', function () {
                updateLocationFlow('WalkIn');
            });
            document.getElementById('cardHouseCall').addEventListener('click', function () {
                updateLocationFlow('HouseCall');
            });

            // FIX: On page load, apply whichever type the server sent back.
            //      This handles both first load (WalkIn default) AND the
            //      case where validation failed and we return with HouseCall.
            updateLocationFlow(initialLocationType);
        });

        // ── FETCH AVAILABILITY ──
        fetch('/ArtistAvailability/GetSlots?artistId=' + artistId)
            .then(function (res) { return res.json(); })
            .then(function (slots) {
                document.getElementById('calLoading').style.display = 'none';

                if (!slots || slots.length === 0) {
                    document.getElementById('calEmpty').style.display = 'block';
                    return;
                }

                allSlots = slots;
                const now = new Date();
                currentYear  = now.getFullYear();
                currentMonth = now.getMonth();
                document.getElementById('calendarWrap').style.display = 'block';
                renderCalendar(currentYear, currentMonth);
            })
            .catch(function () {
                document.getElementById('calLoading').style.display = 'none';
                document.getElementById('calEmpty').style.display   = 'block';
            });

        // ── MONTH NAV ──
        document.getElementById('prevMonth').addEventListener('click', function () {
            currentMonth--;
            if (currentMonth < 0) { currentMonth = 11; currentYear--; }
            renderCalendar(currentYear, currentMonth);
        });
        document.getElementById('nextMonth').addEventListener('click', function () {
            currentMonth++;
            if (currentMonth > 11) { currentMonth = 0; currentYear++; }
            renderCalendar(currentYear, currentMonth);
        });

        // ── RENDER CALENDAR ──
        function renderCalendar(year, month) {
            var monthNames = ['January','February','March','April','May','June',
                              'July','August','September','October','November','December'];
            document.getElementById('monthLabel').textContent = monthNames[month] + ' ' + year;

            var grid = document.getElementById('calDays');
            grid.innerHTML = '';

            var availDates = new Set(
                allSlots.filter(function (s) {
                    var parts  = s.date.split('-');
                    var sYear  = parseInt(parts[0], 10);
                    var sMonth = parseInt(parts[1], 10) - 1;
                    return sYear === year && sMonth === month;
                }).map(function (s) { return s.date; })
            );

            var firstDay    = new Date(year, month, 1).getDay();
            var daysInMonth = new Date(year, month + 1, 0).getDate();
            var today       = new Date();
            today.setHours(0, 0, 0, 0);

            for (var i = 0; i < firstDay; i++) {
                var empty = document.createElement('div');
                empty.className = 'cal-day empty';
                grid.appendChild(empty);
            }

            for (var d = 1; d <= daysInMonth; d++) {
                var dateStr  = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
                var cellDate = new Date(year, month, d);
                var cell     = document.createElement('div');
                cell.textContent = d;

                if (cellDate < today) {
                    cell.className = 'cal-day past';
                } else if (availDates.has(dateStr)) {
                    cell.className = 'cal-day has-slot';
                    var dot = document.createElement('div');
                    dot.className = 'cal-slot-dot';
                    cell.appendChild(dot);
                    (function (ds, c, dd, mm, yy) {
                        c.addEventListener('click', function () {
                            selectDate(ds, c, dd, mm, yy);
                        });
                    })(dateStr, cell, d, month, year);
                } else if (cellDate.getTime() === today.getTime()) {
                    cell.className = 'cal-day today';
                } else {
                    cell.className = 'cal-day no-slot';
                }
                grid.appendChild(cell);
            }

            document.getElementById('timeSlotSection').style.display = 'none';
        }

        // ── SELECT DATE ──
        function selectDate(dateStr, cell, day, month, year) {
            document.querySelectorAll('.cal-day.has-slot').forEach(function (c) {
                c.classList.remove('selected');
            });
            cell.classList.add('selected');

            var daySlots   = allSlots.filter(function (s) { return s.date === dateStr; });
            var monthNames = ['Jan','Feb','Mar','Apr','May','Jun',
                              'Jul','Aug','Sep','Oct','Nov','Dec'];
            var formattedDateLabel = monthNames[month] + ' ' + day + ', ' + year;

            document.getElementById('selectedDateLabel').textContent = formattedDateLabel;

            var grid = document.getElementById('timeSlotsGrid');
            grid.innerHTML = '';

            daySlots.forEach(function (slot) {
                var parts    = slot.display.split(': ');
                var timePart = parts[1] || slot.display;
                var btn      = document.createElement('button');
                btn.type      = 'button';
                btn.className = 'time-slot-btn';
                btn.innerHTML =
                    '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">' +
                    '<circle cx="12" cy="12" r="10"></circle>' +
                    '<polyline points="12,6 12,12 16,14"></polyline></svg>' +
                    '<span>' + timePart + '</span>';

                (function (s, t, fd) {
                    btn.addEventListener('click', function () {
                        document.querySelectorAll('.time-slot-btn').forEach(function (b) {
                            b.classList.remove('selected');
                        });
                        btn.classList.add('selected');
                        document.getElementById('selectedSlotId').value = s.id;
                        document.getElementById('selectedDate').value   = s.date;
                        document.getElementById('summarySlot').textContent =
                            fd + ' at ' + t;
                        checkSummaryVisibility();
                    });
                })(slot, timePart, formattedDateLabel);

                grid.appendChild(btn);
            });

            document.getElementById('timeSlotSection').style.display = 'block';
        }

        // ── LOCATION FLOW ──
        function updateLocationFlow(type) {
            document.querySelectorAll('.location-card').forEach(function (c) {
                c.classList.remove('active');
            });

            if (type === 'HouseCall') {
                document.getElementById('cardHouseCall').classList.add('active');
                document.getElementById('locHouseCall').checked          = true;
                document.getElementById('houseCallWrapper').style.display = 'block';
                document.getElementById('summaryLocationType').textContent = 'House Call';
                document.getElementById('travelDisclaimer').style.display  = 'block';

                // Initialise map — FIX: 150ms timeout is safer on slow connections
                if (!map && document.getElementById('leafletMap')) {
                    setTimeout(function () {
                        map = L.map('leafletMap').setView([-26.8649, 26.6570], 13);

                        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                            attribution: '&copy; OpenStreetMap &copy; CARTO'
                        }).addTo(map);

                        map.on('click', function (e) {
                            updateMarker(e.latlng.lat, e.latlng.lng);
                        });

                        var geocoder      = L.Control.Geocoder.nominatim();
                        var searchControl = L.Control.geocoder({
                            geocoder: geocoder,
                            defaultMarkGeocode: false,
                            placeholder: 'Search suburbs, streets...'
                        }).addTo(map);

                        searchControl.on('markgeocode', function (e) {
                            var bbox = e.geocode.bbox;
                            var poly = L.polygon([
                                bbox.getSouthWest(), bbox.getNorthWest(),
                                bbox.getNorthEast(), bbox.getSouthEast()
                            ]);
                            map.fitBounds(poly.getBounds());
                            updateMarker(e.geocode.center.lat, e.geocode.center.lng);

                            var fullAddress = e.geocode.name;
                            if (e.geocode.properties && e.geocode.properties.address) {
                                var addr        = e.geocode.properties.address;
                                var houseNumber = addr.house_number || addr.street_number || addr.building || '';
                                var road        = addr.road || addr.street || '';
                                var suburb      = addr.suburb || addr.neighbourhood || '';
                                var city        = addr.city || addr.town || '';
                                if (houseNumber && road) {
                                    fullAddress = houseNumber + ' ' + road;
                                    if (suburb) fullAddress += ', ' + suburb;
                                    if (city && city !== suburb) fullAddress += ', ' + city;
                                }
                            }
                            document.getElementById('textAddress').value = fullAddress;
                        });

                        var container = searchControl.getContainer();
                        if (container) {
                            L.DomEvent.disableScrollPropagation(container);
                            L.DomEvent.disableClickPropagation(container);
                        }

                        map.invalidateSize();

                        // FIX: If we're returning from a validation fail and the user
                        //      had already pinned a location, restore the marker
                        var existingLat = document.getElementById('latOutput').value;
                        var existingLng = document.getElementById('lngOutput').value;
                        if (existingLat && existingLng &&
                            parseFloat(existingLat) !== 0 &&
                            parseFloat(existingLng) !== 0) {
                            updateMarker(parseFloat(existingLat), parseFloat(existingLng));
                            map.setView([parseFloat(existingLat), parseFloat(existingLng)], 15);
                        }

                    }, 150);
                } else if (map) {
                    setTimeout(function () { map.invalidateSize(); }, 150);
                }

            } else {
                // Walk-In
                document.getElementById('cardWalkIn').classList.add('active');
                document.getElementById('locWalkIn').checked            = true;
                document.getElementById('houseCallWrapper').style.display = 'none';
                document.getElementById('summaryLocationType').textContent = 'Walk-In';
                document.getElementById('travelDisclaimer').style.display  = 'none';
            }

            checkSummaryVisibility();
        }

        // ── UPDATE MAP MARKER ──
        function updateMarker(lat, lng) {
            document.getElementById('latOutput').value = lat;
            document.getElementById('lngOutput').value = lng;
            document.getElementById('mapValidationError').style.display = 'none';

            if (mapMarker) {
                mapMarker.setLatLng([lat, lng]);
            } else if (map) {
                mapMarker = L.marker([lat, lng], { draggable: true }).addTo(map);
                mapMarker.on('dragend', function () {
                    var pos = mapMarker.getLatLng();
                    document.getElementById('latOutput').value = pos.lat;
                    document.getElementById('lngOutput').value = pos.lng;
                });
            }
        }

        // ── SHOW SUMMARY WHEN SLOT IS SELECTED ──
        function checkSummaryVisibility() {
            var hasSlot = parseInt(document.getElementById('selectedSlotId').value) > 0;
            if (hasSlot) {
                document.getElementById('bookSummary').style.display = 'block';
            }
        }

        // ── FORM SUBMIT VALIDATION ──
        document.getElementById('bookingForm').addEventListener('submit', function (e) {
            var isValid = true;
            var slotId  = parseInt(document.getElementById('selectedSlotId').value);

            // Slot must be selected
            if (!slotId || slotId <= 0) {
                var slotErr = document.getElementById('slotError');
                slotErr.style.display = 'block';
                slotErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
                isValid = false;
            } else {
                document.getElementById('slotError').style.display = 'none';
            }

            // House Call: map pin + address required
            if (document.getElementById('locHouseCall').checked) {
                var lat  = document.getElementById('latOutput').value;
                var lng  = document.getElementById('lngOutput').value;
                var addr = document.getElementById('textAddress').value.trim();

                // FIX: check for empty string OR literal "0" / "0.0" from default
                var hasPin = lat && lng &&
                             parseFloat(lat) !== 0 &&
                             parseFloat(lng) !== 0;

                if (!hasPin || !addr) {
                    document.getElementById('mapValidationError').style.display = 'block';
                    document.getElementById('mapValidationError')
                        .scrollIntoView({ behavior: 'smooth', block: 'center' });
                    isValid = false;
                } else {
                    document.getElementById('mapValidationError').style.display = 'none';
                }
            }

            if (!isValid) e.preventDefault();
        });
    </script>
}
