@using BeautyArtists.Models
@model BeautyArtists.Models.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Book Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<div class="book-page">

    @* ── HERO ── *@
    <div class="book-hero">
        <div class="book-hero-glow"></div>
        <div class="container book-hero-inner">
            <div class="book-service-info">
                <span class="book-eyebrow">You're booking</span>
                <h1 class="book-service-name">@Model.ServiceName</h1>
                <div class="book-artist-line">
                    <span class="book-artist-label">with</span>
                    <span class="book-artist-name">@Model.ArtistName</span>
                </div>
            </div>
            <div class="book-price-block">
                <span class="book-price-label">Total</span>
                <span class="book-price">R @Model.Price.ToString("N0")</span>
            </div>
        </div>
    </div>

    <div class="container book-body">

        @* ── SERVER-SIDE VALIDATION SUMMARY ── *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="book-server-errors">
                <strong>Please fix the following issues:</strong>
                <ul>
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        foreach (var error in modelState.Errors)
                        {
                            if (!string.IsNullOrEmpty(error.ErrorMessage))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    }
                </ul>
            </div>
        }

        <form asp-controller="Booking" asp-action="ConfirmBooking" method="post" id="bookingForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UserServiceId" value="@Model.UserServiceId" />
            <input type="hidden" name="ArtistId" value="@Model.ArtistId" />
            <input type="hidden" name="Price" value="@Model.Price" />
            <input type="hidden" name="ServiceName" value="@Model.ServiceName" />
            <input type="hidden" name="ArtistName" value="@Model.ArtistName" />

            @* Hidden fields *@
            <input type="hidden" name="AvailabilitySlotId" id="AvailabilitySlotId" value="@Model.AvailabilitySlotId" />
            <input type="hidden" name="PreferredDate" id="PreferredDate" value="@Model.PreferredDate.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="Latitude" id="Latitude" value="@Model.Latitude" />
            <input type="hidden" name="Longitude" id="Longitude" value="@Model.Longitude" />

            @* ── STEP 1: CALENDAR ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">1</div>
                    <div>
                        <h2 class="book-step-title">Choose a Date &amp; Time</h2>
                        <p class="book-step-sub">Gold dates have available slots — click to see times</p>
                    </div>
                </div>

                <div id="calLoading" class="slots-loading">
                    <div class="slots-spinner"></div>
                    <span>Loading availability...</span>
                </div>

                <div id="calEmpty" class="slots-empty" style="display:none">
                    <div class="slots-empty-icon">📅</div>
                    <p>This artist has no available slots right now.</p>
                    <small>Check back soon or contact them directly.</small>
                </div>

                <div id="calendarWrap" style="display:none">
                    <div class="cal-nav">
                        <button type="button" class="cal-nav-btn" id="prevMonth">◀</button>
                        <span class="cal-month-label" id="monthLabel"></span>
                        <button type="button" class="cal-nav-btn" id="nextMonth">▶</button>
                    </div>
                    <div class="cal-grid cal-headers">
                        <div class="cal-day-header">Sun</div>
                        <div class="cal-day-header">Mon</div>
                        <div class="cal-day-header">Tue</div>
                        <div class="cal-day-header">Wed</div>
                        <div class="cal-day-header">Thu</div>
                        <div class="cal-day-header">Fri</div>
                        <div class="cal-day-header">Sat</div>
                    </div>
                    <div class="cal-grid" id="calDays"></div>
                    <div id="timeSlotSection" style="display:none">
                        <div class="cal-time-header">Available times for <strong id="selectedDateLabel"></strong></div>
                        <div class="time-slots-grid" id="timeSlotsGrid"></div>
                    </div>
                </div>
                <div id="slotError" class="book-field-error" style="display:none">⚠ Please select a date and time to continue.</div>
            </div>

            @* ── STEP 2: LOCATION TYPE ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">2</div>
                    <div>
                        <h2 class="book-step-title">Select Appointment Location</h2>
                        <p class="book-step-sub">Choose between a salon studio visit or mobile home service</p>
                    </div>
                </div>

                <div class="location-options-container">
                    <div class="location-card" id="cardWalkIn">
                        @Html.RadioButtonFor(m => m.SelectedLocationType, LocationType.WalkIn, new { id = "locWalkIn", @class = "location-radio" })
                        <div class="card-content">
                            <div class="card-icon">🏢</div>
                            <div class="card-text">
                                <h3>Walk-In</h3>
                                <p>At the artist's studio/salon.</p>
                            </div>
                        </div>
                        <div class="radio-indicator"></div>
                    </div>
                    <div class="location-card" id="cardHouseCall">
                        @Html.RadioButtonFor(m => m.SelectedLocationType, LocationType.HouseCall, new { id = "locHouseCall", @class = "location-radio" })
                        <div class="card-content">
                            <div class="card-icon">📍</div>
                            <div class="card-text">
                                <h3>House Call</h3>
                                <p>Artist travels out to your doorstep.</p>
                            </div>
                        </div>
                        <div class="radio-indicator"></div>
                    </div>
                </div>
                <span asp-validation-for="SelectedLocationType" class="text-danger small"></span>

                <!-- ─── ENHANCED HOUSE CALL SECTION – ADDRESS FIELDS NOW ABOVE MAP ─── -->
                <div id="houseCallWrapper" class="housecall-container" style="display:none; margin-top:20px;">

                    <!-- ─── ADDRESS FIELDS (MOVED TO TOP) ─── -->
                    <div class="address-highlight-wrapper">
                        <div class="address-warning-badge">
                            ⚠️ REQUIRED FOR HOUSE CALLS ⚠️
                        </div>

                        <div class="address-input-container">
                            <div class="address-icon">📍📝</div>
                            <div class="address-field-content">
                                <label class="address-label">
                                    COMPLETE DELIVERY ADDRESS
                                    <span class="required-star">*</span>
                                </label>

                                <div class="address-help-text">
                                    <strong>❗ IMPORTANT:</strong> The artist needs your EXACT location to travel to you!
                                </div>

                                <div class="address-format-example">
                                    <div class="example-title">📋 Include ALL of the following:</div>
                                    <ul class="example-list">
                                        <li><strong>House/Flat/Apartment Number</strong> <span class="example">(e.g., 42, Flat 3B)</span></li>
                                        <li><strong>Street Name & Number</strong> <span class="example">(e.g., 2255 Mosime Street)</span></li>
                                        <li><strong>Suburb or Area</strong> <span class="example">(e.g., Klerksdorp, 2571)</span></li>
                                        <li><strong>Complex/Building Name</strong> <span class="example">(e.g., Serengeti Estates)</span></li>
                                        <li><strong>Landmarks or Directions</strong> <span class="example">(e.g., Near the mall)</span></li>
                                    </ul>
                                </div>

                                <!-- ─── 3 STRUCTURED FIELDS ─── -->
                                <div class="address-fields-grid">
                                    <div class="address-field-group">
                                        <label class="field-label">House/Unit Number <span class="required-star">*</span></label>
                                        <input asp-for="HouseNumber"
                                               class="address-input-field"
                                               placeholder="e.g., 42, Flat 3B, Unit 5A"
                                               id="houseNumberInput"
                                               autocomplete="off" />
                                    </div>

                                    <div class="address-field-group">
                                        <label class="field-label">Street Address <span class="required-star">*</span></label>
                                        <input asp-for="StreetAddress"
                                               class="address-input-field"
                                               placeholder="e.g., 2255 Mosime Street, Klerksdorp"
                                               id="streetAddressInput"
                                               autocomplete="off" />
                                    </div>

                                    <div class="address-field-group">
                                        <label class="field-label">Area / Postal Code <span class="required-star">*</span></label>
                                        <input asp-for="AreaCode"
                                               class="address-input-field"
                                               placeholder="e.g., 2571, Sandton"
                                               id="areaCodeInput"
                                               autocomplete="off" />
                                    </div>
                                </div>

                                <!-- ─── COMBINED ADDRESS (Hidden, for backward compatibility) ─── -->
                                <input type="hidden" asp-for="HouseCallAddress" id="textAddress" />

                                <div class="address-warning-message">
                                    ⚡ Your artist will use this EXACT address to find you on their map!
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ─── MAP SECTION (NOW BELOW ADDRESS) ─── -->
                    <div class="map-section-wrapper">
                        <div class="map-instruction">
                            📍 Tap directly on the map to drop your pin, or search below:
                        </div>

                        <div class="map-search-wrapper">
                            <input type="text" id="mapSearchInput" class="map-search-input" placeholder="🔍 Search for an address, suburb, or landmark..." />
                            <button type="button" id="searchAddressBtn" class="map-search-btn">Go</button>
                        </div>

                        <div id="leafletMap" class="map-frame"></div>
                    </div>

                    <div id="mapValidationError" class="book-field-error" style="display:none">
                        ⚠ Please pinpoint your location on the map AND enter a complete address above.
                    </div>
                </div>
            </div>

            @* ── STEP 3: NOTES ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">3</div>
                    <div>
                        <h2 class="book-step-title">Any Special Requests?</h2>
                        <p class="book-step-sub">Optional — tell the artist anything they should know</p>
                    </div>
                </div>
                <textarea asp-for="Notes" class="book-textarea" placeholder="e.g. I prefer natural looks, I have sensitive skin..." rows="3"></textarea>
            </div>

            @* ── STEP 4: SUMMARY ── *@
            <div class="book-section book-summary" id="bookSummary" style="display:none">
                <div class="book-summary-row"><span>Service</span><strong>@Model.ServiceName</strong></div>
                <div class="book-summary-row"><span>Artist</span><strong>@Model.ArtistName</strong></div>
                <div class="book-summary-row"><span>Appointment Type</span><strong id="summaryLocationType">Walk-In</strong></div>
                <div class="book-summary-row"><span>Date &amp; Time</span><strong id="summarySlot">—</strong></div>
                <div class="book-summary-row book-summary-total"><span>Base Service Total</span><strong>R @Model.Price.ToString("N0")</strong></div>
                <div class="travel-cost-disclaimer" id="travelDisclaimer" style="display:none">ℹ️ <em>Transport costs for house calls are calculated and added by your artist when reviewing the request.</em></div>
            </div>

            <button type="submit" class="book-confirm-btn">Confirm Booking Request ✓</button>
        </form>
    </div>
</div>

<style>
    /* ── NEW ADDRESS FIELDS GRID ── */
    .address-fields-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin: 15px 0;
    }

    @@media (max-width: 600px) {
        .address-fields-grid {
            grid-template-columns: 1fr;
        }
    }

    .address-field-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .field-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: rgba(255,255,255,0.5);
    }

    .address-input-field {
        width: 100%;
        background: #1a1a00;
        border: 1.5px solid rgba(255,215,0,0.3);
        border-radius: 10px;
        color: #fff;
        padding: 10px 14px;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
    }

        .address-input-field:focus {
            border-color: #FFD700;
            background: #2a2a00;
            box-shadow: 0 0 12px rgba(255,215,0,0.2);
        }

        .address-input-field::placeholder {
            color: rgba(255,255,255,0.25);
        }

    /* ── MAP SECTION WRAPPER ── */
    .map-section-wrapper {
        margin-top: 20px;
    }

    /* BASE STYLES */
    .book-page {
        background: #000;
        min-height: 100vh;
        padding-bottom: 80px;
    }

    .book-hero {
        position: relative;
        padding: 50px 0 40px;
        overflow: hidden;
    }

    .book-hero-glow {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg,#100000 0%,#1a0900 50%,#050505 100%);
    }

        .book-hero-glow::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%,rgba(179,0,0,0.2) 0%,transparent 55%),radial-gradient(ellipse at 80% 50%,rgba(255,215,0,0.06) 0%,transparent 55%);
        }

    .book-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .book-eyebrow {
        display: block;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(255,215,0,0.4);
        margin-bottom: 8px;
    }

    .book-service-name {
        color: #FFD700;
        font-size: clamp(1.5rem, 5vw, 2.2rem);
        font-weight: 800;
        margin: 0 0 8px;
        text-shadow: 0 0 30px rgba(255,215,0,0.25);
        line-height: 1.1;
    }

    .book-artist-line {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .book-artist-label {
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
    }

    .book-artist-name {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .book-price-block {
        text-align: right;
    }

    .book-price-label {
        display: block;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.25);
        margin-bottom: 4px;
    }

    .book-price {
        display: block;
        font-size: clamp(1.5rem, 6vw, 2.4rem);
        font-weight: 800;
        color: #FFD700;
        text-shadow: 0 0 20px rgba(255,215,0,0.3);
    }

    .book-server-errors {
        background: rgba(255,0,0,0.08);
        border: 1px solid rgba(255,0,0,0.3);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        color: #ff6666;
        font-size: 0.85rem;
    }

        .book-server-errors ul {
            margin: 8px 0 0 16px;
        }

    .book-body {
        padding-top: 40px;
        max-width: 720px;
        margin: 0 auto;
        padding-left: 16px;
        padding-right: 16px;
    }

    .book-section {
        margin-bottom: 36px;
        background: #0b0b0b;
        border: 1px solid rgba(255,215,0,0.1);
        border-radius: 18px;
        padding: 20px;
    }

    @@media (min-width: 768px) {
        .book-section {
            padding: 28px;
        }

        .book-body {
            padding-left: 20px;
            padding-right: 20px;
        }
    }

    .book-step-header {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .book-step-num {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg,#b30000,#FFD700);
        color: #000;
        font-size: 0.95rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .book-step-title {
        color: #FFD700;
        font-size: 1.1rem;
        font-weight: 800;
        margin: 0 0 4px;
    }

    .book-step-sub {
        color: rgba(255,255,255,0.3);
        font-size: 0.78rem;
        margin: 0;
    }

    /* LOCATION CARDS */
    .location-options-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        margin-top: 16px;
    }

    @@media (min-width: 600px) {
        .location-options-container {
            flex-direction: row;
        }
    }

    .location-card {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #121212;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.25s ease;
        flex: 1;
    }

    .card-content {
        display: flex;
        align-items: center;
        gap: 16px;
        flex: 1;
        padding-right: 32px;
    }

    .card-icon {
        font-size: 1.5rem;
        line-height: 1;
        flex-shrink: 0;
    }

    .card-text h3 {
        color: #ffffff;
        font-size: 1rem;
        margin: 0 0 4px;
        font-weight: 600;
    }

    .card-text p {
        color: #8a8a8a;
        font-size: 0.8rem;
        margin: 0;
        line-height: 1.3;
    }

    @@media (min-width: 768px) {
        .card-text h3 {
            font-size: 1.1rem;
        }

        .card-text p {
            font-size: 0.85rem;
        }
    }

    .location-radio {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }

    .radio-indicator {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        width: 18px;
        height: 18px;
        border: 2px solid #555;
        border-radius: 50%;
        background: transparent;
        transition: all 0.2s;
    }

    .location-card.active {
        border-color: #FFD700;
        background: #161204;
        box-shadow: 0 0 15px rgba(255,215,0,0.15);
    }

        .location-card.active .radio-indicator {
            border-color: #FFD700;
            background: #FFD700;
            box-shadow: inset 0 0 0 3px #121212;
        }

    /* MAP STYLES */
    .housecall-container {
        animation: fadeIn 0.3s ease-in-out;
    }

    .map-instruction {
        font-size: 0.9rem;
        color: #FFD700;
        background: rgba(255, 215, 0, 0.1);
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 12px;
        text-align: center;
        font-weight: 600;
    }

    .map-search-wrapper {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        width: 100%;
    }

    .map-search-input {
        flex: 1;
        background: #1a1a1a;
        border: 1.5px solid rgba(255,215,0,0.2);
        border-radius: 10px;
        color: #fff;
        padding: 12px 16px;
        font-size: 0.9rem;
        outline: none;
    }

        .map-search-input:focus {
            border-color: #FFD700;
            background: #1a1500;
        }

    .map-search-btn {
        background: linear-gradient(135deg, #b30000, #FFD700);
        border: none;
        border-radius: 10px;
        color: #000;
        font-weight: 700;
        padding: 0 20px;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 0.85rem;
    }

        .map-search-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 0 12px rgba(255,215,0,0.3);
        }

    .map-frame {
        height: 380px;
        width: 100%;
        background: #151515;
        border-radius: 12px;
        border: 1px solid rgba(255,215,0,0.2);
        margin-bottom: 20px;
        position: relative;
        z-index: 1;
    }

    @@media (max-width: 768px) {
        .map-frame {
            height: 320px;
        }
    }

    @@media (max-width: 480px) {
        .map-frame {
            height: 280px;
        }
    }

    /* ENHANCED ADDRESS SECTION */
    .address-highlight-wrapper {
        margin-top: 0;
        border: 3px solid #FFD700;
        border-radius: 16px;
        background: linear-gradient(135deg, #1a0f00 0%, #0d0800 100%);
        overflow: hidden;
        box-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
        animation: pulseGlow 2s ease-in-out infinite;
    }

    @@keyframes pulseGlow {
        0%, 100% {
            box-shadow: 0 0 5px rgba(255, 215, 0, 0.3);
            border-color: rgba(255, 215, 0, 0.5);
        }

        50% {
            box-shadow: 0 0 25px rgba(255, 215, 0, 0.6);
            border-color: #FFD700;
        }
    }

    .address-warning-badge {
        background: linear-gradient(135deg, #FF0000, #FF4500);
        color: white;
        text-align: center;
        padding: 10px;
        font-weight: 900;
        font-size: 0.85rem;
        letter-spacing: 2px;
        animation: blinkWarning 1s ease-in-out infinite;
    }

    @@keyframes blinkWarning {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.7;
        }
    }

    .address-input-container {
        display: flex;
        gap: 15px;
        padding: 20px;
    }

    @@media (max-width: 768px) {
        .address-input-container {
            flex-direction: column;
            gap: 10px;
            padding: 15px;
        }
    }

    .address-icon {
        font-size: 2.5rem;
        text-align: center;
        flex-shrink: 0;
        background: rgba(255, 215, 0, 0.1);
        border-radius: 12px;
        padding: 10px;
        height: fit-content;
    }

    @@media (max-width: 768px) {
        .address-icon {
            font-size: 2rem;
            padding: 5px;
        }
    }

    .address-field-content {
        flex: 1;
    }

    .address-label {
        display: block;
        color: #FFD700;
        font-size: 1.1rem;
        font-weight: 800;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .required-star {
        color: #FF0000;
        font-size: 1.2rem;
        margin-left: 4px;
    }

    .address-help-text {
        background: rgba(255, 100, 0, 0.2);
        border-left: 4px solid #FF6600;
        padding: 10px;
        margin-bottom: 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        color: #FFA500;
    }

    .address-format-example {
        background: #0a0a0a;
        border: 1px solid rgba(255, 215, 0, 0.3);
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 15px;
    }

    .example-title {
        color: #FFD700;
        font-weight: 700;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .example-list {
        margin: 0;
        padding-left: 20px;
    }

        .example-list li {
            color: #cccccc;
            font-size: 0.8rem;
            margin-bottom: 5px;
            line-height: 1.4;
        }

        .example-list .example {
            color: #FFD700;
            font-size: 0.75rem;
            opacity: 0.8;
        }

    .address-textarea {
        width: 100%;
        background: #1a1a00;
        border: 2px solid #FFD700;
        border-radius: 12px;
        color: #fff;
        padding: 14px 16px;
        font-size: 0.95rem;
        resize: vertical;
        outline: none;
        font-family: monospace;
        font-weight: 500;
    }

        .address-textarea:focus {
            background: #2a2a00;
            border-color: #FFAA00;
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.4);
        }

    .address-warning-message {
        background: rgba(255, 50, 50, 0.15);
        border: 1px solid #FF4444;
        border-radius: 8px;
        padding: 10px;
        margin-top: 12px;
        font-size: 0.8rem;
        color: #FF8888;
        text-align: center;
        font-weight: 500;
    }

    /* CALENDAR STYLES */
    .slots-loading {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.4);
        font-size: 0.85rem;
        padding: 20px 0;
    }

    .slots-spinner {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid rgba(255,215,0,0.2);
        border-top-color: #FFD700;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(4px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .cal-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .cal-nav-btn {
        background: rgba(255,215,0,0.08);
        border: 1px solid rgba(255,215,0,0.15);
        color: #FFD700;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        cursor: pointer;
    }

    .cal-month-label {
        color: #FFD700;
        font-size: 0.95rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 6px;
        margin-bottom: 6px;
    }

    .cal-day-header {
        text-align: center;
        font-size: 0.62rem;
        font-weight: 700;
        color: rgba(255,255,255,0.2);
        padding: 6px 0;
    }

    .cal-day {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
    }

        .cal-day.empty {
            pointer-events: none;
        }

        .cal-day.past {
            color: rgba(255,255,255,0.12);
            pointer-events: none;
        }

        .cal-day.has-slot {
            background: linear-gradient(135deg,#b30000,#FFD700);
            color: #000;
            font-weight: 800;
            box-shadow: 0 0 10px rgba(255,215,0,0.2);
        }

        .cal-day.selected {
            background: #FFD700 !important;
            color: #000 !important;
            transform: scale(1.1);
            box-shadow: 0 0 28px rgba(255,215,0,0.6);
        }

    .time-slots-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 10px;
    }

    .time-slot-btn {
        background: #111;
        border: 1.5px solid rgba(255,215,0,0.15);
        border-radius: 10px;
        color: #fff;
        padding: 10px 20px;
        cursor: pointer;
    }

        .time-slot-btn.selected {
            background: rgba(255,215,0,0.1);
            border-color: #FFD700;
            color: #FFD700;
        }

    .book-textarea {
        width: 100%;
        background: #111;
        border: 1.5px solid rgba(255,215,0,0.1);
        border-radius: 12px;
        color: #fff;
        padding: 14px 16px;
        resize: vertical;
    }

    .book-summary {
        border-color: rgba(255,215,0,0.2);
    }

    .book-summary-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .travel-cost-disclaimer {
        font-size: 0.75rem;
        color: rgba(255,215,0,0.6);
        background: rgba(255,215,0,0.04);
        padding: 10px;
        border-radius: 8px;
        margin-top: 10px;
    }

    .book-confirm-btn {
        width: 100%;
        padding: 18px;
        background: linear-gradient(135deg,#b30000,#FFD700);
        color: #000;
        font-weight: 800;
        border: none;
        border-radius: 999px;
        cursor: pointer;
    }

    .book-field-error {
        color: #ff4444;
        font-size: 0.8rem;
        margin-top: 10px;
        padding: 8px 12px;
        background: rgba(255,0,0,0.08);
        border-radius: 8px;
        border-left: 3px solid #ff4444;
    }
</style>
@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ─── YOUR LOCATIONIQ API KEY ───
            const LOCATIONIQ_API_KEY = 'pk.262798f25cd021707b77f66c88babd01';

            let slotsData = [];
            let currentYear = new Date().getFullYear();
            let currentMonth = new Date().getMonth();
            const artistId = '@Model.ArtistId';

            // DOM Elements
            const cardWalkIn = document.getElementById("cardWalkIn");
            const cardHouseCall = document.getElementById("cardHouseCall");
            const radWalkIn = document.getElementById("locWalkIn");
            const radHouseCall = document.getElementById("locHouseCall");
            const houseCallWrapper = document.getElementById("houseCallWrapper");
            const textAddress = document.getElementById("textAddress");
            const summaryLocationType = document.getElementById("summaryLocationType");
            const travelDisclaimer = document.getElementById("travelDisclaimer");
            const selectedSlotIdInput = document.getElementById("AvailabilitySlotId");
            const selectedDateInput = document.getElementById("PreferredDate");
            const latOutput = document.getElementById("Latitude");
            const lngOutput = document.getElementById("Longitude");
            const bookingForm = document.getElementById("bookingForm");
            const slotError = document.getElementById("slotError");
            const mapValidationError = document.getElementById("mapValidationError");
            const monthLabel = document.getElementById("monthLabel");
            const calDays = document.getElementById("calDays");
            const timeSlotSection = document.getElementById("timeSlotSection");
            const selectedDateLabel = document.getElementById("selectedDateLabel");
            const timeSlotsGrid = document.getElementById("timeSlotsGrid");
            const bookSummary = document.getElementById("bookSummary");
            const summarySlot = document.getElementById("summarySlot");

            let map, marker;

            // ─── MAP FUNCTIONS ───
            function initMap() {
                if (map) { map.invalidateSize(); return; }
                map = L.map('leafletMap').setView([-26.2041, 28.0473], 13);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
                marker = L.marker([-26.2041, 28.0473], { draggable: true }).addTo(map);
                marker.on('dragend', function(e) {
                    updateCoordinates(marker.getLatLng().lat, marker.getLatLng().lng);
                    reverseGeocode(marker.getLatLng().lat, marker.getLatLng().lng);
                });
                map.on('click', function(e) {
                    marker.setLatLng(e.latlng);
                    updateCoordinates(e.latlng.lat, e.latlng.lng);
                    reverseGeocode(e.latlng.lat, e.latlng.lng);
                });
            }

            // ─── UPDATE COORDINATES ───
            function updateCoordinates(lat, lng) {
                latOutput.value = lat;
                lngOutput.value = lng;
            }

            // ─── REVERSE GEOCODE (unchanged – uses OSM) ───
            async function reverseGeocode(lat, lng) {
                try {
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`);
                    const data = await response.json();

                    if (data && data.address) {
                        const addr = data.address;

                        // Parse South African address components
                        const houseNumber = addr.house_number || addr.building || '';
                        const road = addr.road || addr.street || '';
                        const suburb = addr.suburb || addr.neighbourhood || addr.city_district || '';
                        const city = addr.city || addr.town || addr.village || '';
                        const postcode = addr.postcode || '';

                        // Fill the 3 fields
                        document.getElementById('houseNumberInput').value = houseNumber;
                        document.getElementById('streetAddressInput').value = `${road}${road && suburb ? ', ' : ''}${suburb}${suburb && city ? ', ' : ''}${city}`;
                        document.getElementById('areaCodeInput').value = postcode;

                        // Also build the full address for the hidden field
                        const fullAddress = `${houseNumber} ${road}, ${suburb}, ${city} ${postcode}`.trim();
                        document.getElementById('textAddress').value = fullAddress;
                    }
                } catch (error) {
                    console.log('Reverse geocode error:', error);
                }
            }

            // ─── SEARCH ADDRESS (NOW USING LOCATIONIQ) ───
            function searchAddress() {
                const houseNum = document.getElementById('houseNumberInput')?.value?.trim() || '';
                const streetAddr = document.getElementById('streetAddressInput')?.value?.trim() || '';
                const areaCode = document.getElementById('areaCodeInput')?.value?.trim() || '';
                const searchQuery = document.getElementById('mapSearchInput')?.value?.trim() || '';

                // Build query: use fields if available, otherwise fallback to search box
                let query = '';
                if (houseNum && streetAddr) {
                    query = `${houseNum} ${streetAddr}`;
                    if (areaCode) query += `, ${areaCode}`;
                } else if (searchQuery) {
                    query = searchQuery;
                } else {
                    alert('Please enter a house number and street address, or search for a location.');
                    return;
                }

                if (!map) { alert('Map is loading...'); return; }

                const searchBtn = document.getElementById('searchAddressBtn');
                const originalText = searchBtn.textContent;
                searchBtn.textContent = 'Searching...';
                searchBtn.disabled = true;

                // ─── LOCATIONIQ SEARCH ───
                const url = `https://us1.locationiq.com/v1/search.php?key=${LOCATIONIQ_API_KEY}&q=${encodeURIComponent(query)}&format=json&limit=1`;

                fetch(url)
                    .then(res => res.json())
                    .then(data => {
                        searchBtn.textContent = originalText;
                        searchBtn.disabled = false;
                        if (data && data.length > 0) {
                            const lat = parseFloat(data[0].lat);
                            const lon = parseFloat(data[0].lon);
                            map.setView([lat, lon], 18); // Zoom in close
                            marker.setLatLng([lat, lon]);
                            updateCoordinates(lat, lon);
                            reverseGeocode(lat, lon);
                            if (data[0].display_name) {
                                document.getElementById('mapSearchInput').value = data[0].display_name;
                            }
                        } else {
                            alert('Address not found. Please check the house number and street.');
                        }
                    })
                    .catch(() => {
                        searchBtn.textContent = originalText;
                        searchBtn.disabled = false;
                        alert('Error searching for address.');
                    });
            }

            // ─── FIND EXACT LOCATION (NOW USING LOCATIONIQ) ───
            function findExactAddress() {
                const houseNum = document.getElementById('houseNumberInput')?.value?.trim();
                const streetAddr = document.getElementById('streetAddressInput')?.value?.trim();
                const areaCode = document.getElementById('areaCodeInput')?.value?.trim();

                if (!houseNum || !streetAddr) {
                    alert('Please enter your house number and street address first.');
                    return;
                }

                let query = `${houseNum} ${streetAddr}`;
                if (areaCode) query += `, ${areaCode}`;

                if (!map) { alert('Map is loading...'); return; }

                const btn = document.getElementById('findExactBtn');
                if (btn) {
                    btn.textContent = 'Locating...';
                    btn.disabled = true;
                }

                // ─── LOCATIONIQ SEARCH ───
                const url = `https://us1.locationiq.com/v1/search.php?key=${LOCATIONIQ_API_KEY}&q=${encodeURIComponent(query)}&format=json&limit=1`;

                fetch(url)
                    .then(res => res.json())
                    .then(data => {
                        if (btn) { btn.textContent = '📍 Find My Exact Location'; btn.disabled = false; }

                        if (data && data.length > 0) {
                            const lat = parseFloat(data[0].lat);
                            const lon = parseFloat(data[0].lon);
                            map.setView([lat, lon], 19); // Zoom very close
                            marker.setLatLng([lat, lon]);
                            updateCoordinates(lat, lon);
                            reverseGeocode(lat, lon);
                            if (data[0].display_name) {
                                document.getElementById('mapSearchInput').value = data[0].display_name;
                            }
                            // Flash success feedback
                            const wrapper = document.querySelector('.address-highlight-wrapper');
                            if (wrapper) {
                                wrapper.style.borderColor = '#00ff88';
                                wrapper.style.boxShadow = '0 0 30px rgba(0,255,136,0.3)';
                                setTimeout(() => {
                                    wrapper.style.borderColor = '#FFD700';
                                    wrapper.style.boxShadow = '0 0 20px rgba(255,215,0,0.3)';
                                }, 2000);
                            }
                        } else {
                            alert('Could not pinpoint the exact address. Please check the house number and street.');
                        }
                    })
                    .catch(() => {
                        if (btn) { btn.textContent = '📍 Find My Exact Location'; btn.disabled = false; }
                        alert('Error locating address.');
                    });
            }

            // ─── SETUP SEARCH LISTENERS (unchanged) ───
            function setupSearchListeners() {
                const searchBtn = document.getElementById('searchAddressBtn');
                const searchInput = document.getElementById('mapSearchInput');
                if (searchBtn) searchBtn.onclick = (e) => { e.preventDefault(); searchAddress(); };
                if (searchInput) searchInput.onkeypress = (e) => { if (e.key === 'Enter') { e.preventDefault(); searchAddress(); } };

                // Add "Find Exact Location" button if it doesn't exist
                const houseCallWrapper = document.getElementById('houseCallWrapper');
                if (houseCallWrapper && !document.getElementById('findExactBtn')) {
                    const btnContainer = document.querySelector('.map-search-wrapper');
                    if (btnContainer) {
                        const findBtn = document.createElement('button');
                        findBtn.type = 'button';
                        findBtn.id = 'findExactBtn';
                        findBtn.className = 'map-search-btn';
                        findBtn.style.background = 'linear-gradient(135deg, #00c853, #00e676)';
                        findBtn.style.color = '#000';
                        findBtn.innerHTML = '📍 Find My Exact Location';
                        findBtn.onclick = (e) => { e.preventDefault(); findExactAddress(); };
                        btnContainer.appendChild(findBtn);
                    }
                }
            }

            // ─── LOCATION SELECTION ───
            function selectLocationCard(type) {
                if (type === "WalkIn") {
                    radWalkIn.checked = true;
                    cardWalkIn.classList.add("active");
                    cardHouseCall.classList.remove("active");
                    houseCallWrapper.style.display = "none";
                    summaryLocationType.innerText = "Walk-In";
                    travelDisclaimer.style.display = "none";
                } else {
                    radHouseCall.checked = true;
                    cardHouseCall.classList.add("active");
                    cardWalkIn.classList.remove("active");
                    houseCallWrapper.style.display = "block";
                    summaryLocationType.innerText = "House Call";
                    travelDisclaimer.style.display = "block";
                    setTimeout(() => { initMap(); if(map) map.invalidateSize(); setupSearchListeners(); }, 150);
                }
            }

            cardWalkIn.onclick = () => selectLocationCard("WalkIn");
            cardHouseCall.onclick = () => selectLocationCard("HouseCall");
            if (radWalkIn && radWalkIn.checked) selectLocationCard("WalkIn");

            // ─── CALENDAR FUNCTIONS (unchanged) ───
            function showTimeSlots(dateString, slots) {
                timeSlotsGrid.innerHTML = "";
                selectedDateLabel.innerText = new Date(dateString).toLocaleDateString('default', { weekday: 'short', month: 'short', day: 'numeric' });
                timeSlotSection.style.display = "block";

                slots.forEach(slot => {
                    const btn = document.createElement("button");
                    btn.type = "button";
                    btn.className = "time-slot-btn";
                    btn.innerHTML = `<span>${slot.timeString}</span>`;

                    if (selectedSlotIdInput.value == slot.id) {
                        btn.classList.add("selected");
                    }

                    btn.addEventListener("click", () => {
                        document.querySelectorAll(".time-slot-btn").forEach(b => b.classList.remove("selected"));
                        btn.classList.add("selected");

                        selectedSlotIdInput.value = slot.id;
                        selectedDateInput.value = dateString;

                        summarySlot.innerText = `${new Date(dateString).toLocaleDateString('default', { month: 'short', day: 'numeric' })} at ${slot.timeString}`;
                        bookSummary.style.display = "block";
                    });
                    timeSlotsGrid.appendChild(btn);
                });
            }

            function renderCalendar() {
                console.log("Rendering calendar with slotsData:", slotsData);
                console.log("Current month/year:", currentMonth, currentYear);

                if (!calDays) return;

                calDays.innerHTML = "";
                const dateObj = new Date(currentYear, currentMonth, 1);
                const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
                monthLabel.innerText = `${monthNames[currentMonth]} ${currentYear}`;

                const firstDayIndex = new Date(currentYear, currentMonth, 1).getDay();
                const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();
                const todayStr = new Date().toISOString().split('T')[0];

                for (let i = 0; i < firstDayIndex; i++) {
                    let div = document.createElement("div");
                    div.classList.add("cal-day", "empty");
                    calDays.appendChild(div);
                }

                for (let day = 1; day <= totalDays; day++) {
                    let dayDiv = document.createElement("div");
                    dayDiv.classList.add("cal-day");
                    dayDiv.innerText = day;

                    const dateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;

                    if (dateStr < todayStr) {
                        dayDiv.classList.add("past");
                    } else {
                        if (dateStr === todayStr) {
                            dayDiv.classList.add("today");
                            dayDiv.style.border = "1px solid #FFD700";
                        }

                        const daySlots = slotsData.filter(s => {
                            const slotDate = s.date ? s.date.split('T')[0] : s;
                            return slotDate === dateStr;
                        });

                        if (daySlots.length > 0) {
                            dayDiv.classList.add("has-slot");
                            dayDiv.addEventListener("click", (function(date, slots) {
                                return function() {
                                    document.querySelectorAll(".cal-day").forEach(d => d.classList.remove("selected"));
                                    this.classList.add("selected");
                                    showTimeSlots(date, slots);
                                };
                            })(dateStr, daySlots));

                            if (selectedDateInput.value === dateStr) {
                                dayDiv.classList.add("selected");
                                showTimeSlots(dateStr, daySlots);
                            }
                        }
                    }
                    calDays.appendChild(dayDiv);
                }
            }

            function prevMonth() {
                currentMonth--;
                if (currentMonth < 0) {
                    currentMonth = 11;
                    currentYear--;
                }
                renderCalendar();
            }

            function nextMonth() {
                currentMonth++;
                if (currentMonth > 11) {
                    currentMonth = 0;
                    currentYear++;
                }
                renderCalendar();
            }

            // ─── FETCH AVAILABILITY ───
            const calLoading = document.getElementById("calLoading");
            const calEmpty = document.getElementById("calEmpty");
            const calendarWrap = document.getElementById("calendarWrap");

            console.log("Fetching slots for artistId:", artistId);

            if (!artistId || artistId === '' || artistId === 'null') {
                console.error("No artistId provided!");
                calLoading.style.display = "none";
                calEmpty.style.display = "block";
                calEmpty.innerHTML = '<div class="slots-empty-icon">⚠️</div><p>Artist ID not found. Please try again.</p>';
            } else {
                fetch(`/Booking/GetArtistAvailability?artistId=${artistId}`)
                    .then(res => {
                        if (!res.ok) throw new Error(`HTTP ${res.status}`);
                        return res.json();
                    })
                    .then(data => {
                        console.log("Raw slots data received:", data);
                        console.log("Number of slots:", data.length);

                        slotsData = data;
                        calLoading.style.display = "none";

                        if (!slotsData || slotsData.length === 0) {
                            console.log("No slots found - showing empty state");
                            calEmpty.style.display = "block";
                            calEmpty.innerHTML = '<div class="slots-empty-icon">📅</div><p>This artist has no available slots right now.</p><small>Check back soon or contact them directly.</small>';
                        } else {
                            console.log("Slots found - rendering calendar");
                            calendarWrap.style.display = "block";
                            renderCalendar();
                        }
                    })
                    .catch(error => {
                        console.error("Error fetching slots:", error);
                        calLoading.style.display = "none";
                        calEmpty.style.display = "block";
                        calEmpty.innerHTML = '<div class="slots-empty-icon">⚠️</div><p>Error loading availability. Please try again later.</p>';
                    });
            }

            const prevBtn = document.getElementById("prevMonth");
            const nextBtn = document.getElementById("nextMonth");
            if (prevBtn) prevBtn.onclick = prevMonth;
            if (nextBtn) nextBtn.onclick = nextMonth;

            // ─── FORM VALIDATION ───
            bookingForm.onsubmit = function(e) {
                let valid = true;
                slotError.style.display = "none";
                mapValidationError.style.display = "none";

                if (!selectedSlotIdInput.value) {
                    slotError.style.display = "block";
                    slotError.scrollIntoView({ behavior: 'smooth' });
                    valid = false;
                }

                if (radHouseCall && radHouseCall.checked) {
                    const houseNum = document.getElementById('houseNumberInput').value.trim();
                    const streetAddr = document.getElementById('streetAddressInput').value.trim();
                    const areaCode = document.getElementById('areaCodeInput').value.trim();

                    if (!houseNum || !streetAddr || !areaCode) {
                        mapValidationError.style.display = "block";
                        mapValidationError.scrollIntoView({ behavior: 'smooth' });
                        valid = false;
                    }

                    if (!latOutput.value || !lngOutput.value) {
                        mapValidationError.style.display = "block";
                        mapValidationError.scrollIntoView({ behavior: 'smooth' });
                        valid = false;
                    }
                }

                if (radHouseCall && radHouseCall.checked) {
                    const houseNum = document.getElementById('houseNumberInput').value.trim();
                    const streetAddr = document.getElementById('streetAddressInput').value.trim();
                    const areaCode = document.getElementById('areaCodeInput').value.trim();
                    const fullAddress = `${houseNum} ${streetAddr}, ${areaCode}`.trim();
                    document.getElementById('textAddress').value = fullAddress;
                }

                if (!valid) e.preventDefault();
            };
        });
    </script>
}