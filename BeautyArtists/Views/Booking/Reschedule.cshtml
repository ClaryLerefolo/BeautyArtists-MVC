@* ================================================================
   Reschedule.cshtml
   Save to: /Views/Booking/Reschedule.cshtml
   ================================================================ *@

@model BeautyArtists.Models.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Reschedule Appointment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="book-page">

    @* ── HEADER ── *@
    <div class="book-hero">
        <div class="book-hero-glow"></div>
        <div class="container book-hero-inner">
            <div class="book-service-info">
                <span class="book-eyebrow">Rescheduling</span>
                <h1 class="book-service-name">@Model.ServiceName</h1>
                <div class="book-artist-line">
                    <span class="book-artist-label">with</span>
                    <span class="book-artist-name">@Model.ArtistName</span>
                </div>
                <div class="reschedule-warning">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    You can only reschedule once. Choose carefully!
                </div>
            </div>
            <div class="book-price-block">
                <span class="book-price-label">Current Appointment</span>
                <span class="book-current-date">@Model.PreferredDate.ToString("dd MMM")</span>
                <span class="book-current-time">@Model.PreferredDate.ToString("HH:mm")</span>
            </div>
        </div>
    </div>

    <div class="container book-body">

        @if (TempData["Error"] != null)
        {
            <div class="mb-alert-error mb-3">
                ⚠ @TempData["Error"]
            </div>
        }

        <form asp-controller="Booking" asp-action="Reschedule" method="post" id="rescheduleForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="BookingId" value="@Model.BookingId" />
            <input type="hidden" name="UserServiceId" value="@Model.UserServiceId" />
            <input type="hidden" name="Price" value="@Model.Price" />
            <input type="hidden" name="ServiceName" value="@Model.ServiceName" />
            <input type="hidden" name="ArtistName" value="@Model.ArtistName" />
            <input type="hidden" name="ArtistId" value="@Model.ArtistId" />
            <input type="hidden" name="AvailabilitySlotId" id="selectedSlotId" value="0" />
            <input type="hidden" name="PreferredDate" id="selectedDate" value="" />

            @* ── PICK NEW SLOT ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">1</div>
                    <div>
                        <h2 class="book-step-title">Pick a New Time Slot</h2>
                        <p class="book-step-sub">Select a different available window from the artist</p>
                    </div>
                </div>

                <div id="slotsLoading" class="slots-loading">
                    <div class="slots-spinner"></div>
                    <span>Fetching availability...</span>
                </div>

                <div id="slotsEmpty" class="slots-empty" style="display:none">
                    <div class="slots-empty-icon">📅</div>
                    <p>No other slots available right now.</p>
                    <small>The artist hasn't added new availability yet.</small>
                </div>

                <div id="slotsGrid" class="slots-grid" style="display:none"></div>

                <div id="slotError" class="book-field-error" style="display:none">
                    ⚠ Please select a new time slot to continue.
                </div>
            </div>

            @* ── SUMMARY ── *@
            <div class="book-section book-summary" id="bookSummary" style="display:none">
                <div class="book-summary-row">
                    <span>Service</span>
                    <strong>@Model.ServiceName</strong>
                </div>
                <div class="book-summary-row">
                    <span>Artist</span>
                    <strong>@Model.ArtistName</strong>
                </div>
                <div class="book-summary-row">
                    <span>Previous Slot</span>
                    <strong style="color:rgba(255,255,255,0.4); text-decoration:line-through">
                        @Model.PreferredDate.ToString("MMM dd — HH:mm")
                    </strong>
                </div>
                <div class="book-summary-row">
                    <span>New Slot</span>
                    <strong id="summarySlot" style="color:#00c853">—</strong>
                </div>
            </div>

            @* ── REASON FOR RESCHEDULING ── *@
            <div class="book-section">
                <div class="book-step-header">
                    <div class="book-step-num">2</div>
                    <div>
                        <h2 class="book-step-title">Reason for Rescheduling</h2>
                        <p class="book-step-sub">Let the artist know why you're changing the time</p>
                    </div>
                </div>

                <div class="mb-3">
                    <textarea name="Notes" id="rescheduleReason" class="form-control"
                              style="background: #111; border: 1px solid rgba(255,215,0,0.1); color: white; border-radius: 12px; padding: 15px;"
                              rows="3" placeholder="e.g., Work conflict, personal emergency..." required></textarea>
                    <div id="reasonError" class="book-field-error" style="display:none">
                        ⚠ Please provide a reason for rescheduling.
                    </div>
                </div>
            </div>

            @* ── ACTIONS ── *@
            <div class="reschedule-actions">
                <button type="submit" class="book-confirm-btn" id="confirmBtn">
                    <span>Confirm Reschedule</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5">
                        <polyline points="20,6 9,17 4,12" />
                    </svg>
                </button>
                <a href="javascript:history.back()" class="reschedule-cancel-link">
                    Cancel — Keep Original
                </a>
            </div>

        </form>
    </div>
</div>

<style>
    .book-page {
        background: #000;
        min-height: 100vh;
        padding-bottom: 80px;
    }

    /* ── HERO ── */
    .book-hero {
        position: relative;
        padding: 50px 0 40px;
        overflow: hidden;
    }

    .book-hero-glow {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #000d10 0%, #001a0d 50%, #050505 100%);
    }

        .book-hero-glow::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(0,150,80,0.15) 0%, transparent 55%), radial-gradient(ellipse at 80% 50%, rgba(255,215,0,0.05) 0%, transparent 55%);
        }

    .book-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .book-eyebrow {
        display: block;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(0,200,83,0.5);
        margin-bottom: 8px;
    }

    .book-service-name {
        color: #FFD700;
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 8px;
        text-shadow: 0 0 30px rgba(255,215,0,0.2);
        line-height: 1.1;
    }

    .book-artist-line {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
    }

    .book-artist-label {
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
    }

    .book-artist-name {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .reschedule-warning {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(255,200,0,0.08);
        border: 1px solid rgba(255,200,0,0.2);
        color: rgba(255,200,0,0.7);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 7px 14px;
        border-radius: 20px;
    }

    .book-price-block {
        text-align: right;
    }

    .book-price-label {
        display: block;
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
        margin-bottom: 6px;
    }

    .book-current-date {
        display: block;
        font-size: 2rem;
        font-weight: 800;
        color: rgba(255,255,255,0.5);
        line-height: 1;
        text-decoration: line-through;
    }

    .book-current-time {
        display: block;
        font-size: 1rem;
        color: rgba(255,255,255,0.25);
        text-decoration: line-through;
    }

    /* ── BODY ── */
    .book-body {
        padding-top: 40px;
        max-width: 720px;
    }

    /* ── ERROR ── */
    .mb-alert-error {
        background: rgba(255,50,50,0.08);
        border: 1px solid rgba(255,50,50,0.25);
        border-radius: 10px;
        padding: 12px 18px;
        color: #ff5555;
        font-size: 0.88rem;
        font-weight: 600;
    }

    /* ── SECTION ── */
    .book-section {
        margin-bottom: 24px;
        background: #0b0b0b;
        border: 1px solid rgba(255,215,0,0.1);
        border-radius: 18px;
        padding: 28px;
    }

    .book-step-header {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 24px;
    }

    .book-step-num {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #006633, #00c853);
        color: #000;
        font-size: 0.95rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .book-step-title {
        color: #FFD700;
        font-size: 1.1rem;
        font-weight: 800;
        margin: 0 0 4px;
    }

    .book-step-sub {
        color: rgba(255,255,255,0.3);
        font-size: 0.78rem;
        margin: 0;
    }

    /* ── SLOTS ── */
    .slots-loading {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.4);
        font-size: 0.85rem;
        padding: 20px 0;
    }

    .slots-spinner {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid rgba(0,200,83,0.2);
        border-top-color: #00c853;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .slots-empty {
        text-align: center;
        padding: 32px 0;
        color: rgba(255,255,255,0.3);
    }

    .slots-empty-icon {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .slots-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
    }

    .slot-card {
        background: #111;
        border: 1.5px solid rgba(255,215,0,0.1);
        border-radius: 12px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.2s ease;
        user-select: none;
    }

        .slot-card:hover {
            border-color: rgba(0,200,83,0.4);
            background: #001a0d;
            transform: translateY(-2px);
        }

        .slot-card.selected {
            border-color: #00c853;
            background: rgba(0,200,83,0.07);
            box-shadow: 0 0 20px rgba(0,200,83,0.15);
        }

            .slot-card.selected .slot-date {
                color: #00c853;
            }

    .slot-date {
        font-size: 0.95rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 6px;
    }

    .slot-time {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.4);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .slot-check {
        display: none;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #00c853;
        align-items: center;
        justify-content: center;
        margin-left: auto;
        margin-top: -24px;
        float: right;
        font-size: 0.65rem;
        color: #000;
        font-weight: 900;
    }

    .slot-card.selected .slot-check {
        display: flex;
    }

    /* ── SUMMARY ── */
    .book-summary {
        border-color: rgba(0,200,83,0.15);
    }

    .book-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 0.88rem;
    }

        .book-summary-row:last-child {
            border-bottom: none;
        }

        .book-summary-row span {
            color: rgba(255,255,255,0.4);
        }

        .book-summary-row strong {
            color: #fff;
        }

    /* ── ACTIONS ── */
    .reschedule-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
    }

    .book-confirm-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 18px;
        background: linear-gradient(135deg, #006633, #00c853);
        color: #000;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .book-confirm-btn:hover {
            background: linear-gradient(135deg, #00c853, #006633);
            box-shadow: 0 0 30px rgba(0,200,83,0.3);
            transform: translateY(-2px);
        }

    .reschedule-cancel-link {
        color: rgba(255,255,255,0.25);
        font-size: 0.8rem;
        text-decoration: none;
        transition: color 0.2s;
    }

        .reschedule-cancel-link:hover {
            color: rgba(255,255,255,0.5);
        }

    .book-field-error {
        color: #ff4444;
        font-size: 0.8rem;
        margin-top: 10px;
        padding: 8px 12px;
        background: rgba(255,0,0,0.08);
        border-radius: 8px;
        border-left: 3px solid #ff4444;
    }
</style>

@section Scripts {
    <script>
        const artistId = '@Model.ArtistId';
        let selectedSlot = null;

        // 🔥 FIXED: Use the correct endpoint from your BookingController
        fetch(`/Booking/GetArtistAvailability?artistId=${artistId}`)
            .then(res => {
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                return res.json();
            })
            .then(slots => {
                document.getElementById('slotsLoading').style.display = 'none';

                if (!slots || slots.length === 0) {
                    document.getElementById('slotsEmpty').style.display = 'block';
                    return;
                }

                const grid = document.getElementById('slotsGrid');
                grid.style.display = 'grid';

                slots.forEach(slot => {
                    // 🔥 FIXED: Use the exact format from your API
                    const dateDisplay = new Date(slot.date + 'T00:00:00').toLocaleDateString('en-US', {
                        weekday: 'short',
                        month: 'short',
                        day: 'numeric'
                    });

                    const card = document.createElement('div');
                    card.className = 'slot-card';
                    card.dataset.slotId = slot.id;
                    card.dataset.date = slot.date;

                    card.innerHTML = `
                        <div class="slot-check">✓</div>
                        <div class="slot-date">📅 ${dateDisplay}</div>
                        <div class="slot-time">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12,6 12,12 16,14"/>
                            </svg>
                            ${slot.timeString}
                        </div>
                    `;

                    card.addEventListener('click', () => {
                        document.querySelectorAll('.slot-card').forEach(c => c.classList.remove('selected'));
                        card.classList.add('selected');
                        selectedSlot = slot;

                        document.getElementById('selectedSlotId').value = slot.id;
                        document.getElementById('selectedDate').value = slot.date;
                        document.getElementById('summarySlot').textContent = `${dateDisplay} — ${slot.timeString}`;
                        document.getElementById('bookSummary').style.display = 'block';
                        document.getElementById('slotError').style.display = 'none';
                    });

                    grid.appendChild(card);
                });
            })
            .catch(() => {
                document.getElementById('slotsLoading').style.display = 'none';
                document.getElementById('slotsEmpty').style.display = 'block';
            });

        document.getElementById('rescheduleForm').addEventListener('submit', function(e) {
            let valid = true;

            if (!selectedSlot) {
                e.preventDefault();
                document.getElementById('slotError').style.display = 'block';
                document.getElementById('slotError').scrollIntoView({ behavior: 'smooth', block: 'center' });
                valid = false;
            }

            const reason = document.getElementById('rescheduleReason').value.trim();
            if (!reason) {
                e.preventDefault();
                document.getElementById('reasonError').style.display = 'block';
                document.getElementById('reasonError').scrollIntoView({ behavior: 'smooth', block: 'center' });
                valid = false;
            }

            if (!valid) e.preventDefault();
        });

        // Hide reason error when user starts typing
        document.getElementById('rescheduleReason').addEventListener('input', function() {
            if (this.value.trim()) {
                document.getElementById('reasonError').style.display = 'none';
            }
        });
    </script>
}