@model BeautyArtists.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = Model.IsLastMinute ? "Pay Full Amount" : "Complete Your Deposit";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var buttonText = Model.IsLastMinute ? "💳 Pay Full Amount" : "💳 Pay 50% Deposit";
    var headerColor = Model.IsLastMinute ? "#f0c808" : "#FFD700";
    var buttonGradient = Model.IsLastMinute ? "linear-gradient(135deg, #f0c808, #e50914)" : "linear-gradient(135deg, #f0c808, #e50914)";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card" style="background: #0b0b0b; border: 1px solid rgba(240, 200, 8, 0.3);">
                <div class="card-header text-center" style="border-bottom-color: rgba(240,200,8,0.1);">
                    <h3 style="color: @headerColor;">@ViewData["Title"]</h3>
                    <p style="color: #fff;">Booking #@Model.Booking.Id</p>
                    @if (Model.IsLastMinute)
                    {
                        <p style="color: #ffc107; font-size: 0.9rem;">
                            <i class="fas fa-clock me-1"></i> Appointment is within 2 days – full payment required.
                        </p>
                    }
                </div>
                <div class="card-body">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                        </div>
                    }
                    <div class="booking-summary mb-4">
                        <h4 style="color: @headerColor;">Booking Summary</h4>
                        <hr style="border-color: rgba(240,200,8,0.2);">
                        <p><strong>Service:</strong> @Model.Booking.UserService?.Service?.Name</p>
                        <p><strong>Artist:</strong> @Model.Booking.UserService?.Artist?.FirstName @Model.Booking.UserService?.Artist?.LastName</p>
                        <p><strong>Date:</strong> @Model.Booking.AppointmentDate.ToString("MMMM dd, yyyy")</p>
                        <p><strong>Time:</strong> @Model.Booking.AppointmentDate.ToString("hh:mm tt")</p>
                        <hr style="border-color: rgba(240,200,8,0.2);">

                        <!-- 🔥 PAYMENT BREAKDOWN -->
                        <div style="background: #1a1a1a; padding: 12px 15px; border-radius: 8px; margin: 10px 0;">
                            <p style="margin: 4px 0;"><strong>Service Price:</strong> R @Model.Booking.ServicePrice.ToString("N2")</p>
                            <p style="margin: 4px 0;"><strong>Booking Fee:</strong> R @Model.Booking.BookingFee.ToString("N2")</p>
                            <hr style="border-color: rgba(240,200,8,0.2); margin: 8px 0;">
                            <p style="margin: 4px 0;"><strong>Total Amount:</strong> <span style="color: #FFD700;">R @Model.Booking.TotalAmount.ToString("N2")</span></p>
                            <hr style="border-color: rgba(240,200,8,0.2); margin: 8px 0;">
                            <p style="margin: 4px 0; color: #ffc107;"><strong>Deposit Breakdown:</strong></p>
                            <p style="margin: 2px 0 2px 20px; font-size: 0.9rem;">50% of Service Price: R @((Model.Booking.ServicePrice / 2).ToString("N2"))</p>
                            <p style="margin: 2px 0 2px 20px; font-size: 0.9rem; color: #f0c808;">+ Full Booking Fee: R @Model.Booking.BookingFee.ToString("N2")</p>
                            <p style="margin: 6px 0 0 0;"><strong style="color: #ff6600; font-size: 1.1rem;">Total Deposit: R @Model.DepositAmount.ToString("N2")</strong></p>
                            @if (!Model.IsLastMinute)
                            {
                                <p style="margin: 4px 0 0 0; font-size: 0.7rem; color: rgba(255,255,255,0.3);">
                                    Final Payment (remaining 50% of service): R @((Model.Booking.ServicePrice / 2).ToString("N2"))
                                </p>
                            }
                        </div>

                        <hr style="border-color: rgba(240,200,8,0.2);">
                        <p><strong>Amount Due:</strong> <span style="color: #ff6600; font-size: 1.5rem;">R @Model.DepositAmount.ToString("N2")</span></p>
                        @if (Model.IsLastMinute)
                        {
                            <p class="text-warning small mt-2"><i class="fas fa-info-circle me-1"></i> This is the full amount – no further payment required.</p>
                        }
                        else
                        {
                            <p class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i> Remaining 50% to be paid 2 days before appointment.</p>
                          
                        }
                    </div>

                    <form method="post" asp-action="InitiatePayment" asp-controller="Payment">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookingId" value="@Model.Booking.Id" />
                        <input type="hidden" name="email" value="@Model.UserEmail" />
                        <input type="hidden" name="amount" value="@Model.DepositAmount" />

                        <button type="submit" class="btn w-100 py-3" style="background: @buttonGradient; color: #000; font-weight: 800; border-radius: 999px; border: none;">
                            @buttonText – R @Model.DepositAmount.ToString("N2")
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>