@model BeautyArtists.Models.ViewModels.MyBookingsViewModel
@{
    ViewData["Title"] = "My Appointments";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bookingsList = Model.Bookings.Select(item => item.Booking).ToList();
    var pending = bookingsList.Count(b => b.Status == BeautyArtists.Models.Booking.BookingStatus.Pending);
    var accepted = bookingsList.Count(b => b.Status == BeautyArtists.Models.Booking.BookingStatus.Accepted);
    var confirmed = bookingsList.Count(b => b.Status == BeautyArtists.Models.Booking.BookingStatus.Confirmed);
    var completed = bookingsList.Count(b => b.Status == BeautyArtists.Models.Booking.BookingStatus.Completed);
    var cancelled = bookingsList.Count(b => b.Status == BeautyArtists.Models.Booking.BookingStatus.Cancelled);
    var rejected = bookingsList.Count(b => b.Status == BeautyArtists.Models.Booking.BookingStatus.Rejected);

    // ── Get filter values from ViewBag (set by controller) ──
    var selectedMonth = ViewBag.SelectedMonth as string;      // "yyyy-MM"
    var startDate = ViewBag.StartDate as DateTime?;
    var endDate = ViewBag.EndDate as DateTime?;
    var selectedStatus = ViewBag.SelectedStatus as string;
}

<div class="mb-page">

    @* ── HEADER ── *@
    <div class="mb-hero">
        <div class="mb-hero-bg"></div>
        <div class="container mb-hero-inner">
            <div>
                <span class="mb-eyebrow">Your Schedule</span>
                <h1 class="mb-title">My Appointments</h1>
                <p class="mb-subtitle">Track and manage all your beauty bookings</p>
            </div>
            <div class="mb-stats-row">
                <div class="mb-stat">
                    <span class="mb-stat-num">@Model.TotalCount</span>
                    <span class="mb-stat-label">TOTAL</span>
                </div>
                <div class="mb-stat-div"></div>
                <div class="mb-stat">
                    <span class="mb-stat-num" style="color:#f0c808">@pending</span>
                    <span class="mb-stat-label">PENDING</span>
                </div>
                <div class="mb-stat-div"></div>
                <div class="mb-stat">
                    <span class="mb-stat-num" style="color:#17a2b8">@accepted</span>
                    <span class="mb-stat-label">ACCEPTED</span>
                </div>
                <div class="mb-stat-div"></div>
                <div class="mb-stat">
                    <span class="mb-stat-num" style="color:#00c853">@confirmed</span>
                    <span class="mb-stat-label">CONFIRMED</span>
                </div>
                <div class="mb-stat-div"></div>
                <div class="mb-stat">
                    <span class="mb-stat-num" style="color:#e50914">@rejected</span>
                    <span class="mb-stat-label">REJECTED</span>
                </div>
            </div>

            <!-- Reviews Link -->
            <div class="mb-reviews-link-row">
                <a asp-controller="Review" asp-action="MyReviews" class="mb-reviews-link">
                    <span class="mr-icon">⭐</span> View My Reviews
                </a>
            </div>
        </div>
    </div>

    @* ── SUCCESS / ERROR MESSAGES ── *@
    @if (TempData["Success"] != null)
    {
        <div class="container mt-4">
            <div class="mb-alert-success">
                <span>✓</span> @TempData["Success"]
            </div>
        </div>
    }

    @* ── FILTER PILL + PANEL ── *@
    <div class="container mt-4">
        <!-- Filter Toggle Pill -->
        <div class="mb-filter-pill-wrapper">
            <button class="mb-filter-pill" id="filterToggleBtn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="4" y1="6" x2="20" y2="6" />
                    <line x1="8" y1="12" x2="16" y2="12" />
                    <line x1="11" y1="18" x2="13" y2="18" />
                </svg>
                Filter
                <span id="filterActiveBadge" class="mb-filter-badge" style="display:none;">●</span>
            </button>
        </div>

        <!-- Filter Panel (initially hidden) -->
        <div class="mb-filter-panel" id="filterPanel" style="display:none;">
            <form method="get" asp-action="MyBookings" id="filterForm">
                <div class="mb-filter-row">

                    @* Month dropdown (Jan to Dec – NO YEARS) *@
                    <div class="mb-filter-group">
                        <label class="mb-filter-label" for="filterMonth">Month</label>
                        <select id="filterMonth" name="month" class="mb-filter-select">
                            <option value="">All Months</option>
                            @{
                                var months = new string[]
                                {
                                                        "January", "February", "March", "April", "May", "June",
                                                        "July", "August", "September", "October", "November", "December"
                                };
                                for (int i = 1; i <= 12; i++)
                                {
                                    var monthValue = DateTime.Now.Year + "-" + i.ToString("D2");
                                    var monthText = months[i - 1];
                                    var isSelected = selectedMonth == monthValue;
                                    <option value="@monthValue" selected="@isSelected">@monthText</option>
                                }
                            }
                        </select>
                    </div>

                    @* Date range *@
                    <div class="mb-filter-group">
                        <label class="mb-filter-label" for="filterStartDate">From</label>
                        <input type="date" id="filterStartDate" name="startDate" class="mb-filter-input"
                               value="@(startDate?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>
                    <div class="mb-filter-group">
                        <label class="mb-filter-label" for="filterEndDate">To</label>
                        <input type="date" id="filterEndDate" name="endDate" class="mb-filter-input"
                               value="@(endDate?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    @* Status dropdown *@
                    <div class="mb-filter-group">
                        <label class="mb-filter-label" for="filterStatus">Status</label>
                        <select id="filterStatus" name="status" class="mb-filter-select">
                            <option value="">All Statuses</option>
                            @foreach (var status in Enum.GetValues(typeof(BeautyArtists.Models.Booking.BookingStatus)))
                            {
                                var statusStr = status.ToString();
                                var isSelected = selectedStatus == statusStr;
                                <option value="@statusStr" selected="@isSelected">@statusStr.ToUpper()</option>
                            }
                        </select>
                    </div>

                    @* Action buttons *@
                    <div class="mb-filter-actions">
                        <button type="submit" class="mb-filter-btn-apply">Apply Filters</button>
                        <a asp-action="MyBookings" class="mb-filter-btn-clear">Clear</a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    @* ── BOOKINGS LIST ── *@
    <div class="container mb-body">

        @if (!bookingsList.Any())
        {
            <div class="mb-empty">
                <div class="mb-empty-icon">📅</div>
                <h3>No Appointments Yet</h3>
                <p>You haven't booked any services yet. Explore our artists and book your first appointment!</p>
                <a asp-controller="Home" asp-action="Index" class="mb-btn-primary">
                    Explore Services
                </a>
            </div>
        }
        else
        {
            @foreach (var item in Model.Bookings)
            {
                var booking = item.Booking;
                string statusClass = booking.Status switch
                {
                    BeautyArtists.Models.Booking.BookingStatus.Pending => "status-pending",
                    BeautyArtists.Models.Booking.BookingStatus.Accepted => "status-accepted",
                    BeautyArtists.Models.Booking.BookingStatus.Confirmed => "status-confirmed",
                    BeautyArtists.Models.Booking.BookingStatus.Completed => "status-completed",
                    BeautyArtists.Models.Booking.BookingStatus.Cancelled => "status-cancelled",
                    BeautyArtists.Models.Booking.BookingStatus.Rejected => "status-rejected",
                    _ => "status-pending"
                };
                string statusIcon = booking.Status switch
                {
                    BeautyArtists.Models.Booking.BookingStatus.Pending => "⏳",
                    BeautyArtists.Models.Booking.BookingStatus.Accepted => "👍",
                    BeautyArtists.Models.Booking.BookingStatus.Confirmed => "✅",
                    BeautyArtists.Models.Booking.BookingStatus.Completed => "⭐",
                    BeautyArtists.Models.Booking.BookingStatus.Cancelled => "❌",
                    BeautyArtists.Models.Booking.BookingStatus.Rejected => "🚫",
                    _ => "⏳"
                };
                string statusDisplay = booking.Status switch
                {
                    BeautyArtists.Models.Booking.BookingStatus.Accepted => "ACCEPTED - AWAITING DEPOSIT",
                    BeautyArtists.Models.Booking.BookingStatus.Rejected => "REJECTED",
                    _ => booking.Status.ToString().ToUpper()
                };

                string artistName = booking.UserService?.Artist?.ArtistProfile?.FullName
                ?? (!string.IsNullOrEmpty(booking.UserService?.Artist?.FirstName)
                ? $"{booking.UserService.Artist.FirstName} {booking.UserService.Artist.LastName}".Trim()
                : booking.UserService?.Artist?.UserName ?? "Pro Artist");

                // ── Payment status ──
                bool isFullyPaid = (booking.DepositPaid + booking.FinalPaymentPaid) >= booking.ServicePrice;
                bool hasDeposit = booking.DepositPaid > 0;
                string paymentStatusText = isFullyPaid ? "Fully Paid" : (hasDeposit ? "Deposit Paid" : "Unpaid");
                string paymentStatusColor = isFullyPaid ? "#28a745" : (hasDeposit ? "#ffc107" : "#6c757d");
                // ── Days until appointment ──
                double daysUntilAppointment = (booking.AppointmentDate.Date - DateTime.Now.Date).TotalDays;
                bool isLastMinute = daysUntilAppointment < 2;

                <div class="mb-card @(booking.Status == BeautyArtists.Models.Booking.BookingStatus.Cancelled || booking.Status == BeautyArtists.Models.Booking.BookingStatus.Rejected ? "mb-card-cancelled" : "")">

                    @* Status strip *@
                    <div class="mb-card-strip @statusClass"></div>

                    <div class="mb-card-body">

                        @* Left: Service info *@
                        <div class="mb-card-main">
                            <div class="mb-card-header">
                                <span class="mb-status-badge @statusClass">
                                    @statusIcon @statusDisplay
                                </span>
                                <span class="mb-booking-id">#@booking.Id</span>
                            </div>

                            <h3 class="mb-service-name">
                                @(booking.UserService?.Service?.Name ?? "Service")
                            </h3>

                            <div class="mb-card-meta">
                                <div class="mb-meta-item">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                        <circle cx="12" cy="7" r="4" />
                                    </svg>
                                    @artistName
                                </div>
                                <div class="mb-meta-item">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                        <line x1="16" y1="2" x2="16" y2="6" />
                                        <line x1="8" y1="2" x2="8" y2="6" />
                                        <line x1="3" y1="10" x2="21" y2="10" />
                                    </svg>
                                    @booking.AppointmentDate.ToString("dddd, dd MMM yyyy")
                                </div>
                                <div class="mb-meta-item">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <polyline points="12,6 12,12 16,14" />
                                    </svg>
                                    @booking.AppointmentDate.ToString("HH:mm")
                                </div>

                                @* ── PAYMENT STATUS ── *@
                                <div class="mb-meta-item" style="margin-top: 6px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 6px;">
                                    <span style="color: @paymentStatusColor; font-weight: 700;">
                                        @paymentStatusText
                                    </span>
                                    @if (isFullyPaid)
                                    {
                                        <span style="color: #28a745;">✅</span>
                                    }
                                    else if (hasDeposit)
                                    {
                                        <span style="color: #ffc107;">💰</span>
                                    }
                                    else
                                    {
                                        <span style="color: #6c757d;">⏳</span>
                                    }
                                    @if (isLastMinute && !isFullyPaid)
                                    {
                                        <span style="color: #ff6b6b; font-size: 0.7rem; margin-left: 6px;">(⚠️ Last Minute)</span>
                                    }
                                </div>

                                @* ── STUDIO LOCATION (Walk‑in, location shared, deposit paid) ── *@
                                @if (item.Booking.SelectedLocationType == BeautyArtists.Models.LocationType.WalkIn
                                                        && item.Booking.IsLocationShared
                                                        && item.Booking.IsDepositPaid)
                                {
                                    <div style="background:rgba(52,152,219,0.08);border:1px solid rgba(52,152,219,0.3);border-radius:10px;padding:14px;margin-bottom:14px;">
                                        <span style="font-size:0.6rem;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,0.3);display:block;margin-bottom:8px;">
                                            📍 Studio Location
                                        </span>

                                        @if (!string.IsNullOrEmpty(item.StudioAddress))
                                        {
                                            <div style="font-size:0.85rem;color:#fff;padding:3px 0;border-bottom:1px solid rgba(255,255,255,0.05);">
                                                <strong style="color:#FFD700;min-width:80px;display:inline-block;">Address:</strong>
                                                <span>@item.StudioAddress</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(item.StudioCity))
                                        {
                                            <div style="font-size:0.85rem;color:#fff;padding:3px 0;border-bottom:1px solid rgba(255,255,255,0.05);">
                                                <strong style="color:#FFD700;min-width:80px;display:inline-block;">City:</strong>
                                                <span>@item.StudioCity</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(item.StudioProvince))
                                        {
                                            <div style="font-size:0.85rem;color:#fff;padding:3px 0;">
                                                <strong style="color:#FFD700;min-width:80px;display:inline-block;">Province:</strong>
                                                <span>@item.StudioProvince</span>
                                            </div>
                                        }

                                        @if (item.StudioLatitude.HasValue && item.StudioLongitude.HasValue)
                                        {
                                            <div style="margin-top:10px;">
                                                <a href="https://www.google.com/maps/search/?api=1&query=@item.StudioLatitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@item.StudioLongitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                   target="_blank"
                                                   style="display:block;text-align:center;padding:9px;background:#1e1e1e;border:1px solid #00ffcc;color:#00ffcc;border-radius:8px;font-size:0.75rem;font-weight:700;text-decoration:none;transition:all .2s;">
                                                    🗺 OPEN STUDIO IN GOOGLE MAPS
                                                </a>
                                            </div>
                                        }
                                        else if (!string.IsNullOrEmpty(item.StudioAddress))
                                        {
                                            var searchQuery = Uri.EscapeDataString($"{item.StudioAddress} {item.StudioCity} {item.StudioProvince}".Trim());
                                            <div style="margin-top:10px;">
                                                <a href="https://www.google.com/maps/search/?api=1&query=@searchQuery"
                                                   target="_blank"
                                                   style="display:block;text-align:center;padding:9px;background:#1e1e1e;border:1px solid #00ffcc;color:#00ffcc;border-radius:8px;font-size:0.75rem;font-weight:700;text-decoration:none;">
                                                    🗺 OPEN STUDIO IN GOOGLE MAPS
                                                </a>
                                            </div>
                                        }
                                    </div>
                                }
                                else if (item.Booking.SelectedLocationType == BeautyArtists.Models.LocationType.WalkIn
                                && item.Booking.Status == BeautyArtists.Models.Booking.BookingStatus.Confirmed
                                && !item.Booking.IsDepositPaid)
                                {
                                    <div style="background:rgba(240,200,8,0.05);border:1px dashed rgba(240,200,8,0.2);border-radius:10px;padding:12px;margin-bottom:14px;text-align:center;">
                                        <span style="font-size:0.75rem;color:rgba(240,200,8,0.6);">
                                            🔒 Studio address unlocks after your 50% deposit is paid.
                                        </span>
                                    </div>
                                }

                                @* ── Transport Cost (House Call) ── *@
                                @if (booking.SelectedLocationType == BeautyArtists.Models.LocationType.HouseCall && booking.TransportCost > 0)
                                {
                                    <div class="mb-meta-item" style="color: #FFD700;">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 3h3l4 9h10l4-9h3" />
                                            <circle cx="7" cy="19" r="2" />
                                            <circle cx="17" cy="19" r="2" />
                                        </svg>
                                        Transport Cost: <strong>R @booking.TransportCost.ToString("N0")</strong>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(booking.Notes))
                                {
                                    <div class="mb-meta-item mb-notes">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14,2 14,8 20,8" />
                                        </svg>
                                        <strong>Note:</strong> @booking.Notes
                                    </div>
                                }

                                @* Artist Notes *@
                                @if (!string.IsNullOrEmpty(booking.ArtistNotes))
                                {
                                    <div class="mb-meta-item" style="color: #FFD700 !important; margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(255,215,0,0.1);">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                        </svg>
                                        <span style="font-weight: 700; margin-right: 4px;">Artist Note:</span> @booking.ArtistNotes
                                    </div>
                                }

                                @* Cancellation Reason *@
                                @if (!string.IsNullOrEmpty(booking.ClientNotes))
                                {
                                    <div class="mb-meta-item" style="color: #ff5555 !important; border-top: 1px solid rgba(255,85,85,0.1); margin-top: 4px; padding-top: 4px;">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <line x1="12" y1="8" x2="12" y2="12"></line>
                                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                        </svg>
                                        <strong>Update Reason:</strong> @booking.ClientNotes
                                    </div>
                                }
                            </div>
                        </div>

                        @* ── RIGHT: PRICE + ACTIONS ── *@
                        <div class="mb-card-right">
                            <div class="mb-amount">
                                <span class="mb-amount-label">Service Price</span>
                                <span class="mb-amount-value" style="color: #fff; font-size: 1.2rem;">R @booking.ServicePrice.ToString("N0")</span>
                                <span style="display: block; font-size: 0.65rem; color: rgba(255,215,0,0.5);">+ R @booking.BookingFee.ToString("N0") booking fee</span>
                                <span class="mb-amount-label" style="margin-top: 4px;">Total</span>
                                <span class="mb-amount-value">R @booking.TotalAmount.ToString("N0")</span>
                                @if (booking.SelectedLocationType == BeautyArtists.Models.LocationType.HouseCall && booking.TransportCost > 0)
                                {
                                    <span class="mb-amount-label" style="font-size: 0.5rem;">(includes transport)</span>
                                }
                            </div>

                            <div class="mb-actions">
                                @* ── PAYMENT BUTTON FOR ACCEPTED STATUS ── *@
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Accepted && !booking.IsDepositPaid)
                                {
                                    if (isLastMinute)
                                    {
                                        <a asp-controller="Booking"
                                           asp-action="CheckoutDeposit"
                                           asp-route-id="@booking.Id"
                                           class="mb-btn-deposit" style="background: linear-gradient(135deg, #f0c808, #e50914); color: #000;">
                                            ⚠️ Pay Full Amount – R @booking.TotalAmount.ToString("N0")
                                        </a>
                                        <span class="text-muted small" style="font-size:0.65rem; text-align:center; display:block; color:#ff6b6b;">
                                            ⚠️ Appointment within 2 days – full amount required
                                        </span>
                                    }
                                    else
                                    {
                                        decimal depositAmount = booking.ServicePrice / 2;
                                        <a asp-controller="Booking"
                                           asp-action="CheckoutDeposit"
                                           asp-route-id="@booking.Id"
                                           class="mb-btn-deposit">
                                            💰 PAY 50% DEPOSIT – R @depositAmount.ToString("N0")
                                        </a>
                                    }
                                }

                                @* ── PAYMENT BUTTONS FOR CONFIRMED STATUS ── *@
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Confirmed)
                                {
                                    decimal remainingBalance = booking.ServicePrice / 2;

                                    if (!booking.IsDepositPaid)
                                    {
                                        remainingBalance = (booking.ServicePrice / 2) + booking.BookingFee;
                                    }

                                    if (remainingBalance < 0) remainingBalance = 0;

                                    if (remainingBalance <= 0 || isFullyPaid)
                                    {
                                        <span class="text-muted small" style="text-align:center; display:block; padding:4px 0; color:#28a745; font-weight:600;">
                                            ✅ Fully Paid – No action needed
                                        </span>
                                    }
                                    else
                                    {
                                        if (isLastMinute)
                                        {
                                            <a asp-controller="Booking"
                                               asp-action="CheckoutFinalPayment"
                                               asp-route-id="@booking.Id"
                                               class="mb-btn-final" style="background: linear-gradient(135deg, #f0c808, #e50914); color: #000;">
                                                ⚠️ Pay Now – R @remainingBalance.ToString("N0")
                                            </a>
                                            <span class="text-muted small" style="font-size:0.65rem; text-align:center; display:block; color:#ff6b6b;">
                                                ⚠️ Appointment within 2 days – full amount required
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-controller="Booking"
                                               asp-action="CheckoutFinalPayment"
                                               asp-route-id="@booking.Id"
                                               class="mb-btn-final">
                                                💳 Pay Remaining – R @remainingBalance.ToString("N0")
                                            </a>
                                        }
                                    }
                                }

                                @* RESCHEDULE BUTTON - ONLY FOR CONFIRMED BOOKINGS *@
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Confirmed && !booking.HasRescheduled)
                                {
                                    <a asp-controller="Booking"
                                       asp-action="Reschedule"
                                       asp-route-id="@booking.Id"
                                       class="mb-btn-secondary">
                                        Reschedule
                                    </a>
                                }

                                @* CANCEL BUTTON - FOR PENDING, ACCEPTED, AND CONFIRMED *@
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Pending
                                                        || booking.Status == BeautyArtists.Models.Booking.BookingStatus.Accepted
                                                        || booking.Status == BeautyArtists.Models.Booking.BookingStatus.Confirmed)
                                {
                                    <form asp-controller="Booking" asp-action="Cancel"
                                          asp-route-id="@booking.Id" method="post"
                                          onsubmit="return handleCancelPrompt(this);">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="clientNotes" />
                                        <button type="submit" class="mb-btn-cancel">Cancel</button>
                                    </form>
                                }

                                @* ── REVIEW BUTTON (CLIENT ONLY - NO MARK COMPLETED) ── *@
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Completed)
                                {
                                    if (!item.HasReviewed)
                                    {
                                        <a asp-controller="Review"
                                           asp-action="Create"
                                           asp-route-bookingId="@booking.Id"
                                           class="mb-btn-review">
                                            ⭐ Leave a Review
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small" style="text-align:center; display:block; padding:4px 0; color:rgba(255,255,255,0.4);">✅ Review submitted</span>
                                    }
                                }

                                @* ── REJECTED STATUS - SHOW REASON ── *@
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Rejected && !string.IsNullOrEmpty(booking.ArtistNotes))
                                {
                                    <div class="alert alert-danger text-center mb-0" style="background: rgba(255,50,50,0.1); border: 1px solid #ff5555; color: #ff5555; font-size: 0.7rem; padding: 6px 10px;">
                                        <strong>Reason:</strong> @booking.ArtistNotes
                                    </div>
                                }
                            </div>

                            @* ── BOOKED DATE ── *@
                            <div class="mb-booked-wrapper">
                                <span class="mb-booked-on">
                                    Booked @booking.BookingDate.ToString("dd MMM yyyy")
                                </span>
                            </div>
                        </div>

                    </div>
                </div>
            }

            @* ─── PAGINATION (with filters preserved) ─── *@
            @if (Model.TotalPages > 1)
            {
                <div class="pagination-wrapper" style="margin-top: 30px;">
                    <div class="pagination-container" style="display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap;">

                        @* Helper to build route values preserving filters *@
                        @{
                            var routeParams = new Dictionary<string, string>();
                            if (!string.IsNullOrEmpty(selectedMonth)) routeParams["month"] = selectedMonth;
                            if (startDate.HasValue) routeParams["startDate"] = startDate.Value.ToString("yyyy-MM-dd");
                            if (endDate.HasValue) routeParams["endDate"] = endDate.Value.ToString("yyyy-MM-dd");
                            if (!string.IsNullOrEmpty(selectedStatus)) routeParams["status"] = selectedStatus;
                        }

                        @if (Model.CurrentPage > 1)
                        {
                            var prevParams = new Dictionary<string, string>(routeParams) { ["page"] = (Model.CurrentPage - 1).ToString() };
                            <a asp-action="MyBookings" asp-all-route-data="prevParams" class="pagination-btn">
                                <i class="fas fa-chevron-left"></i> Previous
                            </a>
                        }

                        <div style="display: flex; gap: 4px; flex-wrap: wrap;">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                if (i == Model.CurrentPage)
                                {
                                    <span style="padding: 8px 14px; background: #FFD700; color: #000; border-radius: 8px; font-weight: 800; font-size: 0.85rem;">@i</span>
                                }
                                else if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.CurrentPage) <= 2)
                                {
                                    var pageParams = new Dictionary<string, string>(routeParams) { ["page"] = i.ToString() };
                                    <a asp-action="MyBookings" asp-all-route-data="pageParams" style="padding: 8px 14px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: rgba(255,255,255,0.6); font-size: 0.85rem; text-decoration: none; transition: 0.2s;">
                                        @i
                                    </a>
                                }
                                else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                                {
                                    <span style="padding: 8px 8px; color: rgba(255,255,255,0.2); font-size: 0.85rem;">…</span>
                                }
                            }
                        </div>

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            var nextParams = new Dictionary<string, string>(routeParams) { ["page"] = (Model.CurrentPage + 1).ToString() };
                            <a asp-action="MyBookings" asp-all-route-data="nextParams" class="pagination-btn">
                                Next <i class="fas fa-chevron-right"></i>
                            </a>
                        }
                    </div>
                    <div class="pagination-info" style="text-align: center; margin-top: 12px; color: rgba(255,255,255,0.3); font-size: 0.75rem;">
                        Showing <span style="color: #FFD700;">@((Model.CurrentPage - 1) * 10 + 1)</span> - <span style="color: #FFD700;">@Math.Min(Model.CurrentPage * 10, Model.TotalCount)</span> of <span style="color: #FFD700;">@Model.TotalCount</span> appointments
                    </div>
                </div>
            }
        }

        <div class="mb-footer-link">
            <a asp-controller="Home" asp-action="Index" class="cat-back-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                    <polyline points="15,18 9,12 15,6" />
                </svg>
                Back to Home
            </a>
        </div>
    </div>
</div>

<script>
    function handleCancelPrompt(form) {
        var reason = prompt("Please provide a reason for cancelling:");
        if (reason === null) return false;
        if (reason.trim() === "") {
            alert("Cancellation reason is required.");
            return false;
        }
        form.querySelector('input[name="clientNotes"]').value = reason;
        return confirm('Are you sure you want to cancel this appointment?');
    }

    // ── FILTER TOGGLE ──
    document.addEventListener('DOMContentLoaded', function() {
        var toggleBtn = document.getElementById('filterToggleBtn');
        var panel = document.getElementById('filterPanel');
        var badge = document.getElementById('filterActiveBadge');

        // Check if any filter is active (if ViewBag has values)
        var hasActiveFilter = '@(string.IsNullOrEmpty(selectedMonth) && !startDate.HasValue && !endDate.HasValue && string.IsNullOrEmpty(selectedStatus) ? "false" : "true")' === 'true';
        if (hasActiveFilter) {
            badge.style.display = 'inline';
        }

        toggleBtn.addEventListener('click', function() {
            if (panel.style.display === 'none' || panel.style.display === '') {
                panel.style.display = 'block';
            } else {
                panel.style.display = 'none';
            }
        });

        // Auto-open if filters are active
        if (hasActiveFilter) {
            panel.style.display = 'block';
        }
    });
</script>

