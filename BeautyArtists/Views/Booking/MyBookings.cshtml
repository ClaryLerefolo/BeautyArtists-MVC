            color: #FFD700;
        }

        .mb-reviews-link .mr-icon {
            font-size: 1.1rem;
        }

    .mb-alert-success {
        background: rgba(0,200,83,0.1);
        border: 1px solid rgba(0,200,83,0.3);
        border-radius: 10px;
        padding: 12px 18px;
        color: #00c853;
        font-size: 0.88rem;
        font-weight: 600;
    }

    .mb-alert-error {
        background: rgba(255,50,50,0.08);
        border: 1px solid rgba(255,50,50,0.25);
        border-radius: 10px;
