        width: 100%;
        justify-content: center;
        flex-wrap: wrap;
    }

    .mb-stat {
        text-align: center;
    }

    .mb-stat-num {
        display: block;
        font-size: 1.5rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .mb-stat-label {
        display: block;
        font-size: 0.52rem;
        font-weight: 700;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.25);
        margin-top: 3px;
    }

    .mb-stat-div {
        width: 1px;
        height: 36px;
        background: rgba(255,215,0,0.12);
    }

    /* ── NEW REVIEWS LINK ROW ── */
    .mb-reviews-link-row {
        margin-top: 6px;
        display: flex;
        justify-content: center;
        width: 100%;
    }

    .mb-reviews-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
