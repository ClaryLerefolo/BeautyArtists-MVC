        background: linear-gradient(135deg, #f0c808, #e50914);
        color: #000;
        border-radius: 50px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }

        .mb-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px rgba(240,200,8,0.3);
            color: #000;
        }

    .mb-card {
        display: flex;
        background: #0b0b0b;
        border: 1px solid rgba(255,215,0,0.1);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 16px;
        transition: border-color 0.25s, transform 0.25s;
    }

        .mb-card:hover {
            border-color: rgba(255,215,0,0.25);
            transform: translateY(-2px);
        }

    .mb-card-cancelled {
        opacity: 0.5;
    }

    .mb-card-strip {
        width: 5px;
        flex-shrink: 0;
    }

    .status-pending {
        background: #f0c808;
    }

    .status-accepted {
        background: #17a2b8;
    }

    .status-confirmed {
        background: #00c853;
    }

    .status-completed {
        background: #2979ff;
    }

    .status-cancelled {
        background: #555;
    }

