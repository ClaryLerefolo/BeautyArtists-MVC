@model IEnumerable<BeautyArtists.Models.Portfolio>
@{
    ViewData["Title"] = "Manage Your Portfolios";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

@section Styles {
    <style>
        body {
            background: #000;
            color: #f0f0f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .dashboard-header {
            background: linear-gradient(90deg, #e50914, #f0c808);
            padding: 20px;
            border-radius: 0 0 12px 12px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            margin-bottom: 25px;
        }

            .dashboard-header h2 {
                color: #000;
                font-weight: 800;
                font-size: 2.2rem;
                margin: 0;
            }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            padding: 0 20px;
        }

        .portfolio-card {
            background: #121212;
            border: 1px solid rgba(240, 200, 8, 0.15);
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.8);
            transition: transform 0.3s ease;
        }

            .portfolio-card:hover {
                transform: translateY(-8px);
                border-color: #f0c808;
            }

        .portfolio-header {
            font-size: 1.5rem;
            color: #f0c808;
            font-weight: 700;
        }

        .portfolio-desc {
            min-height: 48px;
            line-height: 1.4;
            color: rgba(255,255,255,0.6);
        }

        .action-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1.5fr auto;
            gap: 8px;
            margin-top: 15px;
        }

        .btn-action {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 10px 0;
            font-size: 0.7rem;
            font-weight: 700;
            color: #f0c808;
            background: transparent;
            border: 1px solid #f0c808;
            border-radius: 8px;
            transition: 0.2s;
            text-transform: uppercase;
            cursor: pointer;
            text-decoration: none;
        }

            .btn-action:hover {
                background: #f0c808;
                color: #000;
            }

            .btn-action i {
                font-size: 1.1rem;
                margin-bottom: 4px;
            }

        .btn-delete-square {
            background: #e50914;
            border: none;
            color: #fff;
            padding: 10px 14px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #121212;
            border: 1px solid #ffcc00;
            border-radius: 15px;
            box-shadow: 0px 0px 15px rgba(255, 153, 0, 0.3);
        }

        .modal-header {
            border-bottom: 1px solid #444;
            color: #ffcc00;
        }

        .form-label {
            color: #f0c808;
            font-weight: 600;
        }

        .form-control, .form-select {
            background-color: #1e1e1e !important;
            border: 1px solid #444 !important;
            color: #fff !important;
            padding: 12px;
        }

            .form-control:focus {
                border-color: #ff9900 !important;
                box-shadow: 0 0 5px rgba(255, 153, 0, 0.5);
            }

        .drop-area {
            border: 2px dashed #f0c808;
            padding: 25px;
            text-align: center;
            border-radius: 12px;
            background: rgba(255,255,255,0.05);
            cursor: pointer;
        }

        .preview-img {
            max-width: 100%;
            max-height: 200px;
            margin-top: 15px;
            border-radius: 8px;
            display: none;
            border: 1px solid #f0c808;
        }

        .btn-gold-action {
            background: linear-gradient(to right, #ffcc00, #ff9900);
            color: #000;
            font-weight: bold;
            text-transform: uppercase;
            border: none;
            padding: 10px 30px;
            border-radius: 5px;
        }

            .btn-gold-action:hover {
                background: linear-gradient(to right, #ff9900, #ffcc00);
            }

        /* ── Lightbox Styles ── */
        .lightbox-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.92);
            z-index: 9999;
            overflow: hidden;
            animation: fadeIn 0.3s ease;
        }

            .lightbox-overlay.active {
                display: flex;
                align-items: center;
                justify-content: center;
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .lightbox-container {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-close {
            position: absolute;
            top: 20px;
            right: 30px;
            background: none;
            border: none;
            color: #fff;
            font-size: 2.5rem;
            cursor: pointer;
            z-index: 100;
            transition: color 0.3s;
        }

            .lightbox-close:hover {
                color: #FFD700;
            }

        .lightbox-prev, .lightbox-next {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.08);
            border: none;
            color: #fff;
            font-size: 3rem;
            padding: 20px 12px;
            cursor: pointer;
            z-index: 100;
            transition: background 0.3s;
            border-radius: 4px;
            user-select: none;
        }

        .lightbox-prev {
            left: 20px;
        }

        .lightbox-next {
            right: 20px;
        }

            .lightbox-prev:hover, .lightbox-next:hover {
                background: rgba(255,215,0,0.2);
                color: #FFD700;
            }

        .lightbox-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            padding: 60px;
        }

        .lightbox-counter {
            color: rgba(255,255,255,0.5);
            font-size: 0.9rem;
            margin-bottom: 16px;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .lightbox-media-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            max-height: 85vh;
            overflow: hidden;
        }

        #lightboxImage {
            max-width: 90%;
            max-height: 85vh;
            object-fit: contain;
            cursor: zoom-in;
            transition: transform 0.3s ease;
        }

            #lightboxImage.zoomed {
                transform: scale(2);
                cursor: zoom-out;
            }

        #lightboxVideo {
            max-width: 90%;
            max-height: 85vh;
            border-radius: 8px;
            background: #000;
        }

        .lightbox-caption {
            color: rgba(255,255,255,0.6);
            font-size: 0.9rem;
            margin-top: 16px;
            text-align: center;
            max-width: 70%;
            line-height: 1.4;
        }

        @@media (max-width: 768px) {
            .lightbox-prev, .lightbox-next {
                font-size: 1.8rem;
                padding: 10px 8px;
            }

            .lightbox-prev {
                left: 8px;
            }

            .lightbox-next {
                right: 8px;
            }

            .lightbox-content {
                padding: 40px 20px;
            }

            .lightbox-caption {
                max-width: 90%;
                font-size: 0.8rem;
            }
        }
    </style>
}

<div class="dashboard-header">
    <h2>Manage Your Portfolios</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center mx-4">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center mx-4">@TempData["Success"]</div>
}

<div class="d-flex justify-content-end mb-4 px-4">
    <button class="btn rounded-pill px-4 py-2" data-bs-toggle="modal" data-bs-target="#createPortfolioModal"
            style="background: linear-gradient(45deg, #f0c808, #e50914); color: #000; font-weight: 700; border: none;">
        <i class="fas fa-plus-circle me-2"></i>New Portfolio
    </button>
</div>

<div class="portfolio-grid" id="portfolioGrid">
    @foreach (var portfolio in Model)
    {
        <div class="portfolio-card" id="portfolioCard-@portfolio.Id">
            @if (portfolio.Items != null && portfolio.Items.Any())
            {
                var latestItem = portfolio.Items.OrderByDescending(i => i.UploadedAt).First();
                var isVideo = !string.IsNullOrEmpty(latestItem.MediaType) && latestItem.MediaType.Equals("Video", StringComparison.OrdinalIgnoreCase);

                <div class="portfolio-thumbnail position-relative"
                     data-mediaurl="@latestItem.MediaUrl"
                     data-title="@latestItem.Title"
                     data-description="@latestItem.Description"
                     data-mediatype="@(isVideo ? "video" : "image")"
                     onclick="openLightbox(this)"
                     style="cursor:pointer;border-radius:8px;overflow:hidden;height:180px;margin-bottom:12px;background:#000;">

                    @if (isVideo)
                    {
                        <video style="width:100%;height:100%;object-fit:cover;"
                               muted
                               playsinline
                               preload="metadata">
                            <source src="@Url.Content(latestItem.MediaUrl)" type="video/mp4" />
                            Your browser does not support the video tag.
                        </video>
                        <div class="play-overlay" style="position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.2);pointer-events:none;">
                            <i class="bi bi-play-circle-fill" style="font-size:3rem;color:#FFD700;opacity:0.9;text-shadow:0 0 20px rgba(0,0,0,0.9);"></i>
                        </div>
                    }
                    else
                    {
                        <img src="@Url.Content(latestItem.MediaUrl)"
                             style="width:100%;height:100%;object-fit:cover;"
                             onerror="this.src='/images/placeholder.jpg';" />
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 mb-3 bg-dark rounded border border-secondary border-dashed" style="height: 180px;">
                    <i class="fas fa-camera-retro fa-2x text-muted"></i>
                    <p class="small text-muted mt-2">Empty Gallery</p>
                </div>
            }

            <div class="portfolio-header mb-1">@portfolio.Name</div>
            <p class="portfolio-desc small mb-2">@portfolio.Description</p>
            <div class="small text-muted mb-3">
                <span>Created: @portfolio.CreatedAt.ToString("yyyy/MM/dd")</span> | <span>@portfolio.Items?.Count Items</span>
            </div>

            <div class="action-row">
                <button class="btn-action" data-bs-toggle="modal" data-bs-target="#viewItemsModal-@portfolio.Id">
                    <i class="fas fa-eye"></i> View
                </button>
                <button type="button" class="btn-action" onclick="openEditModal('@portfolio.Id', '@portfolio.Name', '@portfolio.Description')">
                    <i class="fas fa-edit"></i> EDIT
                </button>
                <button class="btn-action" data-bs-toggle="modal" data-bs-target="#addItemModal-@portfolio.Id">
                    <i class="fas fa-plus-circle"></i> Add Item
                </button>
                <form asp-action="DeletePortfolio" asp-route-id="@portfolio.Id" method="post" onsubmit="return confirm('Delete Portfolio?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-delete-square h-100"><i class="fas fa-trash-alt"></i></button>
                </form>
            </div>
        </div>

        <!-- Add Item Modal (fixed layout) -->
        <div class="modal fade" id="addItemModal-@portfolio.Id" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <form asp-controller="Portfolio" asp-action="CreatePortfolioItem" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PortfolioId" value="@portfolio.Id" />
                        <div class="modal-header border-0">
                            <h5 class="modal-title text-gold">Upload Work to "@portfolio.Name"</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <div class="mb-3">
                                        <label class="form-label">Media File <span class="text-danger">*</span></label>
                                        <div class="drop-area" onclick="document.getElementById('file-@portfolio.Id').click()">
                                            <div id="prompt-@portfolio.Id">
                                                <i class="fas fa-cloud-upload-alt fa-2x text-warning"></i>
                                                <p class="mt-2 small">Click to upload image/video</p>
                                            </div>
                                            <input type="file" name="MediaFile" id="file-@portfolio.Id" class="d-none" onchange="previewFile(this, 'prev-@portfolio.Id', 'prompt-@portfolio.Id')" required />
                                            <img id="prev-@portfolio.Id" class="preview-img" />
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Service Category <span class="text-danger">*</span></label>
                                        <select name="CategoryId" class="form-select" required>
                                            <option value="">-- Select Category --</option>
                                            @if (ViewBag.Categories != null)
                                            {
                                                foreach (var cat in (IEnumerable<SelectListItem>)ViewBag.Categories)
                                                {
                                                    <option value="@cat.Value">@cat.Text</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <div class="row g-2">
                                        <div class="col-md-8">
                                            <label class="form-label">Title <span class="text-danger">*</span></label>
                                            <input name="Title" class="form-control" required />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Order</label>
                                            <input type="number" name="DisplayOrder" class="form-control" value="0" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Province <span class="text-danger">*</span></label>
                                            <select name="Province" class="form-select province-select" data-target="cSel-@portfolio.Id" required>
                                                <option value="">Select Province</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">City <span class="text-danger">*</span></label>
                                            <select name="City" id="cSel-@portfolio.Id" class="form-select city-select" required>
                                                <option value="">Select City</option>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Description</label>
                                            <textarea name="Description" class="form-control" rows="3"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn-gold-action">SAVE ITEM</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- View Items Modal -->
        <div class="modal fade" id="viewItemsModal-@portfolio.Id" tabindex="-1">
            <div class="modal-dialog modal-xl modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0">
                        <h5 class="modal-title text-gold">Gallery: @portfolio.Name</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body overflow-auto" style="max-height: 70vh;">
                        <div class="row g-3">
                            @if (portfolio.Items != null)
                            {
                                @foreach (var item in portfolio.Items)
                                {
                                    var isVideo = !string.IsNullOrEmpty(item.MediaType) && item.MediaType.Equals("Video", StringComparison.OrdinalIgnoreCase);
                                    <div class="col-md-3">
                                        <div class="card bg-black border-secondary h-100">
                                            <div class="portfolio-thumbnail position-relative"
                                                 data-mediaurl="@item.MediaUrl"
                                                 data-title="@item.Title"
                                                 data-description="@item.Description"
                                                 data-mediatype="@(isVideo ? "video" : "image")"
                                                 onclick="openLightbox(this)"
                                                 style="cursor:pointer;overflow:hidden;height:150px;background:#000;">

                                                @if (isVideo)
                                                {
                                                    <video style="width:100%;height:100%;object-fit:cover;"
                                                           muted
                                                           playsinline
                                                           preload="metadata">
                                                        <source src="@Url.Content(item.MediaUrl)" type="video/mp4" />
                                                        Your browser does not support the video tag.
                                                    </video>
                                                    <div class="play-overlay" style="position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.2);pointer-events:none;">
                                                        <i class="bi bi-play-circle-fill" style="font-size:2.5rem;color:#FFD700;opacity:0.9;text-shadow:0 0 20px rgba(0,0,0,0.9);"></i>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <img src="@Url.Content(item.MediaUrl)" style="width:100%;height:100%;object-fit:cover;" onerror="this.src='/images/placeholder.jpg';" />
                                                }
                                            </div>
                                            <div class="card-body p-2 text-center">
                                                <p class="small text-truncate mb-2">@item.Title</p>
                                                <div class="d-flex gap-1">
                                                    <a href="@Url.Action("EditPortfolioItem", "PortfolioItem", new { id = item.Id })" class="btn btn-sm btn-outline-warning w-100">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </a>
                                                    <button class="btn btn-sm btn-outline-danger delete-item-btn" data-id="@item.Id">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Create Portfolio Modal -->
<div class="modal fade" id="createPortfolioModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="createPortfolioForm">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0">
                    <h5 class="modal-title text-gold">New Collection</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Portfolio Name <span class="text-danger">*</span></label>
                        <input name="Name" type="text" class="form-control" required placeholder="e.g. Bridal Portfolio">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Short Description</label>
                        <textarea name="Description" class="form-control" rows="4"></textarea>
                    </div>
                    <button type="submit" class="btn-gold-action" style="width:100%;">CREATE PORTFOLIO</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Portfolio Modal -->
<div class="modal fade" id="editPortfolioModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="editPortfolioForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editPortfolioId" name="Id" />
                <div class="modal-header border-0">
                    <h5 class="modal-title text-gold">Edit Collection</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Portfolio Name <span class="text-danger">*</span></label>
                        <input id="editPortfolioName" name="Name" type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="editPortfolioDescription" name="Description" class="form-control" rows="4"></textarea>
                    </div>
                    <button type="submit" class="btn-gold-action" style="width:100%;">SAVE CHANGES</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Lightbox Overlay -->
<div id="lightbox" class="lightbox-overlay" onclick="closeLightbox(event)">
    <div class="lightbox-container">
        <button class="lightbox-close" onclick="closeLightbox()">&times;</button>
        <button class="lightbox-prev" onclick="navigateLightbox(-1)">&#10094;</button>
        <button class="lightbox-next" onclick="navigateLightbox(1)">&#10095;</button>
        <div class="lightbox-content">
            <div class="lightbox-counter" id="lightboxCounter"></div>
            <div id="lightboxMediaContainer" class="lightbox-media-container">
                <img id="lightboxImage" src="" alt="" style="display:none;max-width:90%;max-height:80vh;object-fit:contain;" />
                <video id="lightboxVideo" controls style="display:none;max-width:90%;max-height:80vh;" controlsList="nodownload">
                    <source id="videoSource" src="" type="video/mp4" />
                    Your browser does not support the video tag.
                </video>
            </div>
            <div class="lightbox-caption" id="lightboxCaption"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ── Location data ──
        const locationData = {
            "Gauteng": ["Johannesburg", "Pretoria", "Sandton", "Soweto", "Centurion"],
            "Western Cape": ["Cape Town", "Stellenbosch", "Paarl", "George", "Knysna"],
            "KwaZulu-Natal": ["Durban", "Umhlanga", "Pietermaritzburg", "Ballito"],
            "Eastern Cape": ["Gqeberha", "East London", "Makhanda"],
            "Free State": ["Bloemfontein", "Welkom", "Sasolburg"],
            "Limpopo": ["Polokwane", "Phalaborwa", "Thohoyandou"],
            "Mpumalanga": ["Mbombela", "Secunda", "Middelburg"],
            "North West": ["Klerksdorp", "Potchefstroom", "Rustenburg"],
            "Northern Cape": ["Kimberley", "Upington", "Kuruman"]
        };

        let editModal;
        function openEditModal(id, name, description) {
            document.getElementById('editPortfolioId').value = id;
            document.getElementById('editPortfolioName').value = name;
            document.getElementById('editPortfolioDescription').value = description;
            if (!editModal) editModal = new bootstrap.Modal(document.getElementById('editPortfolioModal'));
            editModal.show();
        }

        function populateCities(provinceSelect) {
            const targetId = provinceSelect.getAttribute('data-target');
            const citySelect = document.getElementById(targetId);
            const province = provinceSelect.value;
            citySelect.innerHTML = '<option value="">Select City</option>';
            if (province && locationData[province]) {
                locationData[province].forEach(city => citySelect.add(new Option(city, city)));
            }
        }

        function previewFile(input, previewId, promptId) {
            const preview = document.getElementById(previewId);
            const prompt = document.getElementById(promptId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    if(prompt) prompt.style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // ── Lightbox ──
        let mediaItems = [];
        let currentIndex = 0;
        let isZoomed = false;

        function initializeLightbox() {
            const thumbnails = document.querySelectorAll('.portfolio-thumbnail');
            mediaItems = [];
            thumbnails.forEach(el => {
                const mediaUrl = el.getAttribute('data-mediaurl');
                const title = el.getAttribute('data-title') || '';
                const description = el.getAttribute('data-description') || '';
                const mediaType = el.getAttribute('data-mediatype') || 'image';
                if (mediaUrl) {
                    mediaItems.push({ url: mediaUrl, title: title, description: description, type: mediaType });
                }
            });
        }

        window.openLightbox = function(element) {
            const thumbnails = document.querySelectorAll('.portfolio-thumbnail');
            const index = Array.from(thumbnails).indexOf(element);
            if (index === -1) return;
            initializeLightbox();
            currentIndex = index;
            showMedia(currentIndex);
            document.getElementById('lightbox').classList.add('active');
            document.body.style.overflow = 'hidden';
            isZoomed = false;
        };

        function showMedia(index) {
            const item = mediaItems[index];
            if (!item) return;
            const imageEl = document.getElementById('lightboxImage');
            const videoEl = document.getElementById('lightboxVideo');
            const videoSource = document.getElementById('videoSource');
            const captionEl = document.getElementById('lightboxCaption');
            const counterEl = document.getElementById('lightboxCounter');
            imageEl.classList.remove('zoomed');
            isZoomed = false;
            counterEl.textContent = `${index + 1} / ${mediaItems.length}`;
            let captionText = item.title;
            if (item.description && item.description !== item.title) {
                captionText += item.description ? ` — ${item.description}` : '';
            }
            captionEl.textContent = captionText;
            if (item.type === 'video') {
                imageEl.style.display = 'none';
                videoEl.style.display = 'block';
                videoSource.src = item.url;
                videoEl.load();
                videoEl.play().catch(() => {});
            } else {
                videoEl.style.display = 'none';
                videoEl.pause();
                imageEl.style.display = 'block';
                imageEl.src = item.url;
                imageEl.alt = item.title || 'Portfolio image';
            }
        }

        window.navigateLightbox = function(direction) {
            currentIndex = (currentIndex + direction + mediaItems.length) % mediaItems.length;
            showMedia(currentIndex);
        };

        window.closeLightbox = function(event) {
            if (event && event.target !== event.currentTarget) return;
            document.getElementById('lightbox').classList.remove('active');
            document.body.style.overflow = '';
            const video = document.getElementById('lightboxVideo');
            video.pause();
            isZoomed = false;
        };

        document.getElementById('lightboxImage').addEventListener('click', function() {
            isZoomed = !isZoomed;
            this.classList.toggle('zoomed');
        });

        document.addEventListener('keydown', function(e) {
            const lightbox = document.getElementById('lightbox');
            if (!lightbox.classList.contains('active')) return;
            if (e.key === 'Escape') closeLightbox();
            else if (e.key === 'ArrowLeft') { navigateLightbox(-1); e.preventDefault(); }
            else if (e.key === 'ArrowRight') { navigateLightbox(1); e.preventDefault(); }
        });

        // ── DOM ready ──
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.province-select').forEach(sel => {
                Object.keys(locationData).forEach(p => sel.add(new Option(p, p)));
                sel.addEventListener('change', function() { populateCities(this); });
            });

            // Create Portfolio
            document.getElementById('createPortfolioForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                try {
                    const response = await fetch('@Url.Action("CreatePortfolio", "Portfolio")', {
                        method: 'POST',
                        body: formData
                    });
                    const result = await response.json();
                    if (result.success) location.reload();
                    else Swal.fire('Error', result.message || 'Check inputs', 'error');
                } catch (err) { Swal.fire('Error', 'Connection failed', 'error'); }
            });

            // Edit Portfolio
            document.getElementById('editPortfolioForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                const portfolioId = document.getElementById('editPortfolioId').value;
                const formData = new FormData(this);
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                try {
                    const response = await fetch(`/Portfolio/EditPortfolio/${portfolioId}`, {
                        method: 'POST',
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': token }
                    });
                    const result = await response.json();
                    if (result.success) {
                        Swal.fire({ title: 'Success!', icon: 'success', timer: 1000, showConfirmButton: false })
                            .then(() => location.reload());
                    } else {
                        Swal.fire('Error', result.message || 'Update failed', 'error');
                    }
                } catch (err) {
                    console.error("Fetch error:", err);
                    Swal.fire('Error', 'Update failed. Check Console (F12).', 'error');
                }
            });
        });

        // Delete Item
        $(document).on('click', '.delete-item-btn', function () {
            const btn = $(this);
            const id = btn.data('id');
            const token = $('input[name="__RequestVerificationToken"]').val();
            if (confirm("Delete this item for real?")) {
                $.ajax({
                    url: '/PortfolioItem/DeleteItem/' + id,
                    type: 'POST',
                    data: { "__RequestVerificationToken": token },
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({ title: 'Deleted!', icon: 'success', timer: 1000, showConfirmButton: false })
                                .then(() => location.reload());
                        } else {
                            Swal.fire('Error', response.message || 'Server refused to delete', 'error');
                        }
                    },
                    error: function(err) {
                        console.error("Delete Error:", err);
                        Swal.fire('Error', 'Could not reach the server.', 'error');
                    }
                });
            }
        });
    </script>
}