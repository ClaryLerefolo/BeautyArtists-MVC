@model IEnumerable<BeautyArtists.Models.Portfolio>
@{
    ViewData["Title"] = "Manage Your Portfolios";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

@section Styles {
    <style>
        body {
            background: #000;
            color: #f0f0f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .dashboard-header {
            background: linear-gradient(90deg, #e50914, #f0c808);
            padding: 20px;
            border-radius: 0 0 12px 12px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            margin-bottom: 25px;
        }

            .dashboard-header h2 {
                color: #000;
                font-weight: 800;
                font-size: 2.2rem;
                margin: 0;
            }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            padding: 0 20px;
        }

        .portfolio-card {
            background: #121212;
            border: 1px solid rgba(240, 200, 8, 0.15);
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.8);
            transition: transform 0.3s ease;
        }

            .portfolio-card:hover {
                transform: translateY(-8px);
                border-color: #f0c808;
            }

        .portfolio-header {
            font-size: 1.5rem;
            color: #f0c808;
            font-weight: 700;
        }

        .portfolio-desc {
            min-height: 48px;
            line-height: 1.4;
            color: rgba(255,255,255,0.6);
        }

        .action-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1.5fr auto;
            gap: 8px;
            margin-top: 15px;
        }

        .btn-action {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 10px 0;
            font-size: 0.7rem;
            font-weight: 700;
            color: #f0c808;
            background: transparent;
            border: 1px solid #f0c808;
            border-radius: 8px;
            transition: 0.2s;
            text-transform: uppercase;
            cursor: pointer;
            text-decoration: none;
        }

            .btn-action:hover {
                background: #f0c808;
                color: #000;
            }

            .btn-action i {
                font-size: 1.1rem;
                margin-bottom: 4px;
            }

        .btn-delete-square {
            background: #e50914;
            border: none;
            color: #fff;
            padding: 10px 14px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #121212;
            border: 1px solid #ffcc00;
            border-radius: 15px;
            box-shadow: 0px 0px 15px rgba(255, 153, 0, 0.3);
        }

        .modal-header {
            border-bottom: 1px solid #444;
            color: #ffcc00;
        }

        .form-label {
            color: #f0c808;
            font-weight: 600;
        }

        .form-control, .form-select {
            background-color: #1e1e1e !important;
            border: 1px solid #444 !important;
            color: #fff !important;
            padding: 12px;
        }

            .form-control:focus {
                border-color: #ff9900 !important;
                box-shadow: 0 0 5px rgba(255, 153, 0, 0.5);
            }

        .drop-area {
            border: 2px dashed #f0c808;
            padding: 25px;
            text-align: center;
            border-radius: 12px;
            background: rgba(255,255,255,0.05);
            cursor: pointer;
        }

        .preview-img {
            max-width: 100%;
            max-height: 200px;
            margin-top: 15px;
            border-radius: 8px;
            display: none;
            border: 1px solid #f0c808;
        }

        .btn-gold-action {
            background: linear-gradient(to right, #ffcc00, #ff9900);
            color: #000;
            font-weight: bold;
            text-transform: uppercase;
            border: none;
            width: 100%;
            padding: 10px;
            border-radius: 5px;
        }

            .btn-gold-action:hover {
                background: linear-gradient(to right, #ff9900, #ffcc00);
            }
    </style>
}

<div class="dashboard-header">
    <h2>Manage Your Portfolios</h2>
</div>

<div class="d-flex justify-content-end mb-4 px-4">
    <button class="btn rounded-pill px-4 py-2" data-bs-toggle="modal" data-bs-target="#createPortfolioModal"
            style="background: linear-gradient(45deg, #f0c808, #e50914); color: #000; font-weight: 700; border: none;">
        <i class="fas fa-plus-circle me-2"></i>New Portfolio
    </button>
</div>

<div class="portfolio-grid" id="portfolioGrid">
    @foreach (var portfolio in Model)
    {
        <div class="portfolio-card" id="portfolioCard-@portfolio.Id">
            @if (portfolio.Items != null && portfolio.Items.Any())
            {
                var latestItem = portfolio.Items.OrderByDescending(i => i.UploadedAt).First();
                var isVideo = !string.IsNullOrEmpty(latestItem.MediaType) && latestItem.MediaType.Equals("Video", StringComparison.OrdinalIgnoreCase);
                var imgSrc = isVideo
                ? (!string.IsNullOrEmpty(latestItem.ThumbnailUrl) ? latestItem.ThumbnailUrl : "/images/video-placeholder.jpg")
                : latestItem.MediaUrl;
                <img src="@imgSrc" class="img-fluid rounded mb-3" style="height: 180px; width: 100%; object-fit: cover; border: 1px solid rgba(240,200,8,0.2);" />
            }
            else
            {
                <div class="text-center py-5 mb-3 bg-dark rounded border border-secondary border-dashed" style="height: 180px;">
                    <i class="fas fa-camera-retro fa-2x text-muted"></i>
                    <p class="small text-muted mt-2">Empty Gallery</p>
                </div>
            }

            <div class="portfolio-header mb-1">@portfolio.Name</div>
            <p class="portfolio-desc small mb-2">@portfolio.Description</p>
            <div class="small text-muted mb-3">
                <span>Crea<span>@(portfolio.Items?.Count(i => !string.IsNullOrEmpty(i.MediaUrl)) ?? 0) Items</span>ted: @portfolio.CreatedAt.ToString("yyyy/MM/dd")</span> | <span>@portfolio.Items?.Count Items</span>
            </div>

            <div class="action-row">
                <button class="btn-action" data-bs-toggle="modal" data-bs-target="#viewItemsModal-@portfolio.Id">
                    <i class="fas fa-eye"></i> View
                </button>
                <button type="button" class="btn-action"
                        onclick="openEditModal('@portfolio.Id', '@portfolio.Name', '@portfolio.Description')">
                    <i class="fas fa-edit"></i> EDIT
                </button>
                <button class="btn-action" data-bs-toggle="modal" data-bs-target="#addItemModal-@portfolio.Id">
                    <i class="fas fa-plus-circle"></i> Add Item
                </button>
                <form asp-action="DeletePortfolio" asp-route-id="@portfolio.Id" method="post" onsubmit="return confirm('Delete Portfolio?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-delete-square h-100"><i class="fas fa-trash-alt"></i></button>
                </form>
            </div>
        </div>

        <div class="modal fade" id="addItemModal-@portfolio.Id" tabindex="-1">
            <div class="modal-dialog modal-xl modal-dialog-centered">
                <div class="modal-content">
                    <form asp-controller="Portfolio" asp-action="CreatePortfolioItem" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PortfolioId" value="@portfolio.Id" />
                        <div class="modal-header border-0">
                            <h5 class="modal-title">Upload Work to "@portfolio.Name"</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-4">
                                <div class="col-lg-5 border-end border-secondary border-opacity-25">
                                    <label class="form-label">Media File</label>
                                    <div class="drop-area mb-3" onclick="document.getElementById('file-@portfolio.Id').click()">
                                        <div id="prompt-@portfolio.Id">
                                            <i class="fas fa-cloud-upload-alt fa-2x text-warning"></i>
                                            <p class="mt-2 small">Click to upload image/video</p>
                                        </div>
                                        <input type="file" name="MediaFile" id="file-@portfolio.Id" class="d-none" onchange="previewFile(this, 'prev-@portfolio.Id', 'prompt-@portfolio.Id')" required />
                                        <img id="prev-@portfolio.Id" class="preview-img" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Service Category</label>
                                        <select name="CategoryId" class="form-select" required>
                                            <option value="">-- Select Category --</option>
                                            @if (ViewBag.Categories != null)
                                            {
                                                foreach (var cat in (IEnumerable<SelectListItem>)ViewBag.Categories)
                                                {
                                                    <option value="@cat.Value">@cat.Text</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Media Type</label>
                                        <select name="MediaType" class="form-select" required>
                                            <option value="Image">Image</option>
                                            <option value="Video">Video</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-lg-7">
                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <label class="form-label">Title</label>
                                            <input name="Title" class="form-control" required />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Order</label>
                                            <input type="number" name="DisplayOrder" class="form-control" value="0" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Province</label>
                                            <select name="Province" class="form-select province-select" data-target="cSel-@portfolio.Id" required>
                                                <option value="">Select Province</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">City</label>
                                            <select name="City" id="cSel-@portfolio.Id" class="form-select city-select" required>
                                                <option value="">Select City</option>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Description</label>
                                            <textarea name="Description" class="form-control" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="submit" class="btn-gold-action">SAVE ITEM</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade" id="viewItemsModal-@portfolio.Id" tabindex="-1">
            <div class="modal-dialog modal-xl modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0">
                        <h5 class="modal-title">Gallery: @portfolio.Name</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body overflow-auto" style="max-height: 70vh;">
                        <div class="row g-3">
                            @if (portfolio.Items != null)
                            {
                                @foreach (var item in portfolio.Items)
                                {
                                    var isVideo = !string.IsNullOrEmpty(item.MediaType) && item.MediaType.Equals("Video", StringComparison.OrdinalIgnoreCase);
                                    var imgSrc = isVideo
                                    ? (!string.IsNullOrEmpty(item.ThumbnailUrl) ? item.ThumbnailUrl : "/images/video-placeholder.jpg")
                                    : item.MediaUrl;
                                    <div class="col-md-3">
                                        <div class="card bg-black border-secondary h-100">
                                            <img src="@imgSrc" class="card-img-top" style="height: 150px; object-fit: cover;">
                                            <div class="card-body p-2 text-center">
                                                <p class="small text-truncate mb-2">@item.Title</p>
                                                <div class="d-flex gap-1">
                                                    <a href="@Url.Action("EditPortfolioItem", "PortfolioItem", new { id = item.Id })" class="btn btn-sm btn-outline-warning w-100">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </a>
                                                    <button class="btn btn-sm btn-outline-danger delete-item-btn" data-id="@item.Id">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="createPortfolioModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="createPortfolioForm">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0">
                    <h5 class="modal-title">New Collection</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Portfolio Name</label>
                        <input name="Name" type="text" class="form-control" required placeholder="e.g. Bridal Portfolio">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Short Description</label>
                        <textarea name="Description" class="form-control" rows="4"></textarea>
                    </div>
                    <button type="submit" class="btn-gold-action">CREATE PORTFOLIO</button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="editPortfolioModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="editPortfolioForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editPortfolioId" name="Id" />
                <div class="modal-header border-0">
                    <h5 class="modal-title">Edit Collection</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Portfolio Name</label>
                        <input id="editPortfolioName" name="Name" type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="editPortfolioDescription" name="Description" class="form-control" rows="4"></textarea>
                    </div>
                    <button type="submit" class="btn-gold-action">SAVE CHANGES</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 1. DATA AND GLOBALS
        const locationData = {
            "Gauteng": ["Johannesburg", "Pretoria", "Sandton", "Soweto", "Centurion"],
            "Western Cape": ["Cape Town", "Stellenbosch", "Paarl", "George", "Knysna"],
            "KwaZulu-Natal": ["Durban", "Umhlanga", "Pietermaritzburg", "Ballito"],
            "Eastern Cape": ["Gqeberha", "East London", "Makhanda"],
            "Free State": ["Bloemfontein", "Welkom", "Sasolburg"],
            "Limpopo": ["Polokwane", "Phalaborwa", "Thohoyandou"],
            "Mpumalanga": ["Mbombela", "Secunda", "Middelburg"],
            "North West": ["Klerksdorp", "Potchefstroom", "Rustenburg"],
            "Northern Cape": ["Kimberley", "Upington", "Kuruman"]
        };

        let editModal; // Only declare this ONCE at the top

        // 2. MODAL OPENER FUNCTION
        function openEditModal(id, name, description) {
            console.log("Opening Modal for ID:", id);

            // Set the values in the form fields
            document.getElementById('editPortfolioId').value = id;
            document.getElementById('editPortfolioName').value = name;
            document.getElementById('editPortfolioDescription').value = description;

            // Initialize or show the modal
            if (!editModal) {
                editModal = new bootstrap.Modal(document.getElementById('editPortfolioModal'));
            }
            editModal.show();
        }

        // 3. UI HELPERS
        function populateCities(provinceSelect) {
            const targetId = provinceSelect.getAttribute('data-target');
            const citySelect = document.getElementById(targetId);
            const province = provinceSelect.value;
            citySelect.innerHTML = '<option value="">Select City</option>';
            if (province && locationData[province]) {
                locationData[province].forEach(city => {
                    citySelect.add(new Option(city, city));
                });
            }
        }

        function previewFile(input, previewId, promptId) {
            const preview = document.getElementById(previewId);
            const prompt = document.getElementById(promptId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    if(prompt) prompt.style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // 4. MAIN INITIALIZATION
        document.addEventListener('DOMContentLoaded', () => {

            // Setup Provinces for "Add Item" modals
            document.querySelectorAll('.province-select').forEach(sel => {
                Object.keys(locationData).forEach(p => sel.add(new Option(p, p)));
                sel.addEventListener('change', function() { populateCities(this); });
            });

            // AJAX Create Portfolio Logic
            const createForm = document.getElementById('createPortfolioForm');
            if(createForm) {
                createForm.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    const formData = new FormData(this);
                    try {
                        const response = await fetch('@Url.Action("CreatePortfolio", "Portfolio")', {
                            method: 'POST',
                            body: formData
                        });
                        const result = await response.json();
                        if (result.success) { location.reload(); }
                        else { Swal.fire('Error', result.message || 'Check inputs', 'error'); }
                    } catch (err) { Swal.fire('Error', 'Connection failed', 'error'); }
                });
            }

            // AJAX Edit Portfolio Logic
            const editForm = document.getElementById('editPortfolioForm');
            if (editForm) {
                editForm.addEventListener('submit', async function(e) {
                    e.preventDefault();

                    const portfolioId = document.getElementById('editPortfolioId').value;
                    const formData = new FormData(this);
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    try {
                        const response = await fetch(`/Portfolio/EditPortfolio/${portfolioId}`, {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'RequestVerificationToken': token
                            }
                        });

                        const result = await response.json();
                        if (result.success) {
                            Swal.fire({
                                title: 'Success!',
                                icon: 'success',
                                timer: 1000,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('Error', result.message || 'Update failed', 'error');
                        }
                    } catch (err) {
                        console.error("Fetch error:", err);
                        Swal.fire('Error', 'Update failed. Check Console (F12).', 'error');
                    }
                });
            }
        });

                 // 5. DELETE PORTFOLIO ITEM AJAX
        $(document).on('click', '.delete-item-btn', function () {
            const btn = $(this);
            const id = btn.data('id');
            const card = btn.closest('.col-md-3');
            const token = $('input[name="__RequestVerificationToken"]').val();

            if (confirm("Delete this item for real?")) {
                $.ajax({
                    // TARGETS PortfolioItemController -> DeleteItem method
                    url: '/PortfolioItem/DeleteItem/' + id,
                    type: 'POST',
                    data: {
                        "__RequestVerificationToken": token
                    },
                    success: function (response) {
                        if (response.success) {
                            // SweetAlert for better UX since you already have it loaded
                            Swal.fire({
                                title: 'Deleted!',
                                icon: 'success',
                                timer: 1000,
                                showConfirmButton: false
                            }).then(() => {
                                // REFRESH is required to update the "3 Items" count on the dashboard
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', response.message || 'Server refused to delete', 'error');
                        }
                    },
                    error: function(err) {
                        console.error("Delete Error:", err);
                        Swal.fire('Error', 'Could not reach the server. Check if URL /PortfolioItem/DeleteItem is correct.', 'error');
                    }
                });
            }
        });
    </script>
}
