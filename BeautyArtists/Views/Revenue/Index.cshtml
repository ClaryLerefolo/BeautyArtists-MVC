@model BeautyArtists.Models.ViewModels.RevenueViewModel
@{
    ViewData["Title"] = "Revenue";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var maxService = Model.TopServices.Any() ? Model.TopServices.Max(s => s.BookingCount) : 1;
    var maxArtist = Model.TopArtists.Any() ? Model.TopArtists.Max(a => a.BookingCount) : 1;
    var maxProvince = Model.BookingsByProvince.Any() ? Model.BookingsByProvince.Max(p => p.BookingCount) : 1;
    var maxMonth = Model.MonthlyTrend.Any() ? Model.MonthlyTrend.Max(m => m.TotalRevenue) : 1;

    // Build query string to pass filters to download link
    // 1. Build the query string
    var qs = new System.Text.StringBuilder("?");
    if (!string.IsNullOrEmpty(Model.FilterProvince)) qs.Append($"filterProvince={Uri.EscapeDataString(Model.FilterProvince)}&");
    if (!string.IsNullOrEmpty(Model.FilterArtistId)) qs.Append($"filterArtistId={Uri.EscapeDataString(Model.FilterArtistId)}&");
    if (!string.IsNullOrEmpty(Model.FilterStatus)) qs.Append($"filterStatus={Uri.EscapeDataString(Model.FilterStatus)}&");
    if (!string.IsNullOrEmpty(Model.FilterServiceId)) qs.Append($"filterServiceId={Uri.EscapeDataString(Model.FilterServiceId)}&");
    if (Model.FilterFrom.HasValue) qs.Append($"filterFrom={Model.FilterFrom.Value:yyyy-MM-dd}&");
    if (Model.FilterTo.HasValue) qs.Append($"filterTo={Model.FilterTo.Value:yyyy-MM-dd}&");

    // 2. Define downloadUrl so your existing CSV button doesn't throw an error
    var downloadUrl = "/Revenue/DownloadCsv" + qs.ToString().TrimEnd('&');

    // 3. Define the helper for the NEW buttons (Excel, PDF, Word)
    string getDownloadUrl(string format) => $"/Revenue/DownloadReport{qs}format={format}";
}
}

@section Styles {
    <style>
        /* DROPDOWN CONTAINER */
        .rv-dropdown {
            position: relative;
            display: inline-block;
        }

        .rv-dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            background-color: #111;
            min-width: 160px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5);
            z-index: 100;
            border: 1px solid rgba(255,215,0,0.2);
            border-radius: 8px;
            overflow: hidden;
        }

        .rv-dropdown-item {
            color: rgba(255,255,255,0.7);
            padding: 10px 16px;
            text-decoration: none;
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            transition: all 0.2s;
        }

            .rv-dropdown-item:hover {
                background-color: rgba(255,215,0,0.1);
                color: #FFD700;
            }

        .rv-dropdown:hover .rv-dropdown-content {
            display: block;
        }
        .rv-eyebrow {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: rgba(255,215,0,0.35);
            display: block;
            margin-bottom: 4px;
        }

        .rv-heading {
            font-size: 1.5rem;
            font-weight: 900;
            color: #FFD700;
            margin: 0 0 24px;
        }

        /* STAT CARDS */
        .rv-stats {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 14px;
            margin-bottom: 28px;
        }

        @@media (max-width: 1100px) {
            .rv-stats {
                grid-template-columns: repeat(3,1fr);
            }
        }

        @@media (max-width: 640px) {
            .rv-stats {
                grid-template-columns: repeat(2,1fr);
            }
        }

        .rv-stat {
            background: #0b0b0b;
            border: 1px solid rgba(255,215,0,0.1);
            border-radius: 14px;
            padding: 18px 16px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s, transform 0.2s;
        }

            .rv-stat:hover {
                border-color: rgba(255,215,0,0.25);
                transform: translateY(-2px);
            }

            .rv-stat::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg,#b30000,#FFD700);
                opacity: 0;
                transition: opacity 0.2s;
            }

            .rv-stat:hover::before {
                opacity: 1;
            }

        .rv-stat-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255,215,0,0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            color: #FFD700;
            margin-bottom: 12px;
        }

        .rv-stat-num {
            display: block;
            font-size: 1.6rem;
            font-weight: 900;
            color: #FFD700;
            line-height: 1;
            margin-bottom: 4px;
        }

        .rv-stat-label {
            display: block;
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.25);
        }

        .rv-stat.revenue .rv-stat-num {
            color: #00c853;
        }

        .rv-stat.revenue .rv-stat-icon {
            background: rgba(0,200,83,0.08);
            color: #00c853;
        }

        /* FILTER BAR */
        .rv-filter-bar {
            background: #0b0b0b;
            border: 1px solid rgba(255,215,0,0.1);
            border-radius: 14px;
            padding: 16px 20px;
            margin-bottom: 24px;
        }

        .rv-filter-title {
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(255,215,0,0.35);
            margin-bottom: 12px;
            display: block;
        }

        .rv-filter-grid {
            display: grid;
            grid-template-columns: repeat(6,1fr);
            gap: 10px;
            align-items: end;
        }

        @@media (max-width:1100px) {
            .rv-filter-grid {
                grid-template-columns: repeat(3,1fr);
            }
        }

        @@media (max-width:640px) {
            .rv-filter-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        .rv-filter-field {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .rv-filter-label {
            font-size: 0.62rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.3);
        }

        .rv-filter-input, .rv-filter-select {
            background: rgba(255,255,255,0.04) !important;
            border: 1px solid rgba(255,215,0,0.12) !important;
            border-radius: 8px !important;
            color: #fff !important;
            padding: 8px 12px !important;
            font-size: 0.8rem;
            width: 100%;
        }

            .rv-filter-input:focus, .rv-filter-select:focus {
                outline: none !important;
                border-color: rgba(255,215,0,0.35) !important;
                box-shadow: none !important;
            }

            .rv-filter-select option {
                background: #111;
            }

        .rv-filter-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px 16px;
            border-radius: 8px;
            background: linear-gradient(135deg,#b30000,#FFD700);
            color: #000;
            font-weight: 800;
            font-size: 0.75rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            width: 100%;
        }

            .rv-filter-btn:hover {
                background: linear-gradient(135deg,#FFD700,#b30000);
            }

        .rv-clear-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px 16px;
            border-radius: 8px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.4);
            font-weight: 700;
            font-size: 0.75rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s;
            width: 100%;
        }

            .rv-clear-btn:hover {
                background: rgba(255,255,255,0.08);
                color: rgba(255,255,255,0.7);
            }

        /* DOWNLOAD BUTTON */
        .rv-download-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 22px;
            border-radius: 999px;
            background: rgba(0,200,83,0.12);
            border: 1px solid rgba(0,200,83,0.3);
            color: #00c853;
            font-weight: 800;
            font-size: 0.78rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s;
        }

            .rv-download-btn:hover {
                background: rgba(0,200,83,0.22);
                border-color: rgba(0,200,83,0.5);
                color: #00c853;
                box-shadow: 0 0 16px rgba(0,200,83,0.2);
            }

        /* CHARTS */
        .rv-charts {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        @@media (max-width:900px) {
            .rv-charts {
                grid-template-columns: 1fr;
            }
        }

        .rv-panel {
            background: #0b0b0b;
            border: 1px solid rgba(255,215,0,0.1);
            border-radius: 16px;
            overflow: hidden;
        }

        .rv-panel-header {
            padding: 14px 20px;
            border-bottom: 1px solid rgba(255,215,0,0.07);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .rv-panel-title {
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
        }

            .rv-panel-title i {
                color: #FFD700;
                margin-right: 7px;
            }

        .rv-panel-body {
            padding: 16px 20px;
        }

        /* BAR CHART */
        .rv-bar-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .rv-bar-label {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.65);
            min-width: 140px;
            max-width: 140px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .rv-bar-track {
            flex: 1;
            height: 8px;
            border-radius: 4px;
            background: rgba(255,255,255,0.06);
            overflow: hidden;
        }

        .rv-bar-fill {
            height: 100%;
            border-radius: 4px;
            background: linear-gradient(90deg,#b30000,#FFD700);
            transition: width 0.6s ease;
        }

        .rv-bar-count {
            font-size: 0.75rem;
            font-weight: 700;
            color: #FFD700;
            min-width: 50px;
            text-align: right;
            flex-shrink: 0;
        }

        /* MONTHLY CHART */
        .rv-month-chart {
            display: flex;
            align-items: flex-end;
            gap: 6px;
            height: 120px;
            padding-bottom: 4px;
        }

        .rv-month-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            height: 100%;
            justify-content: flex-end;
        }

        .rv-month-bar-wrap {
            width: 100%;
            flex: 1;
            display: flex;
            align-items: flex-end;
            justify-content: center;
        }

        .rv-month-bar {
            width: 70%;
            border-radius: 4px 4px 0 0;
            background: linear-gradient(0deg,#b30000,#FFD700);
            min-height: 4px;
        }

        .rv-month-label {
            font-size: 0.58rem;
            color: rgba(255,255,255,0.25);
            text-align: center;
            white-space: nowrap;
        }

        /* TABLE */
        .rv-table-wrap {
            overflow-x: auto;
        }

        .rv-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 700px;
        }

            .rv-table thead tr {
                background: rgba(255,215,0,0.04);
            }

            .rv-table th {
                padding: 10px 16px;
                font-size: 0.65rem;
                font-weight: 700;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: rgba(255,215,0,0.4);
                border-bottom: 1px solid rgba(255,215,0,0.07);
            }

            .rv-table td {
                padding: 11px 16px;
                font-size: 0.8rem;
                color: rgba(255,255,255,0.6);
                border-bottom: 1px solid rgba(255,255,255,0.04);
                vertical-align: middle;
            }

            .rv-table tr:last-child td {
                border-bottom: none;
            }

            .rv-table tbody tr:hover td {
                background: rgba(255,215,0,0.02);
            }

        .rv-id {
            color: rgba(255,255,255,0.25);
            font-size: 0.72rem;
            font-family: monospace;
        }

        .rv-client {
            color: #fff;
            font-weight: 600;
        }

        .rv-artist {
            color: rgba(255,215,0,0.7);
        }

        .rv-amount {
            color: #00c853;
            font-weight: 800;
        }

        .rv-province-badge {
            display: inline-block;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 20px;
            background: rgba(255,215,0,0.08);
            border: 1px solid rgba(255,215,0,0.15);
            color: rgba(255,215,0,0.6);
        }

        .rv-status-badge {
            display: inline-block;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 20px;
            text-transform: uppercase;
        }

        .rv-status-Completed {
            background: rgba(0,200,83,0.12);
            color: #00c853;
            border: 1px solid rgba(0,200,83,0.2);
        }

        .rv-status-Confirmed {
            background: rgba(41,121,255,0.12);
            color: #2979ff;
            border: 1px solid rgba(41,121,255,0.2);
        }

        .rv-status-Pending {
            background: rgba(240,200,8,0.12);
            color: #f0c808;
            border: 1px solid rgba(240,200,8,0.2);
        }

        .rv-status-Cancelled {
            background: rgba(255,85,85,0.1);
            color: #ff5555;
            border: 1px solid rgba(255,85,85,0.2);
        }

        .rv-status-Rejected {
            background: rgba(255,140,0,0.1);
            color: #ff8c00;
            border: 1px solid rgba(255,140,0,0.2);
        }

        .rv-empty {
            padding: 40px 20px;
            text-align: center;
            color: rgba(255,255,255,0.25);
            font-size: 0.85rem;
        }

            .rv-empty i {
                font-size: 1.8rem;
                color: rgba(255,215,0,0.1);
                display: block;
                margin-bottom: 10px;
            }

        /* Active filter pills */
        .rv-active-filters {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }

        .rv-filter-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            background: rgba(255,215,0,0.1);
            border: 1px solid rgba(255,215,0,0.2);
            color: rgba(255,215,0,0.8);
        }
    </style>
}

<span class="rv-eyebrow">Administration</span>
<h1 class="rv-heading">Revenue &amp; Reports</h1>

@* ── STAT CARDS ── *@
<div class="rv-stats">
    <div class="rv-stat revenue">
        <div class="rv-stat-icon"><i class="bi bi-currency-exchange"></i></div>
        <span class="rv-stat-num">R @Model.TotalRevenue.ToString("N0")</span>
        <span class="rv-stat-label">Total Revenue</span>
    </div>
    <div class="rv-stat revenue">
        <div class="rv-stat-icon"><i class="bi bi-calendar-month"></i></div>
        <span class="rv-stat-num">R @Model.MonthRevenue.ToString("N0")</span>
        <span class="rv-stat-label">This Month</span>
    </div>
    <div class="rv-stat revenue">
        <div class="rv-stat-icon"><i class="bi bi-calendar-week"></i></div>
        <span class="rv-stat-num">R @Model.WeekRevenue.ToString("N0")</span>
        <span class="rv-stat-label">This Week</span>
    </div>
    <div class="rv-stat">
        <div class="rv-stat-icon"><i class="bi bi-calendar-check-fill"></i></div>
        <span class="rv-stat-num">@Model.TotalBookings</span>
        <span class="rv-stat-label">Total Bookings</span>
    </div>
    <div class="rv-stat">
        <div class="rv-stat-icon"><i class="bi bi-check-circle-fill"></i></div>
        <span class="rv-stat-num">@Model.CompletedBookings</span>
        <span class="rv-stat-label">Completed</span>
    </div>
</div>

@* ── ACTIVE FILTER PILLS ── *@
@{
    bool hasFilters = !string.IsNullOrEmpty(Model.FilterProvince)
                   || !string.IsNullOrEmpty(Model.FilterArtistId)
                   || !string.IsNullOrEmpty(Model.FilterStatus)
                   || !string.IsNullOrEmpty(Model.FilterServiceId)
                   || Model.FilterFrom.HasValue
                   || Model.FilterTo.HasValue;
}
@if (hasFilters)
{
    <div class="rv-active-filters">
        <span style="font-size:0.65rem;color:rgba(255,255,255,0.3);align-self:center;">Active filters:</span>
        @if (!string.IsNullOrEmpty(Model.FilterProvince))
        {
            <span class="rv-filter-pill"><i class="bi bi-geo-alt-fill"></i> @Model.FilterProvince</span>
        }
        @if (!string.IsNullOrEmpty(Model.FilterStatus))
        {
            <span class="rv-filter-pill"><i class="bi bi-circle-fill"></i> @Model.FilterStatus</span>
        }
        @if (Model.FilterFrom.HasValue)
        {
            <span class="rv-filter-pill"><i class="bi bi-calendar"></i> From @Model.FilterFrom.Value.ToString("dd MMM yyyy")</span>
        }
        @if (Model.FilterTo.HasValue)
        {
            <span class="rv-filter-pill"><i class="bi bi-calendar"></i> To @Model.FilterTo.Value.ToString("dd MMM yyyy")</span>
        }
        @if (!string.IsNullOrEmpty(Model.FilterArtistId))
        {
            <span class="rv-filter-pill"><i class="bi bi-person-fill"></i> Artist filtered</span>
        }
        @if (!string.IsNullOrEmpty(Model.FilterServiceId))
        {
            <span class="rv-filter-pill"><i class="bi bi-scissors"></i> Service filtered</span>
        }
    </div>
}

@* ── FILTER BAR ── *@
<div class="rv-filter-bar">
    <span class="rv-filter-title"><i class="bi bi-funnel-fill me-2"></i>Filter Report</span>
    <form method="get" asp-controller="Revenue" asp-action="Index">
        <div class="rv-filter-grid">
            <div class="rv-filter-field">
                <span class="rv-filter-label">Province</span>
                <select name="filterProvince" class="rv-filter-select">
                    <option value="">All Provinces</option>
                    @foreach (var p in ViewBag.Provinces as List<string> ?? new())
                    {
                        <option value="@p" selected="@(Model.FilterProvince == p ? "selected" : null)">@p</option>
                    }
                </select>
            </div>
            <div class="rv-filter-field">
                <span class="rv-filter-label">Artist</span>
                <select name="filterArtistId" class="rv-filter-select">
                    <option value="">All Artists</option>
                    @foreach (var a in ViewBag.Artists as IEnumerable<dynamic> ?? new List<dynamic>())
                    {
                        <option value="@a.Id" selected="@(Model.FilterArtistId == (string)a.Id.ToString() ? "selected" : null)">@a.Name</option>
                    }
                </select>
            </div>
            <div class="rv-filter-field">
                <span class="rv-filter-label">Service</span>
                <select name="filterServiceId" class="rv-filter-select">
                    <option value="">All Services</option>
                    @foreach (var s in ViewBag.Services as IEnumerable<dynamic> ?? new List<dynamic>())
                    {
                        <option value="@s.Id" selected="@(Model.FilterServiceId == (string)s.Id.ToString() ? "selected" : null)">@s.Name</option>
                    }
                </select>
            </div>
            <div class="rv-filter-field">
                <span class="rv-filter-label">Status</span>
                <select name="filterStatus" class="rv-filter-select">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(Model.FilterStatus == "Pending" ? "selected" : null)">Pending</option>
                    <option value="Confirmed" selected="@(Model.FilterStatus == "Confirmed" ? "selected" : null)">Confirmed</option>
                    <option value="Completed" selected="@(Model.FilterStatus == "Completed" ? "selected" : null)">Completed</option>
                    <option value="Cancelled" selected="@(Model.FilterStatus == "Cancelled" ? "selected" : null)">Cancelled</option>
                    <option value="Rejected" selected="@(Model.FilterStatus == "Rejected" ? "selected" : null)">Rejected</option>
                </select>
            </div>
            <div class="rv-filter-field">
                <span class="rv-filter-label">From Date</span>
                <input type="date" name="filterFrom" class="rv-filter-input"
                       value="@Model.FilterFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="rv-filter-field">
                <span class="rv-filter-label">To Date</span>
                <input type="date" name="filterTo" class="rv-filter-input"
                       value="@Model.FilterTo?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div style="display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;">
            <button type="submit" class="rv-filter-btn" style="max-width:160px;">
                <i class="bi bi-search"></i> Apply Filters
            </button>
            <a asp-controller="Revenue" asp-action="Index" class="rv-clear-btn" style="max-width:140px;">
                <i class="bi bi-x-lg"></i> Clear
            </a>
        </div>
    </form>
</div>

@* ── CHARTS ── *@
<div class="rv-charts">
    <div class="rv-panel">
        <div class="rv-panel-header">
            <span class="rv-panel-title"><i class="bi bi-scissors"></i> Top Services</span>
        </div>
        <div class="rv-panel-body">
            @if (!Model.TopServices.Any())
            {
                <div class="rv-empty"><i class="bi bi-bar-chart"></i>No data</div>
            }
            else
            {
                @foreach (var s in Model.TopServices)
                {
                    var pct = maxService > 0 ? (int)((s.BookingCount / (double)maxService) * 100) : 0;
                    <div class="rv-bar-row">
                        <span class="rv-bar-label" title="@s.ServiceName">@s.ServiceName</span>
                        <div class="rv-bar-track"><div class="rv-bar-fill" style="width:@pct%"></div></div>
                        <span class="rv-bar-count">@s.BookingCount</span>
                    </div>
                }
            }
        </div>
    </div>
    <div class="rv-panel">
        <div class="rv-panel-header">
            <span class="rv-panel-title"><i class="bi bi-person-fill"></i> Top Artists</span>
        </div>
        <div class="rv-panel-body">
            @if (!Model.TopArtists.Any())
            {
                <div class="rv-empty"><i class="bi bi-bar-chart"></i>No data</div>
            }
            else
            {
                @foreach (var a in Model.TopArtists)
                {
                    var pct = maxArtist > 0 ? (int)((a.BookingCount / (double)maxArtist) * 100) : 0;
                    <div class="rv-bar-row">
                        <span class="rv-bar-label" title="@a.ArtistName">@a.ArtistName</span>
                        <div class="rv-bar-track"><div class="rv-bar-fill" style="width:@pct%"></div></div>
                        <span class="rv-bar-count">@a.BookingCount</span>
                    </div>
                }
            }
        </div>
    </div>
    <div class="rv-panel">
        <div class="rv-panel-header">
            <span class="rv-panel-title"><i class="bi bi-geo-alt-fill"></i> Bookings by Province</span>
        </div>
        <div class="rv-panel-body">
            @if (!Model.BookingsByProvince.Any())
            {
                <div class="rv-empty"><i class="bi bi-geo"></i>No data</div>
            }
            else
            {
                @foreach (var p in Model.BookingsByProvince)
                {
                    var pct = maxProvince > 0 ? (int)((p.BookingCount / (double)maxProvince) * 100) : 0;
                    <div class="rv-bar-row">
                        <span class="rv-bar-label">@p.Province</span>
                        <div class="rv-bar-track"><div class="rv-bar-fill" style="width:@pct%"></div></div>
                        <span class="rv-bar-count">@p.BookingCount</span>
                    </div>
                }
            }
        </div>
    </div>
    <div class="rv-panel">
        <div class="rv-panel-header">
            <span class="rv-panel-title"><i class="bi bi-graph-up-arrow"></i> Monthly Trend</span>
        </div>
        <div class="rv-panel-body">
            @if (!Model.MonthlyTrend.Any())
            {
                <div class="rv-empty"><i class="bi bi-graph-up"></i>No data</div>
            }
            else
            {
                <div class="rv-month-chart">
                    @foreach (var m in Model.MonthlyTrend)
                    {
                        var h = maxMonth > 0 ? (int)((double)m.TotalRevenue / (double)maxMonth * 100) : 0;
                        <div class="rv-month-col" title="@m.Month — R @m.TotalRevenue.ToString("N0")">
                            <div class="rv-month-bar-wrap">
                                <div class="rv-month-bar" style="height:@h%"></div>
                            </div>
                            <span class="rv-month-label">@m.Month.Split(' ')[0]</span>
                        </div>
                    }
                </div>
                <div style="display:flex;justify-content:space-between;margin-top:8px;">
                    @foreach (var m in Model.MonthlyTrend)
                    {
                        <span style="font-size:0.6rem;color:rgba(255,215,0,0.3);flex:1;text-align:center;">
                            R@((m.TotalRevenue / 1000).ToString("0"))k
                        </span>
                    }
                </div>
            }
        </div>
    </div>
</div>

@* ── REPORT TABLE WITH DOWNLOAD ── *@
<div class="rv-panel">
    <div class="rv-panel-header">
        <span class="rv-panel-title">
            <i class="bi bi-table"></i> Booking Report
        </span>
        <div style="display:flex;align-items:center;gap:12px;">
            <span style="font-size:0.7rem;color:rgba(255,255,255,0.25);">
                @Model.FilteredBookings.Count record@(Model.FilteredBookings.Count != 1 ? "s" : "")
            </span>

            <div class="rv-dropdown">
                <a href="javascript:void(0)" class="rv-download-btn">
                    <i class="bi bi-file-earmark-arrow-down-fill"></i>
                    Export Report <i class="bi bi-chevron-down ms-1" style="font-size: 0.6rem;"></i>
                </a>
                <div class="rv-dropdown-content">
                    <a href="@getDownloadUrl("pdf")" class="rv-dropdown-item"><i class="bi bi-file-pdf me-2 text-danger"></i> PDF Document</a>
                    <a href="@getDownloadUrl("excel")" class="rv-dropdown-item"><i class="bi bi-file-excel me-2 text-success"></i> Excel Sheet</a>
                    <a href="@getDownloadUrl("word")" class="rv-dropdown-item"><i class="bi bi-file-word me-2 text-primary"></i> Word Doc</a>
                    <hr style="margin: 0; border-color: rgba(255,215,0,0.1);" />
                    <a href="@downloadUrl" class="rv-dropdown-item"><i class="bi bi-filetype-csv me-2" style="color: #00c853;"></i> CSV (Legacy)</a>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.FilteredBookings.Any())
    {
        <div class="rv-empty">
            <i class="bi bi-inbox"></i> No bookings match your filters.
        </div>
    }
    else
    {
        <div class="rv-table-wrap">
            <table class="rv-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Date</th>
                        <th>Client</th>
                        <th>Artist</th>
                        <th>Service</th>
                        <th>Province</th>
                        <th>Status</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.FilteredBookings)
                    {
                        <tr>
                            <td class="rv-id">@b.BookingId</td>
                            <td style="white-space:nowrap;color:rgba(255,255,255,0.4);font-size:0.78rem;">
                                @b.AppointmentDate.ToString("dd MMM yyyy")<br />
                                <span style="font-size:0.7rem;color:rgba(255,255,255,0.25)">
                                    @b.AppointmentDate.ToString("HH:mm")
                                </span>
                            </td>
                            <td class="rv-client">@b.ClientName</td>
                            <td class="rv-artist">@b.ArtistName</td>
                            <td>@b.ServiceName</td>
                            <td><span class="rv-province-badge">@b.Province</span></td>
                            <td><span class="rv-status-badge rv-status-@b.Status">@b.Status</span></td>
                            <td class="rv-amount">R @b.Amount.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="border-top:1px solid rgba(255,215,0,0.1);">
                        <td colspan="7" style="padding:12px 16px;font-size:0.75rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,0.3);">Total</td>
                        <td style="padding:12px 16px;font-size:0.9rem;font-weight:900;color:#00c853;">
                            R @Model.FilteredBookings.Sum(b => b.Amount).ToString("N0")
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>
