@model BeautyArtists.Models.ViewModels.ChatViewModel
@{
    Layout = ViewData["Layout"] as string ?? "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"Chat with {Model.ReceiverName}";
}

<style>
    .chat-container {
        max-width: 700px;
        margin: 0 auto;
        height: 80vh;
        display: flex;
        flex-direction: column;
        background: #0d0d0d;
        border: 1px solid #1a1a1a;
        border-radius: 16px;
        overflow: hidden;
    }

    .chat-header {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px 20px;
        border-bottom: 1px solid #1a1a1a;
        background: #121212;
    }

        .chat-header img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #f0c808;
        }

        .chat-header h4 {
            color: #f0c808;
            margin: 0;
            font-weight: 700;
        }

    .chat-back {
        color: #888;
        text-decoration: none;
        margin-right: auto;
        font-size: 0.9rem;
    }

        .chat-back:hover {
            color: #f0c808;
        }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .message {
        max-width: 70%;
        padding: 10px 14px;
        border-radius: 12px;
        word-wrap: break-word;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .message-sent {
        align-self: flex-end;
        background: linear-gradient(135deg, #f0c808, #e50914);
        color: #000;
        border-bottom-right-radius: 4px;
    }

    .message-received {
        align-self: flex-start;
        background: #1a1a1a;
        color: #fff;
        border-bottom-left-radius: 4px;
    }

    .message-time {
        font-size: 0.6rem;
        opacity: 0.5;
        margin-top: 4px;
        display: block;
    }

    .message-read {
        font-size: 0.6rem;
        opacity: 0.5;
        margin-left: 4px;
    }

    .chat-input-area {
        display: flex;
        gap: 10px;
        padding: 15px 20px;
        border-top: 1px solid #1a1a1a;
        background: #121212;
    }

    .chat-input {
        flex: 1;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 20px;
        color: #fff;
        padding: 10px 16px;
        outline: none;
        font-size: 0.9rem;
    }

        .chat-input:focus {
            border-color: #f0c808;
        }

    .chat-send-btn {
        background: linear-gradient(135deg, #f0c808, #e50914);
        border: none;
        border-radius: 50%;
        width: 44px;
        height: 44px;
        color: #000;
        font-size: 1.2rem;
        cursor: pointer;
        transition: 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .chat-send-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(240, 200, 8, 0.3);
        }

    .typing-indicator {
        color: #666;
        font-size: 0.8rem;
        padding: 5px 20px;
        font-style: italic;
        display: none;
    }
</style>

<div class="chat-container">
    <div class="chat-header">
        <a href="@Url.Action("Index")" class="chat-back">←</a>
        <img src="@Model.ReceiverProfilePicture" onerror="this.src='/images/default-profile.png'" />
        <h4>@Model.ReceiverName</h4>
    </div>

    <div class="chat-messages" id="chatMessages">
        @foreach (var msg in Model.Messages)
        {
            var isSent = msg.SenderId == Model.CurrentUserId;
            <div class="message @(isSent ? "message-sent" : "message-received")">
                @msg.Message
                <span class="message-time">
                    @msg.SentAt.ToString("hh:mm tt")
                    @if (isSent && msg.IsRead)
                    {
                        <span class="message-read">✓✓</span>
                    }
                    else if (isSent)
                    {
                        <span class="message-read">✓</span>
                    }
                </span>
            </div>
        }
    </div>

    <div class="typing-indicator" id="typingIndicator">Typing...</div>

    <div class="chat-input-area">
        <input type="text" id="messageInput" class="chat-input" placeholder="Type a message..." />
        <button class="chat-send-btn" id="sendButton">➤</button>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        const chatMessages = document.getElementById('chatMessages');
        const messageInput = document.getElementById('messageInput');
        const sendButton = document.getElementById('sendButton');
        const typingIndicator = document.getElementById('typingIndicator');

        const currentUserId = '@Model.CurrentUserId';
        const receiverId = '@Model.ReceiverId';
        const bookingId = '@Model.BookingId';

        let typingTimeout;

        connection.start()
            .then(() => {
                console.log("✅ Chat connected");
                connection.invoke("GetUnreadCount");
            })
            .catch(err => console.error("❌ Chat connection error:", err));

        connection.on("ReceiveMessage", (msg) => {
            if (msg.senderId === receiverId) {
                appendMessage(msg.senderId, msg.message, msg.sentAt);
                connection.invoke("MarkAsRead", msg.id);
            }
        });

        connection.on("MessageSent", (msg) => {
            if (msg.receiverId === receiverId) {
                appendMessage(currentUserId, msg.message, msg.sentAt);
            }
        });

        connection.on("MessageRead", (messageId) => {
            // optional: update status
        });

        connection.on("UserOnline", (userId, isOnline) => {
            // optional: show online status
        });

        connection.on("UserTyping", (userId) => {
            if (userId === receiverId) {
                typingIndicator.style.display = 'block';
            }
        });

        connection.on("UserStoppedTyping", (userId) => {
            if (userId === receiverId) {
                typingIndicator.style.display = 'none';
            }
        });

        messageInput.addEventListener('input', () => {
            clearTimeout(typingTimeout);
            connection.invoke("Typing", receiverId);
            typingTimeout = setTimeout(() => {
                connection.invoke("StopTyping", receiverId);
            }, 2000);
        });

        sendButton.addEventListener('click', sendMessage);
        messageInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        function sendMessage() {
            const message = messageInput.value.trim();
            if (!message) return;

            connection.invoke("SendMessage", receiverId, message, bookingId)
                .catch(err => console.error("Error sending message:", err));

            messageInput.value = '';
            messageInput.focus();
        }

        function appendMessage(senderId, message, timestamp) {
            const isSent = senderId === currentUserId;
            const div = document.createElement('div');
            div.className = `message ${isSent ? 'message-sent' : 'message-received'}`;
            const time = new Date(timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            div.innerHTML = `
                ${message}
                <span class="message-time">${time}</span>
            `;
            chatMessages.appendChild(div);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        chatMessages.scrollTop = chatMessages.scrollHeight;

        // Mark all messages as read when opening conversation
        connection.invoke("MarkAllAsRead", receiverId);
    </script>
}