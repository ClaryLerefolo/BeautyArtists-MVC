@model IEnumerable<BeautyArtists.Models.PortfolioCategory>
@{
    ViewData["Title"] = "Manage Portfolio Categories";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<h2>@ViewData["Title"]</h2>

<a asp-action="CreateCategory" class="btn btn-success mb-3">Add New Category</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th style="width: 150px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td>
                    <a asp-action="EditCategory" asp-route-id="@category.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this category?');">
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
