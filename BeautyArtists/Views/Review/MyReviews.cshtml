@model BeautyArtists.Models.ViewModels.MyReviewsViewModel
@{
    ViewData["Title"] = "My Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mr-page">

    @* ── HERO HEADER ── *@
    <div class="mr-hero">
        <div class="mr-hero-bg"></div>
        <div class="container mr-hero-inner">
            <div>
                <span class="mr-eyebrow">Your Feedback</span>
                <h1 class="mr-title">My Reviews</h1>
                <p class="mr-subtitle">All the reviews you've left for our artists</p>
            </div>
            <div class="mr-stats">
                <div class="mr-stat">
                    <span class="mr-stat-num">@Model.Reviews.Count</span>
                    <span class="mr-stat-label">TOTAL REVIEWS</span>
                </div>
                <div class="mr-stat-div"></div>
                <div class="mr-stat">
                    <span class="mr-stat-num" style="color:#00c853;">@Model.Reviews.Count(r => r.Review.Rating >= 4)</span>
                    <span class="mr-stat-label">⭐ 4-5 STARS</span>
                </div>
            </div>
        </div>
    </div>

    @* ── SUCCESS / ERROR MESSAGES ── *@
    @if (TempData["Success"] != null)
    {
        <div class="container mt-4">
            <div class="mr-alert-success">
                <span>✓</span> @TempData["Success"]
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="container mt-4">
            <div class="mr-alert-error">
                @TempData["Error"]
            </div>
        </div>
    }

    @* ── REVIEWS LIST ── *@
    <div class="container mr-body">

        @if (!Model.Reviews.Any())
        {
            <div class="mr-empty">
                <div class="mr-empty-icon">✍️</div>
                <h3>No Reviews Yet</h3>
                <p>You haven't left any reviews yet. After your appointments are completed, come back here to share your experience!</p>
                <a asp-controller="Home" asp-action="Index" class="mr-btn-primary">
                    Explore Services
                </a>
            </div>
        }
        else
        {
            @foreach (var item in Model.Reviews)
            {
                var review = item.Review;
                var stars = review.Rating;

                <div class="mr-card">
                    <div class="mr-card-body">

                        @* ── LEFT: REVIEW CONTENT ── *@
                        <div class="mr-card-main">
                            <div class="mr-card-header">
                                <div class="mr-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= stars)
                                        {
                                            <span class="mr-star filled">★</span>
                                        }
                                        else
                                        {
                                            <span class="mr-star empty">★</span>
                                        }
                                    }
                                </div>
                                <span class="mr-date">@review.CreatedAt.ToString("dd MMM yyyy")</span>
                            </div>

                            <h3 class="mr-service-name">@item.ServiceName</h3>

                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="mr-comment">"@review.Comment"</p>
                            }
                            else
                            {
                                <p class="mr-comment-muted"><em>No comment provided</em></p>
                            }

                            <div class="mr-meta">
                                <div class="mr-meta-item">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                        <circle cx="12" cy="7" r="4" />
                                    </svg>
                                    @item.ArtistName
                                </div>
                                <div class="mr-meta-item">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                        <line x1="16" y1="2" x2="16" y2="6" />
                                        <line x1="8" y1="2" x2="8" y2="6" />
                                        <line x1="3" y1="10" x2="21" y2="10" />
                                    </svg>
                                    @item.AppointmentDate
                                </div>
                                <div class="mr-meta-item">
                                    <span class="mr-booking-id">Booking #@review.BookingId</span>
                                </div>
                            </div>
                        </div>

                        @* ── RIGHT: SERVICE INFO ── *@
                        <div class="mr-card-right">
                            <div class="mr-artist-avatar">
                                <img src="@item.ArtistProfilePicture"
                                     alt="@item.ArtistName"
                                     onerror="this.src='/images/default-profile.png'" />
                            </div>
                            <div class="mr-artist-name">@item.ArtistName</div>
                            <a asp-controller="Home" asp-action="BrowseArtists" asp-route-id="@review.Booking?.UserService?.ArtistId" class="mr-btn-profile">
                                View Artist Profile
                            </a>
                        </div>

                    </div>
                </div>
            }
        }

        <div class="mr-footer-link">
            <a asp-controller="Home" asp-action="Index" class="mr-back-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                    <polyline points="15,18 9,12 15,6" />
                </svg>
                Back to Home
            </a>
        </div>
    </div>
</div>

<style>
    /* ────────── MY REVIEWS STYLES ────────── */
    .mr-page {
        background: #000;
        min-height: 100vh;
        padding-bottom: 80px;
    }

    .mr-hero {
        position: relative;
        padding: 50px 0 40px;
        overflow: hidden;
    }

    .mr-hero-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #0d0000 0%, #1a0800 50%, #050505 100%);
    }

        .mr-hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(179,0,0,0.18) 0%, transparent 55%), radial-gradient(ellipse at 80% 50%, rgba(255,215,0,0.06) 0%, transparent 55%);
        }

    .mr-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .mr-eyebrow {
        display: block;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(255,215,0,0.4);
        margin-bottom: 8px;
    }

    .mr-title {
        color: #FFD700;
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 6px;
        text-shadow: 0 0 30px rgba(255,215,0,0.25);
    }

    .mr-subtitle {
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
        margin: 0;
    }

    .mr-stats {
        display: flex;
        align-items: center;
        gap: 20px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,215,0,0.1);
        border-radius: 16px;
        padding: 16px 24px;
    }

    .mr-stat {
        text-align: center;
    }

    .mr-stat-num {
        display: block;
        font-size: 1.5rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .mr-stat-label {
        display: block;
        font-size: 0.52rem;
        font-weight: 700;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.25);
        margin-top: 3px;
    }

    .mr-stat-div {
        width: 1px;
        height: 36px;
        background: rgba(255,215,0,0.12);
    }

    .mr-alert-success {
        background: rgba(0,200,83,0.1);
        border: 1px solid rgba(0,200,83,0.3);
        border-radius: 10px;
        padding: 12px 18px;
        color: #00c853;
        font-size: 0.88rem;
        font-weight: 600;
    }

    .mr-alert-error {
        background: rgba(255,50,50,0.08);
        border: 1px solid rgba(255,50,50,0.25);
        border-radius: 10px;
        padding: 12px 18px;
        color: #ff5555;
        font-size: 0.88rem;
        font-weight: 600;
    }

    .mr-body {
        padding-top: 32px;
    }

    .mr-empty {
        text-align: center;
        padding: 80px 20px;
        background: #0b0b0b;
        border: 1px solid rgba(255,215,0,0.08);
        border-radius: 18px;
    }

    .mr-empty-icon {
        font-size: 3rem;
        margin-bottom: 16px;
    }

    .mr-empty h3 {
        color: #FFD700;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .mr-empty p {
        color: rgba(255,255,255,0.35);
        font-size: 0.88rem;
        margin-bottom: 24px;
    }

    .mr-btn-primary {
        display: inline-block;
        padding: 12px 28px;
        background: linear-gradient(135deg, #f0c808, #e50914);
        color: #000;
        border-radius: 50px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }

        .mr-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px rgba(240,200,8,0.3);
            color: #000;
        }

    .mr-card {
        background: #0b0b0b;
        border: 1px solid rgba(255,215,0,0.08);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 16px;
        transition: border-color 0.25s;
    }

        .mr-card:hover {
            border-color: rgba(255,215,0,0.25);
        }

    .mr-card-body {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        padding: 24px;
        flex-wrap: wrap;
    }

    .mr-card-main {
        flex: 1;
        min-width: 250px;
    }

    .mr-card-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .mr-stars {
        display: flex;
        gap: 3px;
    }

    .mr-star {
        font-size: 1.3rem;
        line-height: 1;
    }

        .mr-star.filled {
            color: #FFD700;
        }

        .mr-star.empty {
            color: rgba(255,255,255,0.1);
        }

    .mr-date {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.25);
        margin-left: auto;
    }

    .mr-service-name {
        color: #FFD700;
        font-size: 1.15rem;
        font-weight: 800;
        margin: 0 0 8px;
    }

    .mr-comment {
        color: rgba(255,255,255,0.7);
        font-size: 0.95rem;
        line-height: 1.6;
        margin: 0 0 14px;
        padding: 12px 16px;
        background: rgba(255,255,255,0.02);
        border-left: 3px solid rgba(255,215,0,0.3);
        border-radius: 4px;
    }

    .mr-comment-muted {
        color: rgba(255,255,255,0.2);
        font-size: 0.85rem;
        font-style: italic;
        margin: 0 0 14px;
        padding: 8px 16px;
        background: rgba(255,255,255,0.02);
        border-radius: 4px;
    }

    .mr-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        padding-top: 12px;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .mr-meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,0.3);
        font-size: 0.78rem;
    }

        .mr-meta-item svg {
            flex-shrink: 0;
        }

    .mr-booking-id {
        color: rgba(255,215,0,0.2);
        font-size: 0.7rem;
        font-weight: 600;
    }

    .mr-card-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 120px;
        flex-shrink: 0;
        padding-left: 16px;
        border-left: 1px solid rgba(255,255,255,0.05);
        gap: 8px;
    }

    .mr-artist-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid rgba(255,215,0,0.2);
        flex-shrink: 0;
    }

        .mr-artist-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .mr-artist-name {
        color: rgba(255,255,255,0.6);
        font-size: 0.75rem;
        font-weight: 600;
        text-align: center;
        line-height: 1.2;
    }

    .mr-btn-profile {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.65rem;
        font-weight: 600;
        color: #000;
        background: linear-gradient(135deg, #f0c808, #ff8c00);
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .mr-btn-profile:hover {
            transform: translateY(-1px);
            box-shadow: 0 0 20px rgba(240,200,8,0.3);
            color: #000;
        }

    .mr-footer-link {
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .mr-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: rgba(255,215,0,0.5);
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s;
    }

        .mr-back-btn:hover {
            color: #FFD700;
        }

    @@media (max-width: 768px) {
        .mr-card-body

    {
        flex-direction: column;
    }

    .mr-card-right {
        flex-direction: row;
        border-left: none;
        border-top: 1px solid rgba(255,255,255,0.05);
        padding-left: 0;
        padding-top: 16px;
        margin-top: 8px;
        min-width: unset;
        width: 100%;
        justify-content: center;
        flex-wrap: wrap;
    }

    .mr-artist-avatar {
        width: 48px;
        height: 48px;
    }

    .mr-artist-name {
        font-size: 0.7rem;
    }

    .mr-stats {
        padding: 12px 16px;
        gap: 12px;
    }

    .mr-stat-num {
        font-size: 1.2rem;
    }

    .mr-title {
        font-size: 1.6rem;
    }

    .mr-hero-inner {
        flex-direction: column;
        align-items: flex-start;
    }

    .mr-star {
        font-size: 1.1rem;
    }

    }
</style>