@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - RubiOr</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        :root {
            --gold: #C9A84C;
            --gold-bright: #FFD700;
            --ruby: #8B0000;
            --ruby-bright: #C0392B;
            --bg-dark: #000;
        }

        * {
            box-sizing: border-box;
        }

        body {
            background: #000;
            color: #eee;
            margin: 0;
        }

        /* ── NAVBAR ── */
        .navbar {
            background: #000 !important;
            border-bottom: 1px solid rgba(201,168,76,0.2);
            padding: 12px 0;
        }

        /* ── BRAND ── */
        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-logo-wrap {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid rgba(201,168,76,0.35);
            box-shadow: 0 0 12px rgba(201,168,76,0.4), 0 0 28px rgba(139,0,0,0.2);
            flex-shrink: 0;
        }

            .brand-logo-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .brand-wordmark {
            display: flex;
            align-items: baseline;
            gap: 0;
            line-height: 1;
        }

        .brand-rubi {
            font-size: 1.25rem;
            font-weight: 900;
            color: #8B0000;
            letter-spacing: 1px;
            font-style: italic;
            text-shadow: 0 0 10px rgba(139,0,0,0.4);
        }

        .brand-or {
            font-size: 1.25rem;
            font-weight: 900;
            color: #C9A84C;
            letter-spacing: 1px;
            font-style: italic;
            text-shadow: 0 0 10px rgba(201,168,76,0.5);
        }

        .brand-tagline {
            display: block;
            font-size: 0.48rem;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(201,168,76,0.4);
            margin-top: 2px;
        }

        /* ── NAV LINKS ── */
        .nav-link {
            color: rgba(201,168,76,0.8) !important;
            text-transform: uppercase;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            padding: 6px 14px !important;
            transition: color 0.2s;
            position: relative;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 14px;
                right: 14px;
                height: 1px;
                background: #C9A84C;
                transform: scaleX(0);
                transition: transform 0.2s ease;
            }

            .nav-link:hover {
                color: #C9A84C !important;
            }

                .nav-link:hover::after {
                    transform: scaleX(1);
                }

        /* ── DROPDOWN ── */
        .dropdown-menu {
            background: #0a0a0a !important;
            border: 1px solid rgba(201,168,76,0.2) !important;
            border-radius: 10px;
            padding: 8px;
            margin-top: 8px !important;
        }

        .dropdown-item {
            color: #fff !important;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 9px 16px;
            border-radius: 6px;
            transition: all 0.2s;
        }

            .dropdown-item:hover {
                background: rgba(201,168,76,0.1) !important;
                color: #C9A84C !important;
            }

        /* ── AUTH BUTTONS ── */
        .nav-auth-link {
            color: rgba(255,255,255,0.7) !important;
            text-transform: uppercase;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            padding: 6px 14px !important;
            text-decoration: none;
            transition: color 0.2s;
        }

            .nav-auth-link:hover {
                color: #C9A84C !important;
            }

        .nav-auth-highlight {
            background: linear-gradient(135deg, #8B0000, #C9A84C);
            color: #000 !important;
            font-weight: 800;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 8px 20px !important;
            border-radius: 999px;
            text-decoration: none;
            transition: all 0.3s;
            box-shadow: 0 0 12px rgba(139,0,0,0.3);
        }

            .nav-auth-highlight:hover {
                background: linear-gradient(135deg, #C9A84C, #8B0000);
                color: #000 !important;
                box-shadow: 0 0 20px rgba(201,168,76,0.4);
            }

        /* ── TOAST ── */
        #toastContainer {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .live-toast {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #1a1a1a;
            border-left: 4px solid #C9A84C;
            border-radius: 8px;
            padding: 12px 15px;
            min-width: 280px;
            max-width: 350px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            animation: slideInRight 0.3s ease;
        }

        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .toast-icon {
            font-size: 24px;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-weight: bold;
            color: #C9A84C;
            font-size: 0.85rem;
            margin-bottom: 4px;
        }

        .toast-message {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.7);
        }

        .toast-close {
            background: none;
            border: none;
            color: rgba(255,255,255,0.5);
            font-size: 18px;
            cursor: pointer;
        }

            .toast-close:hover {
                color: #fff;
            }

        /* ── FOOTER ── */
        footer {
            background: #000;
            border-top: 1px solid rgba(201,168,76,0.1) !important;
        }
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">

                @* ── BRAND ── *@
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <div class="brand-logo-wrap">
                        <img src="~/images/RUBIOR LOGO.jpg"
                             alt="RubiOr"
                             onerror="this.style.display='none'" />
                    </div>
                    <div>
                        <div class="brand-wordmark">
                            <span class="brand-rubi">Rubi</span><span class="brand-or">Or</span>
                        </div>
                        <span class="brand-tagline">Beauty in Red &amp; Gold</span>
                    </div>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Support">Support</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="AllServices">Services</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="BrowseArtists">Artists</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Categories">Explore</a>
                        </li>

                      

                    </ul>

                    @* ── AUTH ── *@
                    <div class="ms-3 d-flex align-items-center gap-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <span class="nav-auth-link" style="color:rgba(201,168,76,0.55)!important;font-size:0.75rem;">
                                Hello, @User.Identity!.Name!.Split('@')[0]
                            </span>
                            <form asp-area="Identity" asp-page="/Account/Logout"
                                  asp-route-returnUrl="@Url.Action("Index", "Home")"
                                  method="post" class="m-0">
                                <button type="submit"
                                        class="nav-auth-link border-0 bg-transparent"
                                        style="cursor:pointer">
                                    Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Register"
                               class="nav-auth-link">Register</a>
                            <a asp-area="Identity" asp-page="/Account/Login"
                               class="nav-auth-highlight">Login</a>
                        }
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        @RenderBody()
    </div>

    <footer class="footer py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1" style="color:rgba(201,168,76,0.4);font-size:0.75rem;letter-spacing:3px;">
                &copy; 2026 &nbsp;
                <span style="color:#8B0000;font-style:italic;font-weight:700;">Rubi</span><span style="color:#C9A84C;font-style:italic;font-weight:700;">Or</span>
                &nbsp;&mdash; Beauty in Red &amp; Gold
            </p>
        </div>
    </footer>

    <div id="toastContainer"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>