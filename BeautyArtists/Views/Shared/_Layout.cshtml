@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - BeautyArtists</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        :root {
            --gold: #FFD700;
            --red-btn: #b30000;
            --bg-dark: #000;
        }

        * {
            box-sizing: border-box;
        }

        body {
            background: #000;
            color: #eee;
            margin: 0;
        }

        /* ── NAVBAR ── */
        .navbar {
            background: #000 !important;
            border-bottom: 1px solid rgba(255, 215, 0, 0.15);
            padding: 14px 0;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .navbar-brand img {
                height: 40px;
                width: 40px;
                object-fit: contain;
                border: 1px solid rgba(255,215,0,0.3);
                border-radius: 6px;
                padding: 2px;
                filter: drop-shadow(0 0 8px rgba(255,215,0,0.7)) drop-shadow(0 0 16px rgba(255,215,0,0.4));
            }

        .navbar-brand-text {
            color: #FFD700 !important;
            font-weight: 900;
            font-size: 1rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-shadow: 0 0 12px rgba(255,215,0,0.4);
            text-decoration: none;
            line-height: 1.2;
        }

        .text-gold {
            color: var(--gold) !important;
        }

        .nav-link {
            color: #FFD700 !important;
            text-transform: uppercase;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            padding: 6px 14px !important;
            transition: color 0.2s;
            position: relative;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 14px;
                right: 14px;
                height: 1px;
                background: #FFD700;
                transform: scaleX(0);
                transition: transform 0.2s ease;
            }

            .nav-link:hover {
                color: #FFD700 !important;
            }

                .nav-link:hover::after {
                    transform: scaleX(1);
                }

        .dropdown-menu {
            background: #0a0a0a !important;
            border: 1px solid rgba(255,215,0,0.2) !important;
            border-radius: 10px;
            padding: 8px;
            margin-top: 8px !important;
        }

        .dropdown-item {
            color: #fff !important;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 9px 16px;
            border-radius: 6px;
            transition: all 0.2s;
        }

            .dropdown-item:hover {
                background: rgba(255,215,0,0.1) !important;
                color: #FFD700 !important;
            }

        /* Notification Bell Styles */
        .notification-bell {
            margin-left: 10px;
        }

            .notification-bell .dropdown-toggle::after {
                display: none;
            }

            .notification-bell .dropdown-toggle {
                position: relative;
                padding: 6px 10px !important;
            }

            .notification-bell .badge {
                position: absolute;
                top: -5px;
                right: -8px;
                background: #e50914;
                color: white;
                border-radius: 50%;
                font-size: 9px;
                padding: 3px 6px;
                min-width: 18px;
                text-align: center;
            }

        .notification-menu {
            width: 350px;
            max-height: 450px;
            background: #121212;
            border: 1px solid rgba(240, 200, 8, 0.2);
            border-radius: 12px;
            padding: 0;
            overflow: hidden;
            margin-top: 10px !important;
        }

        .notification-header {
            padding: 12px 15px;
            border-bottom: 1px solid rgba(240, 200, 8, 0.1);
            color: #FFD700;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .notification-list {
            max-height: 350px;
            overflow-y: auto;
        }

        .notification-item {
            display: flex;
            gap: 12px;
            padding: 12px 15px;
            cursor: pointer;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: background 0.2s;
        }

            .notification-item:hover {
                background: rgba(240, 200, 8, 0.05);
            }

            .notification-item.unread {
                background: rgba(240, 200, 8, 0.08);
            }

        .notification-icon {
            font-size: 20px;
            flex-shrink: 0;
        }

        .notification-content {
            flex: 1;
        }

        .notification-title {
            font-weight: 600;
            color: #FFD700;
            font-size: 0.85rem;
            margin-bottom: 4px;
        }

        .notification-message {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.6);
            word-wrap: break-word;
        }

        .notification-time {
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.3);
            margin-top: 4px;
        }

        .notification-empty {
            text-align: center;
            padding: 40px;
            color: rgba(255, 255, 255, 0.4);
        }

        .notification-footer {
            padding: 10px;
            text-align: center;
            border-top: 1px solid rgba(240, 200, 8, 0.1);
        }

        .btn-mark-all {
            background: none;
            border: none;
            color: #FFD700;
            font-size: 0.7rem;
            cursor: pointer;
        }

            .btn-mark-all:hover {
                text-decoration: underline;
            }

        /* ── FLOATING CHAT BUTTON ── */
        .chat-float-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #f0c808, #e50914);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(240, 200, 8, 0.5);
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 9999;
            text-decoration: none;
            color: #000;
            font-size: 1.8rem;
        }

            .chat-float-btn:hover {
                transform: scale(1.1) translateY(-3px);
                box-shadow: 0 8px 30px rgba(240, 200, 8, 0.7);
            }

        .chat-float-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            background: #e50914;
            color: #fff;
            border-radius: 50%;
            font-size: 0.7rem;
            font-weight: 800;
            min-width: 22px;
            height: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 5px;
            box-shadow: 0 0 10px rgba(229, 9, 20, 0.5);
            animation: pulse-badge 1.5s ease-in-out infinite;
        }

        @@keyframes pulse-badge {
            0%, 100%

        {
            transform: scale(1);
        }

        50% {
            transform: scale(1.15);
        }

        }

        /* Toast Notifications */
        #toastContainer {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .live-toast {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #1a1a1a;
            border-left: 4px solid #f0c808;
            border-radius: 8px;
            padding: 12px 15px;
            min-width: 280px;
            max-width: 350px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            animation: slideInRight 0.3s ease;
        }

        @@keyframes slideInRight {
            from

        {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }

        }

        .toast-icon {
            font-size: 24px;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-weight: bold;
            color: #f0c808;
            font-size: 0.85rem;
            margin-bottom: 4px;
        }

        .toast-message {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.7);
        }

        .toast-close {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.5);
            font-size: 18px;
            cursor: pointer;
            padding: 0 5px;
        }

            .toast-close:hover {
                color: #fff;
            }

        /* Login/Register links */
        .nav-auth-link {
            color: #fff !important;
            text-transform: uppercase;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            padding: 6px 14px !important;
            text-decoration: none;
            transition: color 0.2s;
        }

            .nav-auth-link:hover {
                color: #FFD700 !important;
            }

        .nav-auth-highlight {
            background: linear-gradient(135deg, #b30000, #FFD700);
            color: #000 !important;
            font-weight: 800;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 7px 18px !important;
            border-radius: 999px;
            text-decoration: none;
            transition: all 0.3s;
        }

            .nav-auth-highlight:hover {
                background: linear-gradient(135deg, #FFD700, #b30000);
                color: #000 !important;
                box-shadow: 0 0 15px rgba(255,215,0,0.3);
            }

        /* ── FOOTER ── */
        footer {
            background: #000;
            border-top: 1px solid rgba(255,215,0,0.1) !important;
        }
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">

                @* BRAND *@
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/Beauty in Red and Gold 2.jpg"
                         alt="Beauty In Red and Gold"
                         onerror="this.style.display='none'">
                    <span class="navbar-brand-text">BEAUTY IN RED AND GOLD</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                        </li>

                        @* SERVICES → HomeController.AllServices (customer side) *@
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="AllServices">Services</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="BrowseArtists">Artists</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               id="exploreDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Explore
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="exploreDropdown">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="CustomerPortfolio"
                                       asp-action="Index">Portfolios</a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Home"
                                       asp-action="BrowseArtists">Browse All</a>
                                </li>
                            </ul>
                        </li>

                        @* 🔔 NOTIFICATION BELL - Only for logged in users *@
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown notification-bell">
                                <a class="nav-link dropdown-toggle" href="#" id="notificationDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell-fill" style="font-size: 1.2rem;"></i>
                                    <span id="notificationBadge" class="badge" style="display:none;">0</span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end notification-menu" aria-labelledby="notificationDropdown">
                                    <div class="notification-header">
                                        <h6>Notifications</h6>
                                        <span id="loadingNotifications" class="small">loading...</span>
                                    </div>
                                    <div id="notificationContent">
                                        <!-- Notifications load here -->
                                    </div>
                                </div>
                            </li>
                        }

                    </ul>

                    @* AUTH *@
                    <div class="ms-3 d-flex align-items-center gap-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <span class="nav-auth-link" style="color:rgba(255,215,0,0.6)!important">
                                Hello @User.Identity!.Name!.Split('@')[0]!
                            </span>
                            <form asp-area="Identity" asp-page="/Account/Logout"
                                  asp-route-returnUrl="@Url.Action("Index", "Home")"
                                  method="post" class="m-0">
                                <button type="submit" class="nav-auth-link border-0 bg-transparent"
                                        style="cursor:pointer">
                                    Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Register"
                               class="nav-auth-link">Register</a>
                            <a asp-area="Identity" asp-page="/Account/Login"
                               class="nav-auth-highlight">Login</a>
                        }
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        @RenderBody()
    </div>

    <footer class="footer py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1" style="color:rgba(255,215,0,0.5);font-size:0.8rem;letter-spacing:2px">
                &copy; 2026 BEAUTY IN RED AND GOLD
            </p>
        </div>
    </footer>

    @* ── FLOATING CHAT BUTTON ── *@
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="chat-float-btn" onclick="window.location.href='@Url.Action("Index", "Chat")'">
            <span>💬</span>
            <span class="chat-float-badge" id="chatUnreadBadge">0</span>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SignalR and Notification Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/notifications.js"></script>

    <script>
        @if (SignInManager.IsSignedIn(User))
        {
                <text>
                    var userId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
                    if (typeof initNotificationSystem === 'function') {
                        initNotificationSystem(userId);
                    }

                    // ── CHAT UNREAD BADGE ──
                    function updateChatBadge(count) {
                        var badge = document.getElementById('chatUnreadBadge');
                        if (badge) {
                            if (count > 0) {
                                badge.textContent = count;
                                badge.style.display = 'flex'; // show with flex
                            } else {
                                badge.style.display = 'none';
                            }
                        }
                    }

                    // Fetch initial unread count
                    fetch('/Chat/GetUnreadCount')
                        .then(res => res.json())
                        .then(data => {
                            updateChatBadge(data.count);
                        })
                        .catch(() => {});

                    // Listen for SignalR unread count updates
                    if (typeof connection !== 'undefined' && connection) {
                        connection.on("UnreadCount", function(count) {
                            updateChatBadge(count);
                        });
                    }
                </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>