@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var displayName = user != null && !string.IsNullOrEmpty(user.FirstName)
        ? $"{user.FirstName} {user.LastName}".Trim()
        : "Artist";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artist</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --gold: #FFD700;
            --sidebar-width: 260px;
            --sidebar-collapsed: 70px;
        }

        html, body {
            margin: 0;
            padding: 0;
            background: #000;
            color: #fff;
            font-family: 'Segoe UI', Roboto, sans-serif;
            overflow-x: hidden;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-width);
            background: #000;
            height: 100vh;
            border-right: 1px solid rgba(255,215,0,0.1);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: width 0.3s cubic-bezier(0.4,0,0.2,1), transform 0.3s cubic-bezier(0.4,0,0.2,1);
            overflow: hidden;
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed);
            }

        /* ── SIDEBAR HEADER ── */
        .sidebar-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 20px 18px;
            border-bottom: 1px solid rgba(255,215,0,0.08);
            min-height: 80px;
            flex-shrink: 0;
        }

        .sidebar-logo {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            object-fit: contain;
            border: 1px solid rgba(255,215,0,0.25);
            padding: 2px;
            flex-shrink: 0;
            filter: drop-shadow(0 0 6px rgba(255,215,0,0.5));
        }

        .sidebar-brand-text {
            color: var(--gold);
            font-weight: 900;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            line-height: 1.3;
            white-space: nowrap;
            overflow: hidden;
            opacity: 1;
            transition: opacity 0.2s;
        }

        .sidebar.collapsed .sidebar-brand-text {
            opacity: 0;
            width: 0;
        }

        /* ── DESKTOP TOGGLE ── */
        .sidebar-toggle {
            position: fixed;
            top: 22px;
            left: calc(var(--sidebar-width) - 16px);
            width: 32px;
            height: 32px;
            background: #000;
            border: 1px solid rgba(255,215,0,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 1001;
            transition: left 0.3s cubic-bezier(0.4,0,0.2,1), background 0.2s;
            color: rgba(255,215,0,0.6);
        }

            .sidebar-toggle:hover {
                background: rgba(255,215,0,0.1);
                color: var(--gold);
                border-color: rgba(255,215,0,0.4);
            }

        .toggle-icon {
            transition: transform 0.3s;
            font-size: 0.75rem;
        }

        /* ── NAV LINKS ── */
        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 12px 0;
        }

            .sidebar-nav::-webkit-scrollbar {
                width: 3px;
            }

            .sidebar-nav::-webkit-scrollbar-thumb {
                background: rgba(255,215,0,0.1);
                border-radius: 2px;
            }

        .nav-link {
            color: rgba(255,255,255,0.6) !important;
            padding: 11px 18px !important;
            margin: 2px 10px !important;
            display: flex !important;
            align-items: center !important;
            gap: 14px !important;
            text-decoration: none !important;
            border-radius: 10px !important;
            border-left: none !important;
            transition: all 0.2s !important;
            white-space: nowrap;
            overflow: hidden;
            min-height: 44px;
        }

            .nav-link:hover {
                background: rgba(255,215,0,0.08) !important;
                color: var(--gold) !important;
                font-weight: 600 !important;
            }

            .nav-link.active {
                background: linear-gradient(135deg, rgba(179,0,0,0.3), rgba(255,215,0,0.1)) !important;
                color: var(--gold) !important;
                border: 1px solid rgba(255,215,0,0.15) !important;
            }

            .nav-link i {
                color: var(--gold) !important;
                font-size: 1.1rem !important;
                flex-shrink: 0 !important;
                width: 20px;
                text-align: center;
            }

        .nav-link-text {
            opacity: 1;
            transition: opacity 0.15s;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.3px;
        }

        .sidebar.collapsed .nav-link-text {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        /* Collapsed tooltips — desktop only */
        .sidebar.collapsed .nav-link {
            position: relative;
            justify-content: center !important;
            margin: 2px 8px !important;
            padding: 11px !important;
        }

            .sidebar.collapsed .nav-link::after {
                content: attr(data-label);
                position: absolute;
                left: calc(var(--sidebar-collapsed) + 4px);
                background: #111;
                color: var(--gold);
                border: 1px solid rgba(255,215,0,0.2);
                border-radius: 8px;
                padding: 6px 12px;
                font-size: 0.75rem;
                font-weight: 600;
                white-space: nowrap;
                pointer-events: none;
                opacity: 0;
                transition: opacity 0.15s;
                z-index: 9999;
            }

            .sidebar.collapsed .nav-link:hover::after {
                opacity: 1;
            }

        /* ── LOGOUT ── */
        .sidebar-footer {
            padding: 12px 10px 20px;
            flex-shrink: 0;
            border-top: 1px solid rgba(255,215,0,0.06);
        }

        .logout-btn {
            background: none;
            border: none;
            width: 100%;
            color: rgba(255,100,100,0.7) !important;
            padding: 11px 18px !important;
            display: flex !important;
            align-items: center !important;
            gap: 14px !important;
            border-radius: 10px !important;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
            overflow: hidden;
            font-size: 0.85rem;
        }

            .logout-btn:hover {
                background: rgba(255,50,50,0.1) !important;
                color: #ff6666 !important;
            }

            .logout-btn i {
                color: rgba(255,100,100,0.7) !important;
                font-size: 1.1rem !important;
                flex-shrink: 0 !important;
                width: 20px;
                text-align: center;
            }

            .logout-btn:hover i {
                color: #ff6666 !important;
            }

        .sidebar.collapsed .logout-btn {
            justify-content: center !important;
            padding: 11px !important;
        }

        .sidebar.collapsed .logout-btn-text {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        /* ── MAIN CONTENT ── */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 0 36px 40px 36px;
            min-height: 100vh;
            transition: margin-left 0.3s cubic-bezier(0.4,0,0.2,1);
        }

            .main-content.collapsed {
                margin-left: var(--sidebar-collapsed);
            }

        /* ── TOP BAR ── */
        .top-branding-bar {
            padding: 18px 0 14px;
            margin-bottom: 24px;
            border-bottom: 1px solid rgba(255,215,0,0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .branding-text {
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: 0.5px;
            margin: 0;
            line-height: 1.2;
        }

        .gold-name {
            color: var(--gold);
            text-shadow: 0 0 12px rgba(255,215,0,0.25);
        }

        .top-bar-right {
            display: flex;
            align-items: center;
            gap: 14px;
            position: relative;
        }

        /* Notification Bell Styles */
        .notification-bell {
            position: relative;
        }

            .notification-bell .dropdown-toggle::after {
                display: none;
            }

            .notification-bell .dropdown-toggle {
                text-decoration: none;
                padding: 5px;
                display: flex;
                align-items: center;
            }

            .notification-bell .badge {
                position: absolute;
                top: -8px;
                right: -8px;
                background: #e50914;
                color: white;
                border-radius: 50%;
                font-size: 10px;
                padding: 3px 6px;
                min-width: 18px;
                text-align: center;
            }

        .notification-menu {
            width: 350px;
            max-height: 450px;
            background: #121212;
            border: 1px solid rgba(240, 200, 8, 0.2);
            border-radius: 12px;
            padding: 0;
            overflow: hidden;
            margin-top: 10px !important;
            position: absolute;
            right: 0;
            left: auto !important;
        }

        .notification-header {
            padding: 12px 15px;
            border-bottom: 1px solid rgba(240, 200, 8, 0.1);
            color: #FFD700;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .notification-list {
            max-height: 350px;
            overflow-y: auto;
        }

        .notification-item {
            display: flex;
            gap: 12px;
            padding: 12px 15px;
            cursor: pointer;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: background 0.2s;
        }

            .notification-item:hover {
                background: rgba(240, 200, 8, 0.05);
            }

            .notification-item.unread {
                background: rgba(240, 200, 8, 0.08);
            }

        .notification-icon {
            font-size: 20px;
            flex-shrink: 0;
        }

        .notification-content {
            flex: 1;
        }

        .notification-title {
            font-weight: 600;
            color: #FFD700;
            font-size: 0.85rem;
            margin-bottom: 4px;
        }

        .notification-message {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.6);
            word-wrap: break-word;
        }

        .notification-time {
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.3);
            margin-top: 4px;
        }

        .notification-empty {
            text-align: center;
            padding: 40px;
            color: rgba(255, 255, 255, 0.4);
        }

        .notification-footer {
            padding: 10px;
            text-align: center;
            border-top: 1px solid rgba(240, 200, 8, 0.1);
        }

        .btn-mark-all {
            background: none;
            border: none;
            color: #FFD700;
            font-size: 0.7rem;
            cursor: pointer;
        }

            .btn-mark-all:hover {
                text-decoration: underline;
            }

        /* Toast Notifications */
        #toastContainer {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .live-toast {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #1a1a1a;
            border-left: 4px solid #f0c808;
            border-radius: 8px;
            padding: 12px 15px;
            min-width: 280px;
            max-width: 350px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            animation: slideInRight 0.3s ease;
        }

        @@keyframes slideInRight {
            from

        {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }

        }

        .toast-icon {
            font-size: 24px;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-weight: bold;
            color: #f0c808;
            font-size: 0.85rem;
            margin-bottom: 4px;
        }

        .toast-message {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.7);
        }

        .toast-close {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.5);
            font-size: 18px;
            cursor: pointer;
            padding: 0 5px;
        }

            .toast-close:hover {
                color: #fff;
            }

        .top-bar-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #b30000, #FFD700);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 0.85rem;
            color: #000;
            cursor: pointer;
        }

        /* ── HAMBURGER — hidden on desktop ── */
        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            color: var(--gold);
            font-size: 1.5rem;
            cursor: pointer;
            padding: 2px 8px;
            border-radius: 8px;
            transition: background 0.2s;
            line-height: 1;
        }

            .hamburger-btn:hover {
                background: rgba(255,215,0,0.1);
            }

        /* ── BACKDROP — mobile only ── */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.75);
            z-index: 999;
            backdrop-filter: blur(3px);
        }

            .sidebar-backdrop.show {
                display: block;
            }

        /* ══════════════════════
                           TABLET (769–1024px)
                        ══════════════════════ */
        @@media (min-width: 769px) and (max-width: 1024px) {
            .sidebar

        {
            width: var(--sidebar-collapsed) !important;
        }

        .sidebar .sidebar-brand-text {
            opacity: 0 !important;
            width: 0 !important;
        }

        .sidebar .nav-link-text {
            opacity: 0 !important;
            width: 0 !important;
            overflow: hidden !important;
        }

        .sidebar .nav-link {
            justify-content: center !important;
            margin: 2px 8px !important;
            padding: 11px !important;
            position: relative;
        }

            .sidebar .nav-link::after {
                content: attr(data-label);
                position: absolute;
                left: calc(var(--sidebar-collapsed) + 4px);
                background: #111;
                color: var(--gold);
                border: 1px solid rgba(255,215,0,0.2);
                border-radius: 8px;
                padding: 6px 12px;
                font-size: 0.75rem;
                font-weight: 600;
                white-space: nowrap;
                pointer-events: none;
                opacity: 0;
                transition: opacity 0.15s;
                z-index: 9999;
            }

            .sidebar .nav-link:hover::after {
                opacity: 1;
            }

        .sidebar .logout-btn {
            justify-content: center !important;
            padding: 11px !important;
        }

        .sidebar .logout-btn-text {
            opacity: 0 !important;
            width: 0 !important;
            overflow: hidden !important;
        }

        .main-content {
            margin-left: var(--sidebar-collapsed) !important;
        }

        .sidebar-toggle {
            left: calc(var(--sidebar-collapsed) - 16px) !important;
        }

        }

        /* ══════════════════════
                           MOBILE (max 768px)
                        ══════════════════════ */
        @@media (max-width: 768px) {
            .sidebar-toggle

        {
            display: none !important;
        }

        .hamburger-btn {
            display: inline-flex !important;
            align-items: center;
        }

        .sidebar {
            transform: translateX(-100%);
            width: var(--sidebar-width) !important;
            box-shadow: none;
        }

            .sidebar.mobile-open {
                transform: translateX(0);
                box-shadow: 6px 0 40px rgba(0,0,0,0.9);
            }

            .sidebar.collapsed {
                width: var(--sidebar-width) !important;
                transform: translateX(-100%);
            }

                .sidebar.collapsed.mobile-open {
                    transform: translateX(0) !important;
                }

                .sidebar.collapsed .sidebar-brand-text {
                    opacity: 1 !important;
                    width: auto !important;
                }

                .sidebar.collapsed .nav-link-text {
                    opacity: 1 !important;
                    width: auto !important;
                }

                .sidebar.collapsed .logout-btn-text {
                    opacity: 1 !important;
                    width: auto !important;
                }

                .sidebar.collapsed .nav-link {
                    justify-content: flex-start !important;
                    margin: 2px 10px !important;
                    padding: 11px 18px !important;
                }

                    .sidebar.collapsed .nav-link::after {
                        display: none !important;
                    }

                .sidebar.collapsed .logout-btn {
                    justify-content: flex-start !important;
                    padding: 11px 18px !important;
                }

        .main-content {
            margin-left: 0 !important;
            padding: 0 14px 40px 14px !important;
        }

        .top-branding-bar {
            padding: 14px 0 10px;
        }

        .branding-text {
            font-size: 1.05rem;
        }

        }
    </style>
</head>
<body>

    @* ── MOBILE BACKDROP ── *@
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    @* ── SIDEBAR ── *@
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <img src="~/images/Beauty in Red and Gold 2.jpg"
                 class="sidebar-logo" alt="Logo"
                 onerror="this.style.display='none'">
            <span class="sidebar-brand-text">BEAUTY IN<br>RED AND GOLD</span>
        </div>

        <nav class="sidebar-nav">
            <a class="nav-link" data-label="Dashboard"
               asp-controller="Artist" asp-action="Dashboard">
                <i class="bi bi-grid-1x2-fill"></i>
                <span class="nav-link-text">Dashboard</span>
            </a>
            <a class="nav-link" data-label="Profile"
               asp-controller="Artist" asp-action="Profile">
                <i class="bi bi-person-circle"></i>
                <span class="nav-link-text">Profile</span>
            </a>
            <a class="nav-link" data-label="My Services"
               asp-controller="Artist" asp-action="ManageServices">
                <i class="bi bi-scissors"></i>
                <span class="nav-link-text">My Services</span>
            </a>
            <a class="nav-link" data-label="My Portfolio"
               asp-controller="Portfolio" asp-action="ManagePortfolio">
                <i class="bi bi-images"></i>
                <span class="nav-link-text">My Portfolio</span>
            </a>
            <a class="nav-link" data-label="Availability"
               asp-controller="ArtistAvailability" asp-action="Index">
                <i class="bi bi-calendar3"></i>
                <span class="nav-link-text">Availability</span>
            </a>
            <a class="nav-link" data-label="Appointments"
               asp-controller="Artist" asp-action="MyAppointments">
                <i class="bi bi-calendar-check"></i>
                <span class="nav-link-text">Appointments</span>
            </a>
            <a class="nav-link" data-label="Earnings"
               asp-controller="Earnings" asp-action="Earnings">
                <i class="bi bi-graph-up-arrow"></i>
                <span class="nav-link-text">Earnings</span>
            </a>
            <a class="nav-link" data-label="Messages" asp-controller="Chat" asp-action="Index">
                <i class="bi bi-chat-dots"></i>
                <span class="nav-link-text">Messages</span>
                <span id="chatUnreadBadge" class="badge" style="display:none; background:#e50914; color:#fff; border-radius:50%; padding:1px 6px; font-size:0.6rem; margin-left:auto;"></span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post">
                <button type="submit" class="logout-btn">
                    <i class="bi bi-box-arrow-right"></i>
                    <span class="logout-btn-text">Logout</span>
                </button>
            </form>
        </div>
    </div>

    @* ── DESKTOP COLLAPSE TOGGLE ── *@
    <button class="sidebar-toggle" id="sidebarToggle" title="Toggle sidebar">
        <i class="bi bi-chevron-left toggle-icon" id="toggleIcon"></i>
    </button>

    @* ── MAIN CONTENT ── *@
    <div class="main-content" id="mainContent">
        <div class="top-branding-bar">

            @* Hamburger — shows on mobile only via CSS *@
            <button class="hamburger-btn" id="hamburgerBtn" title="Open menu">
                <i class="bi bi-list"></i>
            </button>

            <h1 class="branding-text">
                @if (ViewData["Title"]?.ToString() == "Dashboard")
                {
                    <span style="color:rgba(255,255,255,0.7)">Welcome, </span>
                    <span class="gold-name">@displayName!</span>
                }
                else
                {
                    <span class="gold-name">@displayName</span>
                }
            </h1>

            <div class="top-bar-right">
                <!-- 🔔 NOTIFICATION BELL DROPDOWN 🔔 -->
                <div class="dropdown notification-bell">
                    <a class="dropdown-toggle" href="#" id="notificationDropdown" role="button"
                       data-bs-toggle="dropdown" aria-expanded="false" style="text-decoration: none;">
                        <i class="bi bi-bell-fill" style="color:var(--gold);cursor:pointer;font-size:1.2rem"></i>
                        <span id="notificationBadge" class="badge" style="display:none;">0</span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end notification-menu" aria-labelledby="notificationDropdown">
                        <div class="notification-header">
                            <h6>Notifications</h6>
                            <span id="loadingNotifications" class="small">loading...</span>
                        </div>
                        <div id="notificationContent">
                            <!-- Notifications load here -->
                        </div>
                    </div>
                </div>
                <div class="top-bar-avatar">
                    @(displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "A")
                </div>
            </div>
        </div>

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SignalR and Notification Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/notifications.js"></script>

    <script>
        const sidebar      = document.getElementById('sidebar');
        const mainContent  = document.getElementById('mainContent');
        const toggleBtn    = document.getElementById('sidebarToggle');
        const toggleIcon   = document.getElementById('toggleIcon');
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const backdrop     = document.getElementById('sidebarBackdrop');

        const isMobile = () => window.innerWidth <= 768;
        const isTablet = () => window.innerWidth > 768 && window.innerWidth <= 1024;

        // ── DESKTOP: restore saved state ──
        if (!isMobile() && !isTablet()) {
            const wasCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (wasCollapsed) {
                sidebar.classList.add('collapsed');
                mainContent.classList.add('collapsed');
                toggleIcon.classList.replace('bi-chevron-left', 'bi-chevron-right');
                toggleBtn.style.left = 'calc(70px - 16px)';
            }
        }

        // ── DESKTOP: collapse toggle ──
        toggleBtn.addEventListener('click', () => {
            if (isMobile() || isTablet()) return;
            const collapsed = sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('collapsed', collapsed);
            if (collapsed) {
                toggleIcon.classList.replace('bi-chevron-left', 'bi-chevron-right');
                toggleBtn.style.left = 'calc(70px - 16px)';
            } else {
                toggleIcon.classList.replace('bi-chevron-right', 'bi-chevron-left');
                toggleBtn.style.left = 'calc(260px - 16px)';
            }
            localStorage.setItem('sidebarCollapsed', collapsed);
        });

        // ── MOBILE: open ──
        hamburgerBtn.addEventListener('click', () => {
            sidebar.classList.add('mobile-open');
            backdrop.classList.add('show');
            document.body.style.overflow = 'hidden';
        });

        // ── MOBILE: close ──
        function closeMobile() {
            sidebar.classList.remove('mobile-open');
            backdrop.classList.remove('show');
            document.body.style.overflow = '';
        }

        backdrop.addEventListener('click', closeMobile);

        // Close sidebar when a nav link is tapped on mobile
        document.querySelectorAll('.sidebar-nav .nav-link').forEach(link => {
            link.addEventListener('click', () => {
                if (isMobile()) closeMobile();
            });
        });

        // ── ACTIVE LINK ──
        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.sidebar-nav .nav-link').forEach(link => {
            const href = link.getAttribute('href')?.toLowerCase();
            if (href && currentPath.includes(href.split('/').pop())) {
                link.classList.add('active');
            }
        });

        // ── RESIZE: close mobile sidebar if screen grows ──
        window.addEventListener('resize', () => {
            if (!isMobile()) closeMobile();
        });

        // Initialize notification system
        var userId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
        if (typeof initNotificationSystem === 'function') {
            initNotificationSystem(userId);
        }

        // ── CHAT UNREAD BADGE FOR ARTIST LAYOUT ──
        function updateChatBadge(count) {
            var badge = document.getElementById('chatUnreadBadge');
            if (badge) {
                if (count > 0) {
                    badge.textContent = count;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            }
        }

        // Fetch initial unread count
        fetch('/Chat/GetUnreadCount')
            .then(res => res.json())
            .then(data => {
                updateChatBadge(data.count);
            })
            .catch(() => {});

        // If you have SignalR connection, listen for updates
        if (typeof connection !== 'undefined' && connection) {
            connection.on("UnreadCount", function(count) {
                updateChatBadge(count);
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>