@*
    _AdminLayout.cshtml
    Theme: Black/Gold/Red, collapsible sidebar, icons included
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BeautyArtist Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --bs-primary: #000;
            --bs-secondary: #FFD700;
            --bs-accent: #8B0000;
            --bs-light: #f8f9fa;
            --bs-dark: #212529;
        }

        body {
            background-color: #000;
            color: #fff;
            font-family: 'Segoe UI', sans-serif;
        }

        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: linear-gradient(to bottom, #000, #111);
            position: fixed;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.4);
            transition: all 0.3s ease-in-out;
            z-index: 1000;
        }

        .sidebar-collapsed {
            width: 80px;
        }

            .sidebar-collapsed .nav-link span {
                display: none;
            }

            .sidebar-collapsed .sidebar-brand {
                font-size: 0;
            }

                .sidebar-collapsed .sidebar-brand::after {
                    content: "BSG";
                    font-size: 1.25rem;
                    color: var(--bs-secondary);
                }

        .main-content {
            margin-left: 250px;
            transition: all 0.3s ease-in-out;
            padding: 2rem;
        }

        .main-content-collapsed {
            margin-left: 80px;
        }

        .sidebar-brand {
            color: var(--bs-secondary);
            font-weight: 700;
            font-size: 1.5rem;
            padding: 1.5rem 1rem;
            text-align: center;
            border-bottom: 1px solid rgba(255, 215, 0, 0.3);
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.85);
            padding: 0.75rem 1.5rem;
            margin: 0.25rem 0;
            border-left: 3px solid transparent;
            transition: all 0.3s;
            font-weight: 600;
        }

            .nav-link:hover, .nav-link.active {
                color: var(--bs-secondary);
                background-color: rgba(255, 215, 0, 0.1);
                border-left: 3px solid var(--bs-secondary);
            }

            .nav-link i {
                margin-right: 0.5rem;
                width: 20px;
                text-align: center;
            }

        .toggle-btn {
            position: fixed;
            bottom: 20px;
            left: 20px;
            z-index: 1100;
            background-color: var(--bs-secondary);
            color: #000;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
        }

        button.nav-link {
            background: none;
            border: none;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            Beauty Artists Admin
        </div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="ManageUsers">
                    <i class="fas fa-users"></i>
                    <span>Manage Users</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="PortfolioCategory" asp-action="ManageCategory">
                    <i class="fas fa-users"></i>
                    <span>Manage Categories</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Services">
                    <i class="fas fa-spa"></i>
                    <span>Manage Services</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="ManageBookings">
                    <i class="fas fa-calendar-check"></i>
                    <span>Manage Bookings</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Revenue">
                    <i class="fas fa-chart-line"></i>
                    <span>Revenue Reports</span>
                </a>
            </li>
            <li class="nav-item mt-4">
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="nav-link text-start w-100">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="main-content">
        @RenderBody()
    </div>

    <!-- Toggle Button -->
    <button class="toggle-btn" id="sidebarToggle">
        <i class="fas fa-bars"></i>
    </button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('sidebar-collapsed');
            document.getElementById('main-content').classList.toggle('main-content-collapsed');
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
