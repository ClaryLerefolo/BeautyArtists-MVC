@model List<Booking>
@{
    ViewData["Title"] = "Appointments";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";

}

<h2>My Appointments</h2>

<table class="table table-bordered table-dark table-striped">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Service</th>
            <th>Date</th>
            <th>Status</th>
            <th>Notes</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@(b.Customer?.UserName ?? b.Customer?.Email)</td>
                <td>@b.UserService?.Service?.Name</td>
                <td>@b.AppointmentDate.ToString("g")</td>
                <td>@b.Status</td>
                <td>@b.Notes</td>
                <td>
                    @if (b.Status == Booking.BookingStatus.Pending)
                    {
                        <form asp-action="UpdateBookingStatus" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@b.Id" />
                            <input type="hidden" name="newStatus" value="Confirmed" />
                            <button type="submit" class="btn btn-success btn-sm">Approve</button>
                        </form>
                        <form asp-action="UpdateBookingStatus" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@b.Id" />
                            <input type="hidden" name="newStatus" value="Cancelled" />
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">No actions</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
