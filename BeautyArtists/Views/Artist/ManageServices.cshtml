@model IEnumerable<BeautyArtists.Models.UserService>
@using System.Text.Encodings.Web
@{
    ViewData["Title"] = "Artist Service Menu";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
    var portfolioItemsByCategory = ViewBag.PortfolioItemsByCategory as Dictionary<int?, List<BeautyArtists.Models.PortfolioItem>> ?? new Dictionary<int?, List<BeautyArtists.Models.PortfolioItem>>();
    var defaultPortfolioId = ViewBag.DefaultPortfolioId as int? ?? 0;
}

@section Styles {
    <style>
        body {
            background: #000;
            color: #f0f0f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .dashboard-header {
            background: linear-gradient(90deg, #e50914, #f0c808);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            margin-bottom: 25px;
        }

            .dashboard-header h2 {
                color: #000;
                font-weight: 800;
                text-transform: uppercase;
                margin: 0;
            }

        .service-card {
            background-color: #121212;
            border: 1px solid rgba(240, 200, 8, 0.2);
            border-radius: 15px;
            transition: 0.3s ease;
        }

            .service-card:hover {
                transform: translateY(-5px);
                border-color: #f0c808;
            }

        .modal-content {
            background: #0a0a0a;
            border: 2px solid #f0c808;
            border-radius: 20px;
        }

        .form-control, .form-select {
            background-color: #1a1a1a;
            border: 1px solid #333;
            color: white;
        }

            .form-control:focus, .form-select:focus {
                background-color: #222;
                border-color: #f0c808;
                color: white;
                box-shadow: 0 0 0 0.25rem rgba(240, 200, 8, 0.25);
            }

        .input-label {
            color: #f0c808;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 5px;
        }

        .badge-active {
            background: #28a745;
            color: #fff;
        }

        .badge-inactive {
            background: #6c757d;
            color: #fff;
        }

        .service-card .card-img-top {
            height: 200px;
            object-fit: cover;
        }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
            gap: 8px;
            margin-top: 8px;
        }

        .portfolio-thumb {
            width: 100%;
            aspect-ratio: 1;
            object-fit: cover;
            border-radius: 6px;
            border: 1px solid rgba(255,215,0,0.15);
            transition: 0.2s;
            cursor: pointer;
        }

            .portfolio-thumb:hover {
                border-color: #f0c808;
                transform: scale(1.05);
            }

        .video-thumb-placeholder {
            position: relative;
            width: 100%;
            aspect-ratio: 1;
            background: #111;
            border-radius: 6px;
            border: 1px solid rgba(255,215,0,0.15);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

            .video-thumb-placeholder:hover {
                border-color: #f0c808;
            }

        .play-icon-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0,0,0,0.2);
            pointer-events: none;
        }

            .play-icon-overlay i {
                font-size: 2rem;
                color: #FFD700;
                opacity: 0.9;
                text-shadow: 0 0 20px rgba(0,0,0,0.9);
            }

        .portfolio-item-actions {
            display: flex;
            gap: 4px;
            margin-top: 4px;
        }

        .btn-sm-gold {
            background: rgba(255,215,0,0.1);
            border: 1px solid rgba(255,215,0,0.2);
            color: #FFD700;
            font-size: 0.6rem;
            padding: 2px 6px;
            border-radius: 4px;
            cursor: pointer;
        }

            .btn-sm-gold:hover {
                background: rgba(255,215,0,0.2);
            }

        .btn-sm-danger {
            background: rgba(255,0,0,0.1);
            border: 1px solid rgba(255,0,0,0.2);
            color: #ff6666;
            font-size: 0.6rem;
            padding: 2px 6px;
            border-radius: 4px;
            cursor: pointer;
        }

            .btn-sm-danger:hover {
                background: rgba(255,0,0,0.2);
            }

        .add-portfolio-btn {
            background: none;
            border: 1px dashed rgba(255,215,0,0.3);
            color: rgba(255,215,0,0.5);
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 0.7rem;
            cursor: pointer;
            transition: 0.2s;
        }

            .add-portfolio-btn:hover {
                border-color: #f0c808;
                color: #f0c808;
                background: rgba(255,215,0,0.05);
            }

        .empty-portfolio {
            color: rgba(255,255,255,0.2);
            font-size: 0.75rem;
            margin-top: 4px;
        }

        /* ── LIGHTBOX STYLES (copied from ManagePortfolio) ── */
        .lightbox-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.92);
            z-index: 9999;
            overflow: hidden;
            animation: fadeIn 0.3s ease;
        }

            .lightbox-overlay.active {
                display: flex;
                align-items: center;
                justify-content: center;
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .lightbox-container {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-close {
            position: absolute;
            top: 20px;
            right: 30px;
            background: none;
            border: none;
            color: #fff;
            font-size: 2.5rem;
            cursor: pointer;
            z-index: 100;
            transition: color 0.3s;
        }

            .lightbox-close:hover {
                color: #FFD700;
            }

        .lightbox-prev, .lightbox-next {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.08);
            border: none;
            color: #fff;
            font-size: 3rem;
            padding: 20px 12px;
            cursor: pointer;
            z-index: 100;
            transition: background 0.3s;
            border-radius: 4px;
            user-select: none;
        }

        .lightbox-prev {
            left: 20px;
        }

        .lightbox-next {
            right: 20px;
        }

            .lightbox-prev:hover, .lightbox-next:hover {
                background: rgba(255,215,0,0.2);
                color: #FFD700;
            }

        .lightbox-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            padding: 60px;
        }

        .lightbox-counter {
            color: rgba(255,255,255,0.5);
            font-size: 0.9rem;
            margin-bottom: 16px;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .lightbox-media-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            max-height: 85vh;
            overflow: hidden;
        }

        #lightboxImage {
            max-width: 90%;
            max-height: 85vh;
            object-fit: contain;
            cursor: zoom-in;
            transition: transform 0.3s ease;
        }

            #lightboxImage.zoomed {
                transform: scale(2);
                cursor: zoom-out;
            }

        #lightboxVideo {
            max-width: 90%;
            max-height: 85vh;
            border-radius: 8px;
            background: #000;
        }

        .lightbox-caption {
            color: rgba(255,255,255,0.6);
            font-size: 0.9rem;
            margin-top: 16px;
            text-align: center;
            max-width: 70%;
            line-height: 1.4;
        }

        @@media (max-width: 768px) {
            .lightbox-prev, .lightbox-next {
                font-size: 1.8rem;
                padding: 10px 8px;
            }

            .lightbox-prev {
                left: 8px;
            }

            .lightbox-next {
                right: 8px;
            }

            .lightbox-content {
                padding: 40px 20px;
            }

            .lightbox-caption {
                max-width: 90%;
                font-size: 0.8rem;
            }
        }
    </style>
}

<div class="dashboard-header">
    <h2><i class="fas fa-cut"></i> Artist Service Menu</h2>
</div>

<div class="d-flex justify-content-between align-items-center mb-4 px-4">
    <h4 class="text-white mb-0">Active Services: <span style="color: #f0c808;">@Model.Count(s => s.IsActive)</span></h4>
    <button class="btn rounded-pill px-4 py-2" data-bs-toggle="modal" data-bs-target="#addServiceModal"
            style="background: linear-gradient(45deg, #f0c808, #e50914); color: #000; font-weight: 700; border: none;">
        <i class="fas fa-plus-circle me-2"></i>+ ADD SERVICE
    </button>
</div>

<div class="row pt-2 px-4" id="serviceOfferingRow">
    @foreach (var item in Model)
    {
        var categoryId = item.Service?.CategoryId;
        var servicePortfolioItems = categoryId.HasValue && portfolioItemsByCategory.ContainsKey(categoryId.Value)
        ? portfolioItemsByCategory[categoryId.Value]
        : new List<BeautyArtists.Models.PortfolioItem>();

        <div class="col-md-4 mb-4" id="service-row-@item.Id">
            <div class="card h-100 service-card text-white overflow-hidden">
                <img src="@(string.IsNullOrEmpty(item.ImagePath) ? (item.Service?.ImagePath ?? "/images/default-service.jpg") : item.ImagePath)"
                     class="card-img-top" alt="@item.Service?.Name">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <h3 style="color: #f0c808; font-weight: 700;">@item.Service?.Name</h3>
                        <span class="badge @(item.IsActive ? "badge-active" : "badge-inactive") px-3 py-2 rounded-pill">
                            @(item.IsActive ? "ACTIVE" : "INACTIVE")
                        </span>
                    </div>
                    <p class="text-muted small">@item.CustomDescription</p>
                    <div class="p-3 rounded mb-3" style="background: #1a1a1a;">
                        <div class="small mb-1"><span style="color:#f0c808">Category:</span> @(item.Service?.ServiceCategory?.Name ?? "General")</div>
                        <div class="small mb-1"><span style="color:#f0c808">Duration:</span> @item.Duration min</div>
                        <div class="h5 mt-2 mb-0 font-weight-bold" style="color:#f0c808">Price: R @item.Price.ToString("N2")</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-warning flex-grow-1 font-weight-bold"
                                onclick="openEditModal('@item.Id', '@item.Price', '@item.Duration', '@Html.Raw(JavaScriptEncoder.Default.Encode(item.CustomDescription ?? ""))', @item.IsActive.ToString().ToLower())">
                            <i class="fas fa-edit me-1"></i> EDIT
                        </button>
                        <button class="btn btn-danger delete-service" data-id="@item.Id">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>

                    @* ── PORTFOLIO INTEGRATION (with video support and lightbox) ── *@
                    <div class="mt-3 pt-3 border-top border-secondary">
                        <div class="d-flex justify-content-between align-items-center">
                            <span style="color:rgba(255,255,255,0.5);font-size:0.8rem;">
                                <i class="bi bi-images me-1"></i> Portfolio
                            </span>
                            <button class="add-portfolio-btn" onclick="openAddPortfolioItem(@categoryId, @defaultPortfolioId)">
                                <i class="bi bi-plus-circle me-1"></i> Add Item
                            </button>
                        </div>
                        @if (servicePortfolioItems.Any())
                        {
                            <div class="portfolio-grid">
                                @foreach (var pItem in servicePortfolioItems)
                                {
                                    var isVideo = !string.IsNullOrEmpty(pItem.MediaType) && pItem.MediaType.Equals("Video", StringComparison.OrdinalIgnoreCase);
                                    var thumbnailUrl = !string.IsNullOrEmpty(pItem.ThumbnailUrl) ? pItem.ThumbnailUrl : (isVideo ? "" : pItem.MediaUrl);
                                    var mediaUrl = pItem.MediaUrl;
                                    var title = pItem.Title ?? "Untitled";
                                    var description = pItem.Description ?? "";
                                    <div class="portfolio-item-wrapper">
                                        @if (isVideo && string.IsNullOrEmpty(pItem.ThumbnailUrl))
                                        {
                                            <div class="video-thumb-placeholder"
                                                 data-mediaurl="@mediaUrl"
                                                 data-title="@title"
                                                 data-description="@description"
                                                 data-mediatype="video"
                                                 onclick="openLightbox(this)">
                                                <i class="bi bi-play-circle-fill" style="font-size:2rem;color:#FFD700;opacity:0.7;"></i>
                                                <span style="color:rgba(255,255,255,0.2);font-size:0.5rem;margin-top:4px;">Video</span>
                                            </div>
                                        }
                                        else if (!string.IsNullOrEmpty(thumbnailUrl))
                                        {
                                            <img src="@Url.Content(thumbnailUrl)"
                                                 class="portfolio-thumb" alt="@title"
                                                 data-mediaurl="@mediaUrl"
                                                 data-title="@title"
                                                 data-description="@description"
                                                 data-mediatype="image"
                                                 onclick="openLightbox(this)" />
                                        }
                                        else
                                        {
                                            <div style="width:100%;aspect-ratio:1;background:#111;border-radius:6px;border:1px solid rgba(255,215,0,0.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.2);font-size:0.6rem;">No media</div>
                                        }
                                        <div class="portfolio-item-actions">
                                            <button class="btn-sm-gold" onclick="event.stopPropagation(); location.href='@Url.Action("EditPortfolioItem", "PortfolioItem", new { id = pItem.Id })'">Edit</button>
                                            <button class="btn-sm-danger" onclick="event.stopPropagation(); deletePortfolioItem(@pItem.Id)">🗑️</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-portfolio">No portfolio items yet.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* ── ADD SERVICE MODAL (unchanged) ── *@
<div class="modal fade" id="addServiceModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title font-weight-bold" style="color: #f0c808;">ADD NEW SERVICE</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Artist" asp-action="AddService" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4">
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="input-label">Select Service Template</label>
                            <select name="ServiceId" id="baseServiceSelect" class="form-select" required>
                                <option value="">-- Choose a Service --</option>
                                @foreach (var svc in (IEnumerable<SelectListItem>)ViewBag.AvailableServices)
                                {
                                    <option value="@svc.Value">@svc.Text</option>
                                }
                            </select>
                        </div>

                        <div id="adminDetailsSection" style="display:none; margin-bottom: 20px; width: 100%;">
                            <div style="background: rgba(229, 9, 20, 0.1); border-left: 4px solid #e50914; padding: 15px; border-radius: 4px;">
                                <div class="row">
                                    <div class="col-md-4"><small class="text-muted d-block">Admin Category</small><strong id="adminCategory" style="color: #f0c808;"></strong></div>
                                    <div class="col-md-4"><small class="text-muted d-block">Base Price</small><strong id="adminBasePrice" style="color: #f0c808;"></strong></div>
                                    <div class="col-md-4"><small class="text-muted d-block">Standard Duration</small><strong id="adminBaseDuration" style="color: #f0c808;"></strong></div>
                                </div>
                                <div class="mt-2">
                                    <small class="text-muted d-block">Admin Description:</small>
                                    <p id="adminBaseDescription" class="small mb-0" style="font-style: italic;"></p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="input-label">Your Price (R)</label>
                            <input type="number" name="Price" id="add_Price" class="form-control" step="0.01" required />
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">Your Duration (Mins)</label>
                            <input type="number" name="Duration" id="add_Duration" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="input-label">Service Photo (Optional)</label>
                            <input type="file" name="ImageFile" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="input-label">Custom Description</label>
                            <textarea name="CustomDescription" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked>
                                <label class="form-check-label text-white ms-2">Make Service Active Immediately</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="submit" class="btn w-100 py-3 font-weight-bold" style="background: #f0c808; color: #000;">+ ADD TO MENU</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── EDIT SERVICE MODAL (unchanged) ── *@
<div class="modal fade" id="editServiceModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title font-weight-bold" style="color: #f0c808;">EDIT YOUR SERVICE</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Artist" asp-action="EditUserService" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="edit_Id" />

                <div class="modal-body px-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="input-label">Your Price (R)</label>
                            <input type="number" name="Price" id="edit_Price" class="form-control" step="0.01" required />
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">Your Duration (Mins)</label>
                            <input type="number" name="Duration" id="edit_Duration" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="input-label">Change Photo (Optional)</label>
                            <input type="file" name="ImageFile" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="input-label">Custom Description</label>
                            <textarea name="CustomDescription" id="edit_Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="IsActive" id="edit_IsActive" value="true">
                                <label class="form-check-label text-white ms-2">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="submit" class="btn w-100 py-3 font-weight-bold" style="background: #f0c808; color: #000;">UPDATE SERVICE</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── ADD PORTFOLIO ITEM MODAL (unchanged) ── *@
<div class="modal fade" id="addPortfolioItemModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title font-weight-bold" style="color: #f0c808;">ADD PORTFOLIO ITEM</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Portfolio" asp-action="CreatePortfolioItem" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PortfolioId" id="addPortfolio_PortfolioId" value="@defaultPortfolioId" />
                <input type="hidden" name="CategoryId" id="addPortfolio_CategoryId" />
                <div class="modal-body px-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="input-label">Title <span class="text-danger">*</span></label>
                            <input name="Title" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">Display Order</label>
                            <input type="number" name="DisplayOrder" class="form-control" value="0" />
                        </div>
                        <div class="col-12">
                            <label class="input-label">Description</label>
                            <textarea name="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="input-label">Media File <span class="text-danger">*</span></label>
                            <input type="file" name="MediaFile" class="form-control" accept="image/*,video/*" required />
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">Province</label>
                            <select name="Province" class="form-select">
                                <option value="">Select</option>
                                <option value="Gauteng">Gauteng</option>
                                <option value="Western Cape">Western Cape</option>
                                <option value="KwaZulu-Natal">KwaZulu-Natal</option>
                                <option value="Eastern Cape">Eastern Cape</option>
                                <option value="Free State">Free State</option>
                                <option value="Limpopo">Limpopo</option>
                                <option value="Mpumalanga">Mpumalanga</option>
                                <option value="North West">North West</option>
                                <option value="Northern Cape">Northern Cape</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">City</label>
                            <input name="City" class="form-control" placeholder="e.g. Johannesburg" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="submit" class="btn w-100 py-3 font-weight-bold" style="background: #f0c808; color: #000;">ADD TO PORTFOLIO</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── LIGHTBOX OVERLAY (copied from ManagePortfolio) ── *@
<div id="lightbox" class="lightbox-overlay" onclick="closeLightbox(event)">
    <div class="lightbox-container">
        <button class="lightbox-close" onclick="closeLightbox()">&times;</button>
        <button class="lightbox-prev" onclick="navigateLightbox(-1)">&#10094;</button>
        <button class="lightbox-next" onclick="navigateLightbox(1)">&#10095;</button>
        <div class="lightbox-content">
            <div class="lightbox-counter" id="lightboxCounter"></div>
            <div id="lightboxMediaContainer" class="lightbox-media-container">
                <img id="lightboxImage" src="" alt="" style="display:none;max-width:90%;max-height:80vh;object-fit:contain;" />
                <video id="lightboxVideo" controls style="display:none;max-width:90%;max-height:80vh;" controlsList="nodownload">
                    <source id="videoSource" src="" type="video/mp4" />
                    Your browser does not support the video tag.
                </video>
            </div>
            <div class="lightbox-caption" id="lightboxCaption"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const rawServices = @Html.Raw(Json.Serialize(ViewBag.RawServices));

        // ── Add Service: auto-fill ──
        document.getElementById('baseServiceSelect').addEventListener('change', function() {
            const s = rawServices.find(x => (x.id || x.Id) == this.value);
            if (s) {
                const category = s.serviceCategory || s.ServiceCategory;
                $('#adminCategory').text(category ? (category.name || category.Name) : "N/A");
                $('#adminBasePrice').text('R ' + parseFloat(s.basePrice || s.BasePrice).toFixed(2));
                $('#adminBaseDuration').text((s.duration || s.Duration) + ' Mins');
                $('#adminBaseDescription').text(s.description || s.Description);
                $('#adminDetailsSection').fadeIn();
                document.getElementById('add_Price').value = s.basePrice || s.BasePrice;
                document.getElementById('add_Duration').value = s.duration || s.Duration;
            } else {
                $('#adminDetailsSection').fadeOut();
            }
        });

        // ── Edit Service Modal ──
        function openEditModal(id, price, duration, desc, isActive) {
            document.getElementById('edit_Id').value = id;
            document.getElementById('edit_Price').value = price;
            document.getElementById('edit_Duration').value = duration;
            document.getElementById('edit_Description').value = desc;
            document.getElementById('edit_IsActive').checked = (isActive === true || isActive === "true");
            var myModal = new bootstrap.Modal(document.getElementById('editServiceModal'));
            myModal.show();
        }

        // ── Delete Service ──
        $(document).on('click', '.delete-service', function() {
            const id = $(this).data('id');
            const card = $(`#service-row-${id}`);
            Swal.fire({
                title: 'Remove Service?',
                text: "This will remove it from your menu.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e50914',
                confirmButtonText: 'Yes, remove it',
                background: '#0a0a0a',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Artist/DeleteUserService/' + id, {
                        "__RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                    }, function() {
                        card.fadeOut(500);
                        Swal.fire('Removed!', '', 'success');
                    });
                }
            });
        });

        // ── Open Add Portfolio Item Modal ──
        function openAddPortfolioItem(categoryId, portfolioId) {
            document.getElementById('addPortfolio_CategoryId').value = categoryId;
            document.getElementById('addPortfolio_PortfolioId').value = portfolioId;
            var modal = new bootstrap.Modal(document.getElementById('addPortfolioItemModal'));
            modal.show();
        }

        // ── Delete Portfolio Item (AJAX) ──
        function deletePortfolioItem(id) {
            Swal.fire({
                title: 'Delete this item?',
                text: "This action cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e50914',
                confirmButtonText: 'Yes, delete',
                background: '#0a0a0a',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/PortfolioItem/DeleteItem/' + id,
                        type: 'POST',
                        data: { "__RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                        success: function (response) {
                            if (response.success) {
                                var el = $(`.btn-sm-danger[onclick*="deletePortfolioItem(${id})"]`).closest('.portfolio-item-wrapper');
                                el.remove();
                                var grid = el.closest('.portfolio-grid');
                                if (grid.find('.portfolio-item-wrapper').length === 0) {
                                    grid.after('<div class="empty-portfolio">No portfolio items yet.</div>');
                                    grid.remove();
                                }
                                Swal.fire('Deleted!', '', 'success');
                            } else {
                                Swal.fire('Error', response.message || 'Delete failed', 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Error', 'Could not delete.', 'error');
                        }
                    });
                }
            });
        }

        // ── LIGHTBOX LOGIC (copied from ManagePortfolio) ──
        let mediaItems = [];
        let currentIndex = 0;
        let isZoomed = false;

        function initializeLightbox() {
            const thumbnails = document.querySelectorAll('.portfolio-thumb, .video-thumb-placeholder');
            mediaItems = [];
            thumbnails.forEach(el => {
                const mediaUrl = el.getAttribute('data-mediaurl');
                const title = el.getAttribute('data-title') || '';
                const description = el.getAttribute('data-description') || '';
                const mediaType = el.getAttribute('data-mediatype') || 'image';
                if (mediaUrl) {
                    mediaItems.push({ url: mediaUrl, title: title, description: description, type: mediaType });
                }
            });
        }

        window.openLightbox = function(element) {
            const thumbnails = document.querySelectorAll('.portfolio-thumb, .video-thumb-placeholder');
            const index = Array.from(thumbnails).indexOf(element);
            if (index === -1) return;
            initializeLightbox();
            currentIndex = index;
            showMedia(currentIndex);
            document.getElementById('lightbox').classList.add('active');
            document.body.style.overflow = 'hidden';
            isZoomed = false;
        };

        function showMedia(index) {
            const item = mediaItems[index];
            if (!item) return;
            const imageEl = document.getElementById('lightboxImage');
            const videoEl = document.getElementById('lightboxVideo');
            const videoSource = document.getElementById('videoSource');
            const captionEl = document.getElementById('lightboxCaption');
            const counterEl = document.getElementById('lightboxCounter');
            imageEl.classList.remove('zoomed');
            isZoomed = false;
            counterEl.textContent = `${index + 1} / ${mediaItems.length}`;
            let captionText = item.title;
            if (item.description && item.description !== item.title) {
                captionText += item.description ? ` — ${item.description}` : '';
            }
            captionEl.textContent = captionText;
            if (item.type === 'video') {
                imageEl.style.display = 'none';
                videoEl.style.display = 'block';
                videoSource.src = item.url;
                videoEl.load();
                videoEl.play().catch(() => {});
            } else {
                videoEl.style.display = 'none';
                videoEl.pause();
                imageEl.style.display = 'block';
                imageEl.src = item.url;
                imageEl.alt = item.title || 'Portfolio image';
            }
        }

        window.navigateLightbox = function(direction) {
            currentIndex = (currentIndex + direction + mediaItems.length) % mediaItems.length;
            showMedia(currentIndex);
        };

        window.closeLightbox = function(event) {
            if (event && event.target !== event.currentTarget) return;
            document.getElementById('lightbox').classList.remove('active');
            document.body.style.overflow = '';
            const video = document.getElementById('lightboxVideo');
            video.pause();
            isZoomed = false;
        };

        document.getElementById('lightboxImage').addEventListener('click', function() {
            isZoomed = !isZoomed;
            this.classList.toggle('zoomed');
        });

        document.addEventListener('keydown', function(e) {
            const lightbox = document.getElementById('lightbox');
            if (!lightbox.classList.contains('active')) return;
            if (e.key === 'Escape') closeLightbox();
            else if (e.key === 'ArrowLeft') { navigateLightbox(-1); e.preventDefault(); }
            else if (e.key === 'ArrowRight') { navigateLightbox(1); e.preventDefault(); }
        });
    </script>
}