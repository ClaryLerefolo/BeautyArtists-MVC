@model IEnumerable<BeautyArtists.Models.Booking>
@using static BeautyArtists.Models.Booking

@{
    ViewData["Title"] = "My Appointments";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

@section Styles {
    <style>
        body {
            background: #000;
            color: #f0f0f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .dashboard-header {
            background: linear-gradient(90deg, #e50914, #f0c808);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            margin-bottom: 25px;
        }

            .dashboard-header h2 {
                color: #000;
                font-weight: 800;
                text-transform: uppercase;
                margin: 0;
            }

        .appointment-card {
            background-color: #121212;
            border: 1px solid rgba(240, 200, 8, 0.2);
            border-radius: 15px;
            transition: 0.3s ease;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

            .appointment-card:hover {
                transform: translateY(-5px);
                border-color: #f0c808;
                box-shadow: 0 10px 20px rgba(240, 200, 8, 0.1);
            }

        .status-badge {
            padding: 5px 15px;
            border-radius: 50px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            white-space: nowrap;
        }

        .bg-pending {
            background-color: #f0c808 !important;
            color: #000 !important;
        }

        .bg-accepted {
            background-color: #17a2b8 !important;
            color: #fff !important;
        }

        .bg-confirmed {
            background-color: #28a745 !important;
            color: #fff !important;
        }

        .bg-completed {
            background-color: #007bff !important;
            color: #fff !important;
        }

        .bg-cancelled {
            background-color: #e50914 !important;
            color: #fff !important;
        }

        .bg-rejected {
            background-color: #6c757d !important;
            color: #fff !important;
        }

        .client-info-box {
            background: #1a1a1a;
            border-left: 4px solid #f0c808;
            padding: 15px;
            border-radius: 4px;
        }

        .type-indicator {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 3px 10px;
            border-radius: 4px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .type-walkin {
            background: rgba(52, 152, 219, 0.15);
            color: #3498db;
            border: 1px solid rgba(52, 152, 219, 0.3);
        }

        .type-housecall {
            background: rgba(155, 89, 182, 0.15);
            color: #9b59b6;
            border: 1px solid rgba(155, 89, 182, 0.3);
        }

        .financial-row {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 8px;
            padding: 10px;
        }

        .map-btn {
            background: #1e1e1e;
            border: 1px solid #444;
            color: #00ffcc;
            font-size: 0.75rem;
            transition: all 0.2s;
        }

            .map-btn:hover {
                background: #00ffcc;
                color: #000;
            }

        /* New footer styling */
        .card-footer-actions {
            border-top: 1px solid rgba(255,255,255,0.08);
            padding-top: 1rem;
            margin-top: auto;
        }

        .booked-date {
            font-size: 0.75rem;
            color: #6c757d;
            text-align: center;
            padding-top: 0.5rem;
            margin-top: 0.5rem;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
    </style>
}

<div class="dashboard-header">
    <h2><i class="fas fa-calendar-check"></i> MY APPOINTMENTS</h2>
</div>

<div class="container-fluid px-4">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card appointment-card text-white">
                    <!-- CARD HEADER -->
                    <div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center pt-4 px-4">
                        <div class="text-muted small">
                            <i class="far fa-clock me-1"></i> @item.AppointmentDate.ToString("MMM dd, yyyy @ HH:mm")
                        </div>
                        <span class="status-badge bg-@(item.Status.ToString().ToLower())">
                            @if (item.Status == BookingStatus.Accepted)
                            {
                                @:ACCEPTED (AWAITING DEPOSIT)
                            }
                            else
                            {
                                @item.Status
                            }
                        </span>
                    </div>

                    <!-- CARD BODY -->
                    <div class="card-body p-4 d-flex flex-column">
                        <!-- CLIENT & SERVICE INFO -->
                        <div>
                            <div class="client-info-box mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h5 class="mb-0" style="color: #f0c808;">@item.Customer?.FirstName @item.Customer?.LastName</h5>
                                    @if (item.SelectedLocationType == BeautyArtists.Models.LocationType.HouseCall)
                                    {
                                        <span class="type-indicator type-housecall">🏠 House Call</span>
                                    }
                                    else
                                    {
                                        <span class="type-indicator type-walkin">💈 Walk-In</span>
                                    }
                                </div>
                                <div class="small text-white-50">@item.UserService?.Service?.Name</div>
                            </div>

                            <!-- MAPS & ADDRESS (HouseCall) -->
                            @if (item.SelectedLocationType == BeautyArtists.Models.LocationType.HouseCall && !string.IsNullOrEmpty(item.HouseCallAddress))
                            {
                                <div class="p-3 mb-3 rounded border border-secondary" style="background: rgba(155, 89, 182, 0.05);">
                                    <small class="text-muted text-uppercase d-block mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">Client Location:</small>
                                    <p class="small text-white-50 mb-2"><i class="fas fa-map-marker-alt text-danger me-1"></i> @item.HouseCallAddress</p>
                                    @if (!string.IsNullOrEmpty(item.Latitude) && !string.IsNullOrEmpty(item.Longitude))
                                    {
                                        <a href="https://www.google.com/maps/search/?api=1&query=@item.Latitude,@item.Longitude"
                                           target="_blank" class="btn btn-sm map-btn w-100 fw-bold rounded-2 shadow-sm text-center">
                                            <i class="fas fa-route me-1"></i> OPEN IN GOOGLE MAPS
                                        </a>
                                    }
                                </div>
                            }

                            <!-- NOTES -->
                            @if (!string.IsNullOrEmpty(item.Notes))
                            {
                                <div class="mb-3">
                                    <small class="text-muted d-block text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">Initial Client Notes:</small>
                                    <p class="small mb-0" style="color: #ddd;">@item.Notes</p>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(item.ArtistNotes))
                            {
                                <div class="note-box mb-3 p-2 rounded" style="background: rgba(241, 196, 15, 0.05); border: 1px dashed rgba(241, 196, 15, 0.2);">
                                    <small class="text-warning d-block text-uppercase" style="font-size: 0.6rem; font-weight: bold;">Your Note to Client:</small>
                                    <span class="small" style="font-style: italic; color: #eee;">"@item.ArtistNotes"</span>
                                </div>
                            }

                            <!-- DURATION & BASE PRICE -->
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">Duration</small>
                                    <strong>@item.UserService?.Duration mins</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Base Price</small>
                                    <strong style="color: #ddd;">R @(item.UserService?.Price.ToString("N2") ?? "0.00")</strong>
                                </div>
                            </div>
                        </div>

                        <!-- FINANCIAL ROW (always visible) -->
                        <div class="financial-row small mb-3">
                            @if (item.SelectedLocationType == BeautyArtists.Models.LocationType.HouseCall)
                            {
                                <div class="d-flex justify-content-between text-white-50 mb-1">
                                    <span>Transport Costs:</span>
                                    <span>R @item.TransportCost.ToString("N2")</span>
                                </div>
                            }
                            <div class="d-flex justify-content-between font-weight-bold border-top border-secondary pt-1">
                                <span style="color: #f0c808;">Total Amount:</span>
                                <span style="color: #f0c808; font-weight: bold;">R @item.TotalAmount.ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-2 pt-1 border-top border-secondary" style="font-size: 0.7rem;">
                                <span class="text-muted">Deposit Status (50%):</span>
                                @if (item.IsDepositPaid)
                                {
                                    <span class="text-success fw-bold"><i class="fas fa-check-circle me-1"></i> PAID</span>
                                }
                                else
                                {
                                    <span class="text-warning fw-bold"><i class="fas fa-hourglass-half me-1"></i> AWAITING</span>
                                }
                            </div>
                        </div>

                        <!-- ===== FOOTER WITH ACTION BUTTONS & BOOKED DATE ===== -->
                        <div class="card-footer-actions">
                            @if (item.Status == BookingStatus.Pending)
                            {
                                <!-- PENDING: Show transport input & note -->
                                <div class="mb-2">
                                    @if (item.SelectedLocationType == BeautyArtists.Models.LocationType.HouseCall)
                                    {
                                        <div class="mb-2">
                                            <small class="text-muted d-block text-uppercase mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">Set Transport Fee (R):</small>
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-dark border-secondary text-white-50">R</span>
                                                <input type="number" id="transport-@item.Id" class="form-control bg-dark text-white border-secondary"
                                                       placeholder="0.00" step="0.01" min="0" value="@(item.TransportCost > 0 ? item.TransportCost.ToString("F2") : "")" />
                                            </div>
                                        </div>
                                    }
                                    <input type="text" id="note-@item.Id" class="form-control bg-dark text-white border-secondary"
                                           placeholder="Add a note for the client..." style="font-size: 0.8rem;" />
                                </div>

                                <!-- Action buttons side by side -->
                                <div class="d-flex gap-2">
                                    <form asp-action="ArtistUpdateStatus" method="post" class="flex-fill">
                                        <input type="hidden" name="bookingId" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="@BookingStatus.Accepted" />
                                        <input type="hidden" name="artistNotes" id="confirm-note-@item.Id" />
                                        <input type="hidden" name="transportCost" id="confirm-transport-@item.Id" value="0" />
                                        <button type="submit" class="btn btn-success w-100 fw-bold"
                                                onclick="document.getElementById('confirm-note-@item.Id').value = document.getElementById('note-@item.Id').value;
                                                                 var tInput = document.getElementById('transport-@item.Id');
                                                                 if(tInput) { document.getElementById('confirm-transport-@item.Id').value = tInput.value || 0; }">
                                            <i class="fas fa-check me-1"></i> ACCEPT
                                        </button>
                                    </form>
                                    <form asp-action="ArtistUpdateStatus" method="post" class="flex-fill">
                                        <input type="hidden" name="bookingId" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="@BookingStatus.Rejected" />
                                        <input type="hidden" name="artistNotes" id="reject-note-@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger w-100 fw-bold"
                                                onclick="document.getElementById('reject-note-@item.Id').value = document.getElementById('note-@item.Id').value">
                                            <i class="fas fa-times me-1"></i> REJECT
                                        </button>
                                    </form>
                                </div>
                            }
                            else if (item.Status == BookingStatus.Accepted)
                            {
                                <!-- ACCEPTED: Waiting for deposit -->
                                <div class="alert alert-info text-center mb-0" style="background: rgba(23, 162, 184, 0.15); border: 1px solid #17a2b8; color: #17a2b8;">
                                    <i class="fas fa-clock me-2"></i> Awaiting client's 50% deposit...
                                </div>
                            }
                            else if (item.Status == BookingStatus.Confirmed)
                            {
                                <!-- CONFIRMED: Mark as completed -->
                                <form asp-action="ArtistUpdateStatus" method="post">
                                    <input type="hidden" name="bookingId" value="@item.Id" />
                                    <input type="hidden" name="newStatus" value="@BookingStatus.Completed" />
                                    <button type="submit" class="btn btn-primary w-100 fw-bold">
                                        <i class="fas fa-check-double me-2"></i> MARK COMPLETED
                                    </button>
                                </form>
                            }

                            <!-- BOOKED DATE (like the client view) -->
                            <div class="booked-date">
                                <i class="far fa-calendar-alt me-1"></i> Booked @item.BookingDate.ToString("dd MMM yyyy")
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <h3 class="text-muted">No appointments yet.</h3>
    </div>
}