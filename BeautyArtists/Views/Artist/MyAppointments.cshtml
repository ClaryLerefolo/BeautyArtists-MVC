@model IEnumerable<BeautyArtists.Models.Booking>
@using static BeautyArtists.Models.Booking
@{
    ViewData["Title"] = "My Appointments";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

@section Styles {
    <style>

        .bg-rejected {
            background-color: #6c757d !important; /* Gray for rejected */
            color: #fff !important;
        }

        .bg-completed {
            background-color: #007bff !important; /* Blue for finished */
            color: #fff !important;
        }

        /* Ensure buttons look premium */
        .btn-success {
            background-color: #28a745;
            border: none;
        }

        .btn-primary {
            background-color: #007bff;
            border: none;
        }
        body {
            background: #000;
            color: #f0f0f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .dashboard-header {
            background: linear-gradient(90deg, #e50914, #f0c808);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            margin-bottom: 25px;
        }

            .dashboard-header h2 {
                color: #000;
                font-weight: 800;
                text-transform: uppercase;
                margin: 0;
            }

        .appointment-card {
            background-color: #121212;
            border: 1px solid rgba(240, 200, 8, 0.2);
            border-radius: 15px;
            transition: 0.3s ease;
            overflow: hidden;
        }

            .appointment-card:hover {
                transform: translateY(-5px);
                border-color: #f0c808;
                box-shadow: 0 10px 20px rgba(240, 200, 8, 0.1);
            }

        .status-badge {
            padding: 5px 15px;
            border-radius: 50px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
        }

        .bg-pending {
            background-color: #f0c808;
            color: #000;
        }

        .bg-confirmed {
            background-color: #28a745;
            color: #fff;
        }

        .bg-completed {
            background-color: #007bff;
            color: #fff;
        }

        .bg-cancelled {
            background-color: #e50914;
            color: #fff;
        }

        .client-info-box {
            background: #1a1a1a;
            border-left: 4px solid #f0c808;
            padding: 15px;
            border-radius: 4px;
        }
    </style>
}
<div class="dashboard-header">
    <h2><i class="fas fa-calendar-check"></i> My Appointments</h2>
</div>

<div class="container-fluid px-4">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card h-100 appointment-card text-white">
                    <div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center pt-4 px-4">
                        <div class="text-muted small">
                            <i class="far fa-clock me-1"></i> @item.AppointmentDate.ToString("MMM dd, yyyy @ HH:mm")
                        </div>
                        <span class="status-badge bg-@item.Status.ToString().ToLower()">@item.Status</span>
                    </div>

                    <div class="card-body p-4">
                        <div class="client-info-box mb-3">
                            <h5 class="mb-1" style="color: #f0c808;">@item.Customer?.FirstName @item.Customer?.LastName</h5>
                            <div class="small text-white-50">@item.UserService?.Service?.Name</div>
                        </div>

                        @* --- CLIENT BOOKING NOTES (The stuff they outlined when booking) --- *@
                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <div class="mb-3">
                                <small class="text-muted d-block text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">Initial Client Notes:</small>
                                <p class="small mb-0" style="color: #ddd;">@item.Notes</p>
                            </div>
                        }

                        <div class="row g-2 mb-4">
                            <div class="col-6">
                                <small class="text-muted d-block">Duration</small>
                                <strong>@item.UserService?.Duration mins</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Price</small>
                                <strong style="color: #f0c808;">R @item.TotalAmount.ToString("N2")</strong>
                            </div>
                        </div>

                        @if (item.Status == BookingStatus.Pending)
                        {
                            <div class="mt-3">
                                <input type="text" id="note-@item.Id" class="form-control bg-dark text-white border-secondary mb-2" placeholder="Add a note for the client..." style="font-size: 0.8rem;" />
                                <div class="d-flex gap-2">
                                    <form asp-action="ArtistUpdateStatus" method="post" class="flex-grow-1">
                                        <input type="hidden" name="bookingId" value="@item.Id" />
                                        <input type="hidden" name="artistNotes" id="confirm-note-@item.Id" />
                                        <button type="submit" name="newStatus" value="@BookingStatus.Confirmed" onclick="document.getElementById('confirm-note-@item.Id').value = document.getElementById('note-@item.Id').value" class="btn btn-success w-100 font-weight-bold">CONFIRM</button>
                                    </form>
                                    <form asp-action="ArtistUpdateStatus" method="post" class="flex-grow-1">
                                        <input type="hidden" name="bookingId" value="@item.Id" />
                                        <input type="hidden" name="artistNotes" id="reject-note-@item.Id" />
                                        <button type="submit" name="newStatus" value="@BookingStatus.Rejected" onclick="document.getElementById('reject-note-@item.Id').value = document.getElementById('note-@item.Id').value" class="btn btn-outline-danger w-100 font-weight-bold">REJECT</button>
                                    </form>
                                </div>
                            </div>
                        }
                        @if (item.Status == BookingStatus.Confirmed)
                        {
                            <div class="mt-3">
                                <form asp-action="ArtistUpdateStatus" method="post">
                                    <input type="hidden" name="bookingId" value="@item.Id" />
                                    @* We send the Completed status to the same controller action *@
                                    <input type="hidden" name="newStatus" value="@BookingStatus.Completed" />

                                    <button type="submit" class="btn btn-primary w-100 font-weight-bold shadow-sm">
                                        <i class="fas fa-check-double me-2"></i> MARK AS COMPLETED
                                    </button>
                                </form>
                                <p class="text-center small text-white-50 mt-2" style="font-size: 0.7rem;">
                                    Click this once the service is finished to finalize earnings.
                                </p>
                            </div>
                        }

                        @* --- CLIENT CANCELLATION/RESCHEDULE NOTES --- *@
                        @if (!string.IsNullOrEmpty(item.ClientNotes))
                        {
                            <div class="note-box">
                                <small class="text-warning d-block text-uppercase" style="font-size: 0.6rem; font-weight: bold;">Update Message:</small>
                                <span class="small" style="font-style: italic;">"@item.ClientNotes"</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>