@model IEnumerable<BeautyArtists.Models.Booking>

@{
    ViewData["Title"] = "My Appointments";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

<div class="dashboard-header">
    <h2><i class="bi bi-calendar-event-fill"></i> MY APPOINTMENTS</h2>
</div>

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            ✅ @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            ❌ @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h3 class="text-muted">No appointments yet.</h3>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var booking in Model.OrderByDescending(b => b.AppointmentDate))
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card availability-card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title" style="color: #f0c808;">@booking.UserService?.Service?.Name</h5>
                                <span class="badge @(booking.Status == BeautyArtists.Models.Booking.BookingStatus.Pending ? "bg-warning" :
                                                                                         booking.Status == BeautyArtists.Models.Booking.BookingStatus.Confirmed ? "bg-success" :
                                                                                         booking.Status == BeautyArtists.Models.Booking.BookingStatus.Completed ? "bg-info" : "bg-danger")">
                            @booking.Status
                        </span>
                    </div>

                            <p><strong>Client:</strong> @booking.Customer?.FirstName @booking.Customer?.LastName</p>
                            <p><strong>Date:</strong> @booking.AppointmentDate.ToString("MMM dd, yyyy")</p>
                            <p><strong>Time:</strong> @booking.AppointmentDate.ToString("hh:mm tt")</p>
                            <p><strong>Location Type:</strong> @(booking.SelectedLocationType == LocationType.HouseCall ? "🏠 House Call" : "🏢 Walk-In")</p>

                    @if (booking.SelectedLocationType == LocationType.HouseCall)
                            {
                                <hr />
                                <p><strong>📍 Client Address:</strong></p>
                                <p class="small bg-dark p-2 rounded">@booking.HouseCallAddress</p>

                                @if (!string.IsNullOrEmpty(booking.Latitude) && !string.IsNullOrEmpty(booking.Longitude))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-info mb-2" onclick="openMap(@booking.Latitude, @booking.Longitude)">
                                        🗺️ View on Map
                                    </button>
                                }

                                <hr />
                                <p><strong>💰 Pricing:</strong></p>
                                <p>Base Price: <strong>R @booking.UserService?.Price.ToString("N0")</strong></p>

                                @if (booking.TransportCost > 0)
                                {
                                    <p>Transport Cost: <strong class="text-warning">R @booking.TransportCost.ToString("N0")</strong></p>
                                    <p>Total Amount: <strong class="text-success">R @booking.TotalAmount.ToString("N0")</strong></p>
                                }
                                else
                                {
                                    <p>Transport Cost: <strong class="text-muted">Not set yet</strong></p>
                                    <p>Total Amount: <strong>R @booking.UserService?.Price.ToString("N0")</strong></p>
                                }

                                <!-- TRANSPORT COST INPUT - ONLY SHOW FOR PENDING BOOKINGS -->
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Pending)
                                {
                                    <hr />
                                    <div class="transport-cost-section mt-3">
                                        <label class="form-label text-warning">✈️ Add Transport Cost:</label>
                                        <div class="input-group">
                                            <span class="input-group-text">R</span>
                                            <input type="number" id="transportCost_@booking.Id" class="form-control"
                                                   placeholder="Enter amount" step="0.01" min="0" />
                                            <button type="button" class="btn btn-warning" onclick="submitTransportCost(@booking.Id)">
                                                Apply Cost
                                            </button>
                                        </div>
                                        <small class="text-muted">Enter transport cost to travel to client's location</small>
                                    </div>
                                }
                            }

                            <hr />
                            <div class="mt-3">
                                @if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Pending)
                                {
                                    <button class="btn btn-success btn-sm" onclick="updateStatus(@booking.Id, 'Confirmed')">
                                        ✅ Confirm
                                    </button>
                                    <button class="btn btn-danger btn-sm" onclick="updateStatus(@booking.Id, 'Rejected')">
                                        ❌ Reject
                                    </button>
                                }
                                else if (booking.Status == BeautyArtists.Models.Booking.BookingStatus.Confirmed)
                                {
                                    <button class="btn btn-info btn-sm" onclick="updateStatus(@booking.Id, 'Completed')">
                                        ✔️ Mark Complete
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Map Modal -->
<div class="modal fade" id="mapModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="background: #0a0a0a;">
            <div class="modal-header border-0">
                <h5 class="modal-title" style="color: #f0c808;">Client Location</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="clientMap" style="height: 400px;"></div>
            </div>
        </div>
    </div>
</div>

<!-- Leaflet CSS and JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

@section Scripts {
    <script>
        let currentMap = null;

        // Open map with client location
        function openMap(lat, lng) {
            const mapModal = new bootstrap.Modal(document.getElementById('mapModal'));
            mapModal.show();

            setTimeout(() => {
                if (currentMap) {
                    currentMap.remove();
                }
                currentMap = L.map('clientMap').setView([parseFloat(lat), parseFloat(lng)], 15);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap'
                }).addTo(currentMap);
                L.marker([parseFloat(lat), parseFloat(lng)]).addTo(currentMap)
                    .bindPopup('Client Location')
                    .openPopup();
                currentMap.invalidateSize();
            }, 100);
        }

        // Submit transport cost
        async function submitTransportCost(bookingId) {
            const transportInput = document.getElementById(`transportCost_${bookingId}`);
            const transportCost = parseFloat(transportInput.value);

            if (isNaN(transportCost) || transportCost < 0) {
                alert('Please enter a valid transport cost amount');
                return;
            }

            if (!confirm(`Add R${transportCost} transport cost to this booking?`)) {
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (!token) {
                alert('Security token not found. Please refresh the page.');
                return;
            }

            const formData = new FormData();
            formData.append('bookingId', bookingId);
            formData.append('transportCost', transportCost);

            try {
                const response = await fetch('/Artist/UpdateTransportCost', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    body: formData
                });

                if (response.ok) {
                    location.reload();
                } else {
                    const error = await response.text();
                    alert('Error: ' + error);
                }
            } catch (error) {
                alert('Error updating transport cost: ' + error.message);
            }
        }

        // Update booking status
        async function updateStatus(bookingId, status) {
            if (!confirm(`Are you sure you want to ${status} this booking?`)) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (!token) {
                alert('Security token not found. Please refresh the page.');
                return;
            }

            const formData = new FormData();
            formData.append('bookingId', bookingId);
            formData.append('newStatus', status);

            try {
                const response = await fetch('/Booking/ArtistUpdateStatus', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    body: formData
                });

                if (response.ok) {
                    location.reload();
                } else {
                    const error = await response.text();
                    alert('Error updating status: ' + error);
                }
            } catch (error) {
                alert('Error updating status: ' + error.message);
            }
        }
    </script>
}