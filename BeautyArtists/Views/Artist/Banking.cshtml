@model BeautyArtists.Models.ViewModels.BankingViewModel
@{
    ViewData["Title"] = "Banking Details";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

<div class="container py-4">

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <div class="card bg-dark text-white border-warning">
                <div class="card-header border-bottom border-warning">
                    <h3 class="text-warning mb-0">
                        <i class="fas fa-university me-2"></i>Banking Details
                    </h3>
                    <p class="text-muted small mt-1 mb-0">
                        Your banking info is used to receive payouts via Paystack.
                    </p>
                </div>

                <div class="card-body">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                        </div>
                    }

                    @if (Model.IsBankAccountVerified && !string.IsNullOrEmpty(Model.SubaccountCode))
                    {
                        <div class="alert alert-info">
                            <div class="d-flex align-items-center">
                                <div style="font-size:2rem; margin-right:15px;">✅</div>
                                <div>
                                    <strong>Bank Account Verified!</strong><br />
                                    <span class="text-white-50">Subaccount: @Model.SubaccountCode</span><br />
                                    <span class="text-white-50">Account Holder: @Model.AccountHolderName</span>
                                </div>
                            </div>
                        </div>
                    }

                    <form method="post" asp-action="Banking" id="bankingForm">
                        @Html.AntiForgeryToken()

                        <!-- ─── VALIDATION SUMMARY ─── -->
                        <div asp-validation-summary="All" class="alert alert-danger" style="display: none;"></div>

                        <div class="mb-3">
                            <label class="form-label text-warning">Bank <span class="text-danger">*</span></label>
                            <select asp-for="BankCode" class="form-select bg-dark text-white border-secondary" id="BankCode">
                                <option value="">Select your bank...</option>
                                @if (Model.Banks != null && Model.Banks.Any())
                                {
                                    @foreach (var bank in Model.Banks)
                                    {
                                        <option value="@bank.Value">@bank.Text</option>
                                    }
                                }
                                else
                                {
                                    <option value="" disabled>Loading banks... or no banks available</option>
                                }
                            </select>
                            <span asp-validation-for="BankCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-warning">Account Number <span class="text-danger">*</span></label>
                            <input asp-for="AccountNumber"
                                   class="form-control bg-dark text-white border-secondary"
                                   placeholder="Enter your account number"
                                   maxlength="24"
                                   id="AccountNumber" />
                            <div class="form-text text-muted">South African bank account number (8-13 digits).</div>
                            <span asp-validation-for="AccountNumber" class="text-danger small"></span>

                            <!-- ─── VALIDATION STATUS ─── -->
                            <div id="validationStatus" class="mt-2"></div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-warning">Account Holder Name</label>
                            <input asp-for="AccountHolderName" class="form-control bg-dark text-white border-secondary"
                                   placeholder="Will auto-fill after validation" readonly id="AccountHolderName" />
                            <div class="form-text text-muted">This will be auto-filled after validation.</div>
                        </div>

                        <div class="alert alert-info small">
                            <i class="fas fa-info-circle me-2"></i>
                            Your bank account will be verified with Paystack to ensure accurate payouts.
                            <strong>This is a one-time process.</strong>
                            <br /><strong>Test Mode:</strong> Use account number <strong>0000000000</strong>
                        </div>

                        <button type="submit" class="btn btn-warning w-100 py-2 fw-bold">
                            <i class="fas fa-check-circle me-2"></i>
                            @if (Model.IsBankAccountVerified)
                            {
                                @:Update Banking Details
                            }
                            else
                            {
                                @:Verify & Save Banking Details
                            }
                        </button>
                    </form>
                </div>
            </div>

            <div class="mt-3 text-center text-muted small">
                <p class="mb-0">
                    <i class="fas fa-lock me-1"></i> Your banking details are securely processed by Paystack.
                    We only store your subaccount reference.
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            $('#AccountNumber').on('blur', function() {
                var bankCode = $('#BankCode').val();
                var accountNumber = $(this).val();

                if (bankCode && accountNumber && accountNumber.length >= 8) {
                    validateAccount(bankCode, accountNumber);
                } else {
                    $('#validationStatus').html('');
                }
            });

            $('#BankCode').on('change', function() {
                var bankCode = $(this).val();
                var accountNumber = $('#AccountNumber').val();

                if (bankCode && accountNumber && accountNumber.length >= 8) {
                    validateAccount(bankCode, accountNumber);
                } else {
                    $('#validationStatus').html('');
                }
            });

            function validateAccount(bankCode, accountNumber) {
                $.ajax({
                    url: '/Artist/ValidateAccount',
                    type: 'GET',
                    data: { bankCode: bankCode, accountNumber: accountNumber },
                    beforeSend: function() {
                        $('#validationStatus').html('<span class="text-warning">⏳ Validating...</span>');
                    },
                    success: function(response) {
                        if (response.success) {
                            $('#validationStatus').html(
                                '<span class="text-success">✅ Account verified: ' + response.accountHolderName + '</span>'
                            );
                            $('#AccountHolderName').val(response.accountHolderName);
                        } else {
                            $('#validationStatus').html(
                                '<span class="text-danger">❌ ' + response.message + '</span>'
                            );
                            $('#AccountHolderName').val('');
                        }
                    },
                    error: function() {
                        $('#validationStatus').html('<span class="text-danger">❌ Validation error</span>');
                    }
                });
            }
        });
    </script>
}