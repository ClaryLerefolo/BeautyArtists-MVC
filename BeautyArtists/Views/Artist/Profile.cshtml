@model BeautyArtists.Models.ArtistProfile
@{
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .profile-wrapper {
        padding: 20px;
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-card {
        background: #0d0d0d;
        border: 1px solid #1a1a1a;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.7);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 30px;
    }

    @@media (min-width: 768px) {
        .profile-card {
            flex-direction: row;
            align-items: flex-start;
            padding: 40px;
        }
    }

    .profile-pic-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        width: 100%;
        max-width: 200px;
    }

    .profile-pic {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        border: 3px solid #f0c808;
        object-fit: cover;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 0 20px rgba(240, 200, 8, 0.15);
    }

        .profile-pic:hover {
            transform: scale(1.02);
            box-shadow: 0 0 30px rgba(240, 200, 8, 0.3);
        }

    .pic-hint {
        color: rgba(240, 200, 8, 0.4);
        font-size: 0.7rem;
        margin-top: 8px;
        letter-spacing: 1px;
    }

    .profile-info {
        flex: 1;
        width: 100%;
    }

    .profile-name {
        color: #f0c808;
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0 0 16px 0;
        text-align: center;
    }

    @@media (min-width: 768px) {
        .profile-name {
            text-align: left;
        }
    }

    .info-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .info-row {
        display: flex;
        flex-direction: column;
        gap: 2px;
        font-size: 0.95rem;
        line-height: 1.4;
    }

    @@media (min-width: 768px) {
        .info-row {
            flex-direction: row;
        }

        .info-label {
            width: 120px;
            flex-shrink: 0;
            font-weight: 700;
            color: #fff;
        }
    }

    .info-label {
        font-weight: 700;
        color: #fff;
    }

    .info-value {
        color: #bbb;
        word-break: break-word;
    }

        .info-value a {
            color: #1e90ff;
            text-decoration: none;
        }

            .info-value a:hover {
                color: #f0c808;
                text-decoration: underline;
            }

    .banking-verified {
        color: #28a745;
        font-weight: 600;
    }

    .banking-unverified {
        color: #ff6b6b;
        font-weight: 600;
    }

    .banking-link {
        color: #FFD700;
        margin-left: 8px;
        text-decoration: none;
        font-weight: 600;
    }

        .banking-link:hover {
            color: #fff;
            text-decoration: underline;
        }

    .social-links {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 8px;
    }

    .social-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #aaa;
        font-size: 0.85rem;
        text-decoration: none;
        transition: 0.2s;
        padding: 4px 12px;
        border-radius: 20px;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
    }

        .social-link:hover {
            color: #f0c808;
            border-color: #f0c808;
            transform: translateY(-2px);
        }

        .social-link .icon {
            font-size: 1.1rem;
        }

        .social-link.instagram:hover {
            color: #E4405F;
            border-color: #E4405F;
        }

        .social-link.facebook:hover {
            color: #1877F2;
            border-color: #1877F2;
        }

        .social-link.twitter:hover {
            color: #1DA1F2;
            border-color: #1DA1F2;
        }

        .social-link.tiktok:hover {
            color: #FF0050;
            border-color: #FF0050;
        }

    .btn-edit {
        background: linear-gradient(135deg, #e50914, #f0c808);
        border: none;
        padding: 10px 30px;
        border-radius: 8px;
        color: #000;
        font-weight: 800;
        font-size: 0.85rem;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        margin-top: 20px;
    }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 20px rgba(240, 200, 8, 0.3);
        }

    .btn-save {
        background: linear-gradient(135deg, #f0c808, #e50914);
        border: none;
        padding: 10px 30px;
        border-radius: 8px;
        color: #000;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 20px rgba(240, 200, 8, 0.3);
        }

    .btn-cancel {
        background: transparent;
        border: 1px solid #444;
        color: #888;
        padding: 10px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            background: #1a1a1a;
            color: #fff;
        }

    .modal-content-custom {
        background: #0d0d0d;
        border: 1px solid #f0c808;
        border-radius: 20px;
        color: #fff;
    }

    .modal-header-custom {
        padding: 20px 25px;
        border-bottom: 1px solid #1a1a1a;
    }

    .modal-body-custom {
        padding: 25px;
    }

    .modal-footer-custom {
        padding: 15px 25px;
        border-top: 1px solid #1a1a1a;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .form-control-custom {
        background: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: #fff !important;
        border-radius: 8px !important;
        padding: 10px 14px !important;
    }

        .form-control-custom:focus {
            border-color: #f0c808 !important;
            box-shadow: 0 0 0 2px rgba(240, 200, 8, 0.2) !important;
        }

    .form-label-custom {
        color: #f0c808;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 5px;
    }

    .pic-preview {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #f0c808;
        margin-bottom: 10px;
    }

    .alert-success-custom {
        background: rgba(0, 200, 83, 0.1);
        border: 1px solid rgba(0, 200, 83, 0.3);
        border-radius: 10px;
        padding: 12px 18px;
        color: #00c853;
        font-weight: 600;
        margin-bottom: 20px;
        max-width: 900px;
    }

    .btn-outline-gold {
        background: #FFD700;
        color: #000 !important;
        border: 1px solid #FFD700;
        font-weight: 700;
        padding: 10px 12px;
        border-radius: 8px;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-outline-gold:hover {
            background: #e5c100;
            border-color: #e5c100;
        }

    #studioMap {
        height: 250px;
        border-radius: 12px;
        border: 1px solid rgba(255, 215, 0, 0.2);
        margin: 10px 0;
        background: #222;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert-success-custom">✅ @TempData["Success"]</div>
}

<div class="profile-wrapper">
    <div class="profile-card">

        @* ── PROFILE PICTURE ── *@
        <div class="profile-pic-section">
            <img src="@Model.ProfilePictureUrl"
                 class="profile-pic"
                 alt="Profile"
                 onclick="openEditModal()"
                 onerror="this.src='/images/default-profile.png'" />
            <span class="pic-hint">📸 Click to edit</span>
        </div>

        @* ── PROFILE INFO ── *@
        <div class="profile-info">
            <h1 class="profile-name">@Model.FullName</h1>

            <div class="info-grid">

                <div class="info-row">
                    <span class="info-label">Bio:</span>
                    <span class="info-value">@Model.Bio</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Experience:</span>
                    <span class="info-value">@Model.YearsExperience years</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Location:</span>
                    <span class="info-value">@Model.City, @Model.Province</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Contact:</span>
                    <span class="info-value">@Model.ContactInfo</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Banking:</span>
                    @if (Model.IsBankAccountVerified && !string.IsNullOrEmpty(Model.SubaccountCode))
                    {
                        <span class="info-value">
                            <span class="banking-verified">✅ Verified</span>
                            <small style="color: rgba(255,255,255,0.3);">
                                (@Model.BankName)
                            </small>
                            <a asp-controller="Artist" asp-action="Banking" class="banking-link" style="color: #FFD700; margin-left: 8px; font-size: 0.8rem;">
                                Update →
                            </a>
                        </span>
                    }
                    else
                    {
                        <span class="info-value">
                            <span class="banking-unverified">⚠️ Not Verified</span>
                            <a asp-controller="Artist" asp-action="Banking" class="banking-link">
                                Add Banking Details →
                            </a>
                        </span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.InstagramUrl) || !string.IsNullOrEmpty(Model.FacebookUrl) ||
                                !string.IsNullOrEmpty(Model.TwitterUrl) || !string.IsNullOrEmpty(Model.TikTokUrl))
                {
                    <div class="info-row" style="margin-top: 8px;">
                        <span class="info-label">Social:</span>
                        <div class="social-links">
                            @if (!string.IsNullOrEmpty(Model.InstagramUrl))
                            {
                                <a href="@Model.InstagramUrl" target="_blank" class="social-link instagram">
                                    <span class="icon">📸</span> Instagram
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.FacebookUrl))
                            {
                                <a href="@Model.FacebookUrl" target="_blank" class="social-link facebook">
                                    <span class="icon">📘</span> Facebook
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.TwitterUrl))
                            {
                                <a href="@Model.TwitterUrl" target="_blank" class="social-link twitter">
                                    <span class="icon">🐦</span> Twitter/X
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.TikTokUrl))
                            {
                                <a href="@Model.TikTokUrl" target="_blank" class="social-link tiktok">
                                    <span class="icon">🎵</span> TikTok
                                </a>
                            }
                        </div>
                    </div>
                }

                <div class="mt-4 pt-3 border-top border-secondary">
                    <h5 style="color:#f0c808; font-weight:700;">Studio Location (Walk‑in)</h5>
                    <p style="color:rgba(255,255,255,0.3); font-size:0.8rem;">
                        This address will be shown to clients after they've fully paid for a walk‑in booking.
                    </p>

                    <div class="row mb-2">
                        <div class="col-md-8">
                            <input type="text" id="studioSearchInput" class="form-control form-control-custom"
                                   placeholder="🔍 Search for your studio address..." />
                        </div>
                        <div class="col-md-4">
                            <button type="button" id="studioSearchBtn" class="btn-outline-gold w-100">Go</button>
                        </div>
                    </div>

                    <div id="studioMap"></div>

                    <div class="row g-2 mt-2">
                        <div class="col-md-6">
                            <label class="form-label-custom">Studio Address</label>
                            <input asp-for="StudioAddress" class="form-control form-control-custom" id="studioAddressField" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">City</label>
                            <input asp-for="StudioCity" class="form-control form-control-custom" id="studioCityField" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Province</label>
                            <input asp-for="StudioProvince" class="form-control form-control-custom" id="studioProvinceField" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Postal Code</label>
                            <input asp-for="StudioPostalCode" class="form-control form-control-custom" id="studioPostalField" />
                        </div>
                        <input asp-for="StudioLatitude" type="hidden" id="studioLatField" />
                        <input asp-for="StudioLongitude" type="hidden" id="studioLngField" />
                    </div>
                    <small class="text-muted">Click on the map to set your studio location. You can also search above.</small>
                </div>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap;">
                <button class="btn-edit" onclick="openEditModal()">✎ Edit Profile</button>
                <a href="@Url.Action("Banking", "Artist")" class="btn-edit" style="background: linear-gradient(135deg, #f0c808, #e50914); text-decoration: none; text-align: center;">
                    💳 Banking Details
                </a>
            </div>
        </div>

    </div>
</div>

@* ── EDIT MODAL ── *@
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom">

            <div class="modal-header-custom">
                <h4 style="color:#f0c808; font-weight:800; margin:0;">Edit Profile</h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserId" />

                <div class="modal-body-custom">
                    <div class="row">
                        <div class="col-12">
                            <label class="form-label-custom">Profile Picture</label>
                            <div class="mb-3">
                                <img id="editPfpPreview" src="@Model.ProfilePictureUrl"
                                     class="pic-preview" onerror="this.src='/images/default-profile.png'" />
                            </div>
                            <input type="file" name="ProfilePicture" id="editPfpInput"
                                   class="form-control form-control-custom" accept="image/*" />
                            <small class="text-muted">Upload a new photo (optional)</small>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label-custom">Full Name</label>
                            <input asp-for="FullName" class="form-control form-control-custom" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label-custom">Years Experience</label>
                            <input asp-for="YearsExperience" type="number"
                                   class="form-control form-control-custom" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Bio</label>
                        <textarea asp-for="Bio" class="form-control form-control-custom" rows="2"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label-custom">Province</label>
                            <select id="editProvince" asp-for="Province"
                                    class="form-select form-control-custom">
                                <option value="">Select Province</option>
                                <option value="Gauteng">Gauteng</option>
                                <option value="North West">North West</option>
                                <option value="Western Cape">Western Cape</option>
                                <option value="KwaZulu-Natal">KwaZulu-Natal</option>
                                <option value="Free State">Free State</option>
                                <option value="Eastern Cape">Eastern Cape</option>
                                <option value="Limpopo">Limpopo</option>
                                <option value="Mpumalanga">Mpumalanga</option>
                                <option value="Northern Cape">Northern Cape</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label-custom">City</label>
                            <select id="editCity" asp-for="City"
                                    class="form-select form-control-custom">
                                <option value="">Select City</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label-custom">Contact Number</label>
                            <input asp-for="ContactInfo" class="form-control form-control-custom" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label-custom">Instagram URL</label>
                            <input asp-for="InstagramUrl" class="form-control form-control-custom" placeholder="https://instagram.com/yourhandle" />
                        </div>
                    </div>

                    <div class="row mt-2">
                        <div class="col-md-4 mb-3">
                            <label class="form-label-custom">Facebook URL</label>
                            <input asp-for="FacebookUrl" class="form-control form-control-custom" placeholder="https://facebook.com/yourhandle" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label-custom">Twitter/X URL</label>
                            <input asp-for="TwitterUrl" class="form-control form-control-custom" placeholder="https://x.com/yourhandle" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label-custom">TikTok URL</label>
                            <input asp-for="TikTokUrl" class="form-control form-control-custom" placeholder="https://tiktok.com/syourhandle" />
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top border-secondary">
                        <h5 style="color:#f0c808; font-weight:700;">Studio Location</h5>
                        <p style="color:rgba(255,255,255,0.3); font-size:0.8rem;">
                            This address will be shown to clients after they've fully paid for a walk‑in booking.
                        </p>

                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label-custom">Studio Address</label>
                                <input asp-for="StudioAddress" class="form-control form-control-custom" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">City</label>
                                <input asp-for="StudioCity" class="form-control form-control-custom" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-custom">Province</label>
                                <input asp-for="StudioProvince" class="form-control form-control-custom" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-custom">Postal Code</label>
                                <input asp-for="StudioPostalCode" class="form-control form-control-custom" />
                            </div>
                            <input asp-for="StudioLatitude" type="hidden" id="modalStudioLat" />
                            <input asp-for="StudioLongitude" type="hidden" id="modalStudioLng" />
                        </div>
                        <small class="text-muted">Latitude and Longitude are set automatically via the map.</small>
                    </div>
                </div>

                <div class="modal-footer-custom">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-save">💾 Save Changes</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    // ─── LOCATIONIQ API KEY ───
    const LOCATIONIQ_API_KEY = 'pk.262798f25cd021707b77f66c88babd01';

    function openEditModal() {
        var myModal = new bootstrap.Modal(document.getElementById('editModal'));
        myModal.show();
    }

    // ── CITY DROPDOWN LOGIC ──
    const cityMap = {
        "Gauteng": ["Johannesburg", "Pretoria", "Sandton", "Soweto", "Centurion"],
        "North West": ["Rustenburg", "Potchefstroom", "Klerksdorp", "Mahikeng"],
        "Western Cape": ["Cape Town", "Stellenbosch", "George", "Paarl"],
        "KwaZulu-Natal": ["Durban", "Pietermaritzburg", "Umhlanga", "Newcastle"],
        "Free State": ["Bloemfontein", "Welkom", "Sasolburg"],
        "Eastern Cape": ["Gqeberha", "East London", "Makhanda"],
        "Limpopo": ["Polokwane", "Thohoyandou", "Tzaneen"],
        "Mpumalanga": ["Mbombela", "Secunda", "Witbank"],
        "Northern Cape": ["Kimberley", "Upington"]
    };

    const provSelect = document.getElementById('editProvince');
    const citySelect = document.getElementById('editCity');

    function updateCities() {
        const selected = provSelect.value;
        citySelect.innerHTML = '<option value="">Select City</option>';
        if (selected && cityMap[selected]) {
            cityMap[selected].forEach(function(city) {
                const opt = document.createElement('option');
                opt.value = city;
                opt.textContent = city;
                if (city === '@Model.City') opt.selected = true;
                citySelect.appendChild(opt);
            });
        }
    }

    const initialProvince = '@Model.Province';
    if (initialProvince) {
        provSelect.value = initialProvince;
    }
    updateCities();
    provSelect.addEventListener('change', updateCities);

    // ── IMAGE PREVIEW ──
    document.getElementById('editPfpInput').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(ev) {
                document.getElementById('editPfpPreview').src = ev.target.result;
            };
            reader.readAsDataURL(file);
        }
    });

    // ── STUDIO MAP ──
    let studioMap, studioMarker;

    function initStudioMap() {
        const lat = @((Model.StudioLatitude ?? -26.2041).ToString(System.Globalization.CultureInfo.InvariantCulture));
        const lng = @((Model.StudioLongitude ?? 28.0473).ToString(System.Globalization.CultureInfo.InvariantCulture));

        studioMap = L.map('studioMap').setView([lat, lng], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(studioMap);

        studioMarker = L.marker([lat, lng], { draggable: true }).addTo(studioMap);

        studioMarker.on('dragend', function() {
            const pos = studioMarker.getLatLng();
            document.getElementById('studioLatField').value = pos.lat.toFixed(6);
            document.getElementById('studioLngField').value = pos.lng.toFixed(6);
            const modalLat = document.getElementById('modalStudioLat');
            const modalLng = document.getElementById('modalStudioLng');
            if (modalLat) modalLat.value = pos.lat.toFixed(6);
            if (modalLng) modalLng.value = pos.lng.toFixed(6);
            reverseGeocode(pos.lat, pos.lng);
        });

        studioMap.on('click', function(e) {
            const pos = e.latlng;
            studioMarker.setLatLng(pos);
            document.getElementById('studioLatField').value = pos.lat.toFixed(6);
            document.getElementById('studioLngField').value = pos.lng.toFixed(6);
            const modalLat = document.getElementById('modalStudioLat');
            const modalLng = document.getElementById('modalStudioLng');
            if (modalLat) modalLat.value = pos.lat.toFixed(6);
            if (modalLng) modalLng.value = pos.lng.toFixed(6);
            reverseGeocode(pos.lat, pos.lng);
        });

        setTimeout(function() {
            studioMap.invalidateSize();
        }, 300);
    }

    // ─── REVERSE GEOCODE USING LOCATIONIQ ───
    async function reverseGeocode(lat, lng) {
        try {
            const resp = await fetch(
                `https://us1.locationiq.com/v1/reverse.php?key=${LOCATIONIQ_API_KEY}&lat=${lat}&lon=${lng}&format=json`
            );
            const data = await resp.json();
            if (data && data.address) {
                const addr = data.address;
                const house = addr.house_number || addr.building || '';
                const road = addr.road || addr.street || '';
                const suburb = addr.suburb || addr.neighbourhood || addr.city_district || '';
                const city = addr.city || addr.town || addr.village || '';
                const state = addr.state || addr.province || '';
                const postcode = addr.postcode || '';

                // ─── UPDATE DISPLAY FIELDS ───
                document.getElementById('studioAddressField').value = `${house} ${road}`.trim();
                document.getElementById('studioCityField').value = city || suburb;
                document.getElementById('studioProvinceField').value = state;
                document.getElementById('studioPostalField').value = postcode;

                // ─── UPDATE MODAL FIELDS (the ones that get saved) ───
                const modalAddress = document.querySelector('input[name="StudioAddress"]');
                const modalCity = document.querySelector('input[name="StudioCity"]');
                const modalProvince = document.querySelector('input[name="StudioProvince"]');
                const modalPostal = document.querySelector('input[name="StudioPostalCode"]');

                if (modalAddress) modalAddress.value = `${house} ${road}`.trim();
                if (modalCity) modalCity.value = city || suburb;
                if (modalProvince) modalProvince.value = state;
                if (modalPostal) modalPostal.value = postcode;

                // ─── UPDATE HIDDEN LAT/LNG FIELDS ───
                const modalLat = document.getElementById('modalStudioLat');
                const modalLng = document.getElementById('modalStudioLng');
                if (modalLat) modalLat.value = lat.toFixed(6);
                if (modalLng) modalLng.value = lng.toFixed(6);
            }
        } catch (e) {
            console.warn('Reverse geocode error:', e);
            document.getElementById('studioAddressField').placeholder = 'Enter address manually';
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        initStudioMap();

        // ─── SEARCH USING LOCATIONIQ ───
        document.getElementById('studioSearchBtn').addEventListener('click', function() {
            const query = document.getElementById('studioSearchInput').value.trim();
            if (!query) return;
            const url = `https://us1.locationiq.com/v1/search.php?key=${LOCATIONIQ_API_KEY}&q=${encodeURIComponent(query)}&format=json&limit=1`;
            fetch(url)
                .then(r => r.json())
                .then(data => {
                    if (data && data.length > 0) {
                        const lat = parseFloat(data[0].lat);
                        const lon = parseFloat(data[0].lon);
                        studioMap.setView([lat, lon], 19);
                        studioMarker.setLatLng([lat, lon]);
                        document.getElementById('studioLatField').value = lat.toFixed(6);
                        document.getElementById('studioLngField').value = lon.toFixed(6);
                        const modalLat = document.getElementById('modalStudioLat');
                        const modalLng = document.getElementById('modalStudioLng');
                        if (modalLat) modalLat.value = lat.toFixed(6);
                        if (modalLng) modalLng.value = lon.toFixed(6);
                        reverseGeocode(lat, lon);
                        document.getElementById('studioSearchInput').value = data[0].display_name || '';
                    } else {
                        alert('Address not found. Try a more specific search.');
                    }
                })
                .catch(() => alert('Search error. Check your connection.'));
        });
    });

    @if (!ViewData.ModelState.IsValid)
    {
            <text>
                openEditModal();
            </text>
    }
</script>