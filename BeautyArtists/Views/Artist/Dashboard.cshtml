@model BeautyArtists.Models.ViewModels.ArtistDashboardViewModel
@{
    Layout = "_ArtistLayout";
}

<style>
    /* REMOVE TOP GAPS & LAYOUT BASE */
    .dashboard-root {
        padding: 5px 15px 20px 15px;
        background: #000;
        min-height: 100vh;
        box-sizing: border-box;
    }

    /* UNIFORM RESPONSIVE STATS GRID */
    .stats-card-grid {
        display: grid;
        /* Default: 2 equal columns on standard portrait mobile screens */
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        width: 100%;
        box-sizing: border-box;
    }

    /* CARDS & HOVER GLOW */
    .stat-glow-card {
        background: #0d0d0d;
        border-radius: 18px;
        padding: 20px 10px; /* Balanced mobile padding */
        text-align: center;
        border: 1px solid #2a1105;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-width: 0; /* Prevents text overflow layout distortion */
        box-sizing: border-box;
    }

        /* THE HOVER EFFECT */
        .stat-glow-card:hover {
            border-color: #ff4500;
            box-shadow: 0 0 25px rgba(255, 69, 0, 0.4);
            transform: translateY(-3px);
        }

    .orb-red-gold {
        width: 50px;
        height: 50px;
        margin: 0 auto 12px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        background: linear-gradient(180deg, #ff7b00 0%, #ff0000 100%);
        box-shadow: 0 0 15px rgba(255, 69, 0, 0.5);
        color: #fff;
    }

    .stat-num {
        font-size: 2.2rem; /* Adjusted slightly to cleanly fit double-digits or currency */
        font-weight: 800;
        color: #fff;
        line-height: 1.1;
        word-break: break-word;
    }

    .stat-tag {
        color: #666;
        font-size: 0.8rem;
        margin-top: 6px;
        line-height: 1.2;
    }

    .recent-label-gold {
        color: #d4af37;
        margin-top: 30px;
        font-weight: 600;
        font-size: 1.4rem;
    }

    /* LOWER SECTION GRID (TABLE & CHART) */
    .dashboard-lower-grid {
        display: grid;
        grid-template-columns: 1fr; /* Stacks vertically on mobile portrait */
        gap: 20px;
        margin-top: 20px;
        width: 100%;
        box-sizing: border-box;
    }

    .content-box-beauty {
        background: #0d0d0d;
        border: 1px solid #1a1a1a;
        border-radius: 12px;
        padding: 15px;
        transition: 0.3s;
        min-width: 0; /* Prevents overflow issues */
    }

        .content-box-beauty:hover {
            border-color: #ff4500;
            box-shadow: 0 0 15px rgba(255, 69, 0, 0.2);
        }

    .box-title-gold {
        color: #d4af37;
        font-size: 1.1rem;
        margin-bottom: 15px;
        font-weight: 600;
    }

    /* COMPACT TABLE STYLE */
    .beauty-table-compact {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 6px;
    }

        .beauty-table-compact th {
            color: #555;
            font-size: 0.75rem;
            text-transform: uppercase;
            padding-bottom: 5px;
            text-align: left;
        }

        .beauty-table-compact td {
            background: #111;
            padding: 10px;
            color: #fff;
            font-size: 0.85rem;
            border-top: 1px solid #1a1a1a;
            border-bottom: 1px solid #1a1a1a;
        }

            .beauty-table-compact td:first-child {
                border-left: 1px solid #1a1a1a;
                border-radius: 8px 0 0 8px;
            }

            .beauty-table-compact td:last-child {
                border-right: 1px solid #1a1a1a;
                border-radius: 0 8px 8px 0;
            }

    /* PENDING STATUS GLOW */
    .status-pill {
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: bold;
        display: inline-block;
    }

        .status-pill.pending {
            background: rgba(255, 123, 0, 0.1);
            color: #ff7b00;
            border: 1px solid #ff7b00;
        }

    .chart-wrapper {
        position: relative;
        height: 200px;
        width: 100%;
    }

    .empty-dashboard-state {
        text-align: center;
        padding: 30px;
        color: #555;
        font-style: italic;
    }

    /* MEDIA QUERIES FOR LARGER VIEWPORTS (Landscape Mobiles, Tablets, Desktops) */
    @@media (min-width: 650px) {
        .stats-card-grid

    {
        /* Smooth transitions out to 4 columns side by side when space permits */
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .stat-glow-card {
        padding: 30px 10px;
    }

    .stat-num {
        font-size: 2.8rem;
    }

    }

    @@media (min-width: 992px) {
        .dashboard-lower-grid

    {
        /* Split layout for broad display fields */
        grid-template-columns: 1.5fr 1fr;
    }

    }
</style>

<div class="dashboard-root">
    <div class="stats-card-grid">
        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-scissors"></i></div>
            <div class="stat-num">@Model.ServicesCount</div>
            <div class="stat-tag">Services</div>
        </div>

        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-image"></i></div>
            <div class="stat-num">@Model.PortfolioItemsCount</div>
            <div class="stat-tag">Portfolio Items</div>
        </div>

        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-num">@Model.UpcomingAppointments</div>
            <div class="stat-tag">Upcoming Appointments</div>
        </div>

        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-wallet2"></i></div>
            <div class="stat-num">R @Model.MonthlyEarnings.ToString("N0")</div>
            <div class="stat-tag">This Month's Earnings</div>
        </div>
    </div>

    <div class="dashboard-lower-grid">
        <div class="content-box-beauty">
            <h3 class="box-title-gold">Recent Appointments</h3>

            @if (Model.RecentAppointments != null && Model.RecentAppointments.Any())
            {
                <div style="overflow-x: auto;">
                    <table class="beauty-table-compact">
                        <thead>
                            <tr>
                                <th>Client</th>
                                <th>Service</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appt in Model.RecentAppointments)
                            {
                                <tr>
                                    <td><strong>@appt.ClientName</strong></td>
                                    <td>@appt.ServiceName</td>
                                    <td>@appt.AppointmentDate.ToString("dd MMM")</td>
                                    <td>
                                        <span class="status-pill @appt.Status.ToLower()">
                                            @appt.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-dashboard-state">
                    <p>No appointments booked yet.</p>
                </div>
            }
        </div>

        <div class="content-box-beauty">
            <h3 class="box-title-gold">Earnings Trend</h3>
            <div class="chart-wrapper">
                <canvas id="earningsChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('earningsChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.MonthlyLabels)),
            datasets: [{
                data: @Html.Raw(Json.Serialize(Model.MonthlyEarningsGraph)),
                borderColor: '#d4af37',
                backgroundColor: 'rgba(192, 57, 43, 0.1)',
                fill: true,
                tension: 0.4,
                borderWidth: 2,
                pointRadius: 3,
                pointBackgroundColor: '#ff4500'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#1a1a1a' }, ticks: { color: '#444', font: { size: 10 } } },
                x: { grid: { display: false }, ticks: { color: '#444', font: { size: 10 } } }
            }
        }
    });
</script>