@model BeautyArtists.Models.ViewModels.ArtistDashboardViewModel
@{
    Layout = "_ArtistLayout";
}

<style>
    /* REMOVE TOP GAPS & LAYOUT BASE */
    .dashboard-root {
        padding: 5px 15px 20px 15px;
        background: #000;
        min-height: 100vh;
        box-sizing: border-box;
    }

    /* UNIFORM RESPONSIVE STATS GRID */
    .stats-card-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        width: 100%;
        box-sizing: border-box;
    }

    /* CARDS & HOVER GLOW */
    .stat-glow-card {
        background: #0d0d0d;
        border-radius: 18px;
        padding: 20px 10px;
        text-align: center;
        border: 1px solid #2a1105;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
    }

        .stat-glow-card:hover {
            border-color: #ff4500;
            box-shadow: 0 0 25px rgba(255, 69, 0, 0.4);
            transform: translateY(-3px);
        }

    .orb-red-gold {
        width: 50px;
        height: 50px;
        margin: 0 auto 12px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        background: linear-gradient(180deg, #ff7b00 0%, #ff0000 100%);
        box-shadow: 0 0 15px rgba(255, 69, 0, 0.5);
        color: #fff;
    }

    .stat-num {
        font-size: 2.2rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.1;
        word-break: break-word;
    }

    .stat-tag {
        color: #666;
        font-size: 0.8rem;
        margin-top: 6px;
        line-height: 1.2;
    }

    .recent-label-gold {
        color: #d4af37;
        margin-top: 30px;
        font-weight: 600;
        font-size: 1.4rem;
    }

    /* LOWER SECTION GRID (TABLE & CHART) */
    .dashboard-lower-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        margin-top: 20px;
        width: 100%;
        box-sizing: border-box;
    }

    .content-box-beauty {
        background: #0d0d0d;
        border: 1px solid #1a1a1a;
        border-radius: 12px;
        padding: 15px;
        transition: 0.3s;
        min-width: 0;
    }

        .content-box-beauty:hover {
            border-color: #ff4500;
            box-shadow: 0 0 15px rgba(255, 69, 0, 0.2);
        }

    .box-title-gold {
        color: #d4af37;
        font-size: 1.1rem;
        margin-bottom: 15px;
        font-weight: 600;
    }

    /* COMPACT TABLE STYLE */
    .beauty-table-compact {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 6px;
    }

        .beauty-table-compact th {
            color: #555;
            font-size: 0.75rem;
            text-transform: uppercase;
            padding-bottom: 5px;
            text-align: left;
        }

        .beauty-table-compact td {
            background: #111;
            padding: 10px;
            color: #fff;
            font-size: 0.85rem;
            border-top: 1px solid #1a1a1a;
            border-bottom: 1px solid #1a1a1a;
        }

            .beauty-table-compact td:first-child {
                border-left: 1px solid #1a1a1a;
                border-radius: 8px 0 0 8px;
            }

            .beauty-table-compact td:last-child {
                border-right: 1px solid #1a1a1a;
                border-radius: 0 8px 8px 0;
            }

    /* ─── STATUS PILLS ─── */
    .status-pill {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .status-pill.pending {
            background: rgba(255, 165, 0, 0.15);
            color: #ffa500;
            border: 1px solid rgba(255, 165, 0, 0.3);
        }

        .status-pill.confirmed {
            background: rgba(0, 200, 83, 0.15);
            color: #00c853;
            border: 1px solid rgba(0, 200, 83, 0.3);
        }

        .status-pill.accepted {
            background: rgba(23, 162, 184, 0.15);
            color: #17a2b8;
            border: 1px solid rgba(23, 162, 184, 0.3);
        }

        .status-pill.completed {
            background: rgba(41, 121, 255, 0.15);
            color: #2979ff;
            border: 1px solid rgba(41, 121, 255, 0.3);
        }

        .status-pill.cancelled {
            background: rgba(255, 50, 50, 0.15);
            color: #ff3333;
            border: 1px solid rgba(255, 50, 50, 0.3);
        }

        .status-pill.rejected {
            background: rgba(229, 9, 20, 0.2);
            color: #e50914;
            border: 1px solid rgba(229, 9, 20, 0.3);
        }

    .chart-wrapper {
        position: relative;
        height: 200px;
        width: 100%;
    }

    .empty-dashboard-state {
        text-align: center;
        padding: 30px 10px;
        color: rgba(255, 255, 255, 0.3);
        font-style: italic;
    }

        .empty-dashboard-state p {
            margin: 0;
        }

    /* MEDIA QUERIES */
    @@media (min-width: 650px) {
        .stats-card-grid

    {
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .stat-glow-card {
        padding: 30px 10px;
    }

    .stat-num {
        font-size: 2.8rem;
    }

    }

    @@media (min-width: 992px) {
        .dashboard-lower-grid

    {
        grid-template-columns: 1.5fr 1fr;
    }

    }

    @@media (max-width: 400px) {
        .stat-num

    {
        font-size: 1.6rem;
    }

    .orb-red-gold {
        width: 40px;
        height: 40px;
        font-size: 1rem;
    }

    .stat-glow-card {
        padding: 12px 6px;
    }

    .beauty-table-compact td {
        font-size: 0.7rem;
        padding: 6px 8px;
    }

    .beauty-table-compact th {
        font-size: 0.6rem;
    }

    }
</style>

<div class="dashboard-root">
    <div class="stats-card-grid">
        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-scissors"></i></div>
            <div class="stat-num">@Model.ServicesCount</div>
            <div class="stat-tag">Services</div>
        </div>

        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-image"></i></div>
            <div class="stat-num">@Model.PortfolioItemsCount</div>
            <div class="stat-tag">Portfolio Items</div>
        </div>

        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-num">@Model.UpcomingAppointments</div>
            <div class="stat-tag">Upcoming Appointments</div>
        </div>

        <div class="stat-glow-card">
            <div class="orb-red-gold"><i class="bi bi-wallet2"></i></div>
            <div class="stat-num">R @Model.MonthlyEarnings.ToString("N0")</div>
            <div class="stat-tag">This Month's Earnings</div>
        </div>
    </div>

    <div class="dashboard-lower-grid">
        <div class="content-box-beauty">
            <h3 class="box-title-gold">Recent Appointments</h3>

            @if (Model.RecentAppointments != null && Model.RecentAppointments.Any())
            {
                <div style="overflow-x: auto;">
                    <table class="beauty-table-compact">
                        <thead>
                            <tr>
                                <th>Client</th>
                                <th>Service</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appt in Model.RecentAppointments)
                            {
                                <tr>
                                    <td><strong>@appt.ClientName</strong></td>
                                    <td>@appt.ServiceName</td>
                                    <td>@appt.AppointmentDate.ToString("dd MMM")</td>
                                    <td>
                                        <span class="status-pill @appt.Status.ToLower()">
                                            @appt.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-dashboard-state">
                    <p>📅 No appointments booked yet.</p>
                </div>
            }
        </div>

        <div class="content-box-beauty">
            <h3 class="box-title-gold">Earnings Trend</h3>
            @if (Model.MonthlyEarningsGraph != null && Model.MonthlyEarningsGraph.Any() && Model.MonthlyEarningsGraph.Sum() > 0)
            {
                <div class="chart-wrapper">
                    <canvas id="earningsChart"></canvas>
                </div>
            }
            else
            {
                <div class="empty-dashboard-state">
                    <p>📊 No earnings data yet.</p>
                    <p style="font-size: 0.8rem; color: rgba(255,255,255,0.15);">Earnings will appear here once you complete bookings.</p>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // ─── EARNINGS CHART ───
        @if (Model.MonthlyEarningsGraph != null && Model.MonthlyEarningsGraph.Any() && Model.MonthlyEarningsGraph.Sum() > 0)
        {
                <text>
                const ctx = document.getElementById('earningsChart');
                if (ctx) {
                    const chart = new Chart(ctx.getContext('2d'), {
                        type: 'line',
                        data: {
                            labels: @Html.Raw(Json.Serialize(Model.MonthlyLabels)),
                            datasets: [{
                                label: 'Earnings (R)',
                                data: @Html.Raw(Json.Serialize(Model.MonthlyEarningsGraph)),
                                borderColor: '#d4af37',
                                backgroundColor: 'rgba(212, 175, 55, 0.08)',
                                fill: true,
                                tension: 0.4,
                                borderWidth: 2,
                                pointRadius: 4,
                                pointBackgroundColor: '#ff4500',
                                pointBorderColor: '#d4af37',
                                pointBorderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return 'R ' + context.parsed.y.toLocaleString('en-ZA', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: { color: 'rgba(255,255,255,0.05)' },
                                    ticks: {
                                        color: '#444',
                                        font: { size: 10 },
                                        callback: function(value) {
                                            return 'R ' + value.toLocaleString();
                                        }
                                    }
                                },
                                x: {
                                    grid: { display: false },
                                    ticks: {
                                        color: '#444',
                                        font: { size: 10 }
                                    }
                                }
                            }
                        }
                    });

                    // ─── RESIZE HANDLER ───
                    window.addEventListener('resize', function() {
                        chart.resize();
                    });
                }
                </text>
        }
    });
</script>