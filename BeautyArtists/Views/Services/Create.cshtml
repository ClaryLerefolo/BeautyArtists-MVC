@model BeautyArtists.Models.ViewModels.ServiceViewModel
@{
    ViewData["Title"] = "New Service";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .cs-eyebrow {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: rgba(255,215,0,0.35);
            display: block;
            margin-bottom: 4px;
        }

        .cs-heading {
            font-size: 1.5rem;
            font-weight: 900;
            color: #FFD700;
            margin: 0 0 24px;
        }

        .cs-card {
            background: #0b0b0b;
            border: 1px solid rgba(255,215,0,0.12);
            border-radius: 18px;
            overflow: hidden;
            max-width: 760px;
        }

        .cs-card-header {
            background: linear-gradient(135deg, #0a0000, #150500);
            border-bottom: 1px solid rgba(255,215,0,0.08);
            padding: 18px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .cs-header-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, #b30000, #FFD700);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            color: #000;
            flex-shrink: 0;
        }

        .cs-header-title {
            font-size: 0.85rem;
            font-weight: 800;
            color: #FFD700;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin: 0;
        }

        .cs-header-sub {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.3);
            margin: 2px 0 0;
        }

        .cs-card-body {
            padding: 28px 24px;
        }

        /* Grid rows */
        .cs-row {
            display: grid;
            gap: 18px;
            margin-bottom: 18px;
        }

        .cs-row-2 {
            grid-template-columns: 1fr 1fr;
        }

        .cs-row-3 {
            grid-template-columns: 1fr 1fr 1fr;
        }

        @@media (max-width: 640px) {
            .cs-row-2, .cs-row-3 {
                grid-template-columns: 1fr;
            }
        }

        .cs-field {
            display: flex;
            flex-direction: column;
        }

        .cs-label {
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,215,0,0.5);
            margin-bottom: 7px;
        }

        .cs-input, .cs-select, .cs-textarea {
            background: rgba(255,255,255,0.04) !important;
            border: 1px solid rgba(255,215,0,0.15) !important;
            border-radius: 10px !important;
            color: #fff !important;
            padding: 11px 14px !important;
            font-size: 0.86rem;
            transition: border-color 0.2s;
            width: 100%;
        }

            .cs-input:focus, .cs-select:focus, .cs-textarea:focus {
                outline: none !important;
                border-color: rgba(255,215,0,0.4) !important;
                background: rgba(255,215,0,0.03) !important;
                box-shadow: none !important;
            }

            .cs-input::placeholder, .cs-textarea::placeholder {
                color: rgba(255,255,255,0.2) !important;
            }

            .cs-select option {
                background: #111;
                color: #fff;
            }

        .cs-textarea {
            resize: vertical;
            min-height: 100px;
        }

        .cs-validation {
            font-size: 0.75rem;
            color: #ff5555;
            margin-top: 5px;
        }

        /* Price */
        .cs-price-wrap {
            display: flex;
            align-items: stretch;
            border: 1px solid rgba(255,215,0,0.15);
            border-radius: 10px;
            overflow: hidden;
            background: rgba(255,255,255,0.04);
            transition: border-color 0.2s;
        }

            .cs-price-wrap:focus-within {
                border-color: rgba(255,215,0,0.4);
            }

        .cs-price-prefix {
            padding: 11px 14px;
            background: rgba(255,215,0,0.1);
            color: #FFD700;
            font-weight: 900;
            font-size: 0.9rem;
            border-right: 1px solid rgba(255,215,0,0.15);
            display: flex;
            align-items: center;
        }

        .cs-price-input {
            flex: 1;
            background: transparent !important;
            border: none !important;
            border-radius: 0 !important;
            color: #fff !important;
            padding: 11px 14px !important;
            font-size: 0.86rem;
        }

            .cs-price-input:focus {
                outline: none !important;
                box-shadow: none !important;
            }

        /* Checkbox */
        .cs-check-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 13px 16px;
            border-radius: 10px;
            background: rgba(255,215,0,0.04);
            border: 1px solid rgba(255,215,0,0.1);
            cursor: pointer;
            transition: background 0.2s;
        }

            .cs-check-wrap:hover {
                background: rgba(255,215,0,0.08);
            }

        .cs-checkbox {
            width: 18px;
            height: 18px;
            accent-color: #FFD700;
            cursor: pointer;
            flex-shrink: 0;
        }

        .cs-check-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: rgba(255,255,255,0.6);
            cursor: pointer;
            margin: 0;
        }

        /* Divider */
        .cs-divider {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 6px 0 18px;
        }

        .cs-divider-line {
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.06);
        }

        .cs-divider-text {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.2);
        }

        /* Actions */
        .cs-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 8px;
        }

        .cs-btn-save {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 30px;
            border-radius: 999px;
            background: linear-gradient(135deg, #b30000, #FFD700);
            color: #000;
            font-weight: 800;
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }

            .cs-btn-save:hover {
                background: linear-gradient(135deg, #FFD700, #b30000);
                box-shadow: 0 0 20px rgba(255,215,0,0.3);
                transform: translateY(-1px);
            }

        .cs-btn-cancel {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border-radius: 999px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.45);
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s;
        }

            .cs-btn-cancel:hover {
                background: rgba(255,255,255,0.08);
                color: rgba(255,255,255,0.7);
                border-color: rgba(255,255,255,0.2);
            }
    </style>
}

<span class="cs-eyebrow">Administration</span>
<h1 class="cs-heading">Define New Service</h1>

<div class="cs-card">
    <div class="cs-card-header">
        <div class="cs-header-icon"><i class="bi bi-plus-lg"></i></div>
        <div>
            <p class="cs-header-title">New Service Template</p>
            <p class="cs-header-sub">Artists pick from these templates when listing their services</p>
        </div>
    </div>

    <div class="cs-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly"
                 style="color:#ff5555;font-size:0.82rem;margin-bottom:16px;"></div>

            @* Name + Category *@
            <div class="cs-row cs-row-2">
                <div class="cs-field">
                    <label asp-for="Name" class="cs-label">Service Name</label>
                    <input asp-for="Name" class="cs-input" placeholder="e.g. Gel Manicure" />
                    <span asp-validation-for="Name" class="cs-validation"></span>
                </div>
                <div class="cs-field">
                    <label asp-for="CategoryId" class="cs-label">Service Category</label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="cs-select">
                        <option value="">— Select Category —</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="cs-validation"></span>
                </div>
            </div>

            @* Price + Duration + Featured *@
            <div class="cs-row cs-row-3">
                <div class="cs-field">
                    <label asp-for="BasePrice" class="cs-label">Base Price</label>
                    <div class="cs-price-wrap">
                        <span class="cs-price-prefix">R</span>
                        <input asp-for="BasePrice" type="number" step="0.01"
                               class="cs-price-input" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="BasePrice" class="cs-validation"></span>
                </div>
                <div class="cs-field">
                    <label asp-for="Duration" class="cs-label">Duration (mins)</label>
                    <input asp-for="Duration" type="number" class="cs-input" placeholder="e.g. 60" />
                    <span asp-validation-for="Duration" class="cs-validation"></span>
                </div>
                <div class="cs-field">
                    <label class="cs-label">Featured</label>
                    <label class="cs-check-wrap">
                        <input asp-for="IsFeatured" type="checkbox" class="cs-checkbox" />
                        <span class="cs-check-label">Show on homepage</span>
                    </label>
                </div>
            </div>

            @* Description *@
            <div class="cs-divider">
                <div class="cs-divider-line"></div>
                <span class="cs-divider-text">Description</span>
                <div class="cs-divider-line"></div>
            </div>

            <div class="cs-field" style="margin-bottom:24px;">
                <label asp-for="Description" class="cs-label">Service Description</label>
                <textarea asp-for="Description" class="cs-textarea"
                          placeholder="Describe what this service involves for the client..."></textarea>
                <span asp-validation-for="Description" class="cs-validation"></span>
            </div>

            <div class="cs-actions">
                <button type="submit" class="cs-btn-save">
                    <i class="bi bi-check-lg"></i> Save Service
                </button>
                <a asp-action="Index" class="cs-btn-cancel">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
