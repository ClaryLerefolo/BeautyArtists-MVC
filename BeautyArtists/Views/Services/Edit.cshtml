@model BeautyArtists.Models.UserService
@{
    ViewData["Title"] = "Edit Service";
}

<h2>Edit Service</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="ServiceId" class="control-label"></label>
        <select asp-for="ServiceId" class="form-control" asp-items="ViewBag.ServiceId"></select>
        <span asp-validation-for="ServiceId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Price" class="control-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CustomDescription" class="control-label"></label>
        <input asp-for="CustomDescription" class="form-control" />
        <span asp-validation-for="CustomDescription" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
