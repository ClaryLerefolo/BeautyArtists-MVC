@model IEnumerable<BeautyArtists.Models.UserService>

@{
    ViewData["Title"] = "Services";
    var selectedCategory = ViewBag.SelectedCategory as string;
    var categories = ViewBag.Categories as List<string>;
}

<h2 class="text-gold mb-4">Available Services</h2>

<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <select name="category" class="form-select" onchange="this.form.submit()">
                <option value="">All Categories</option>
                @foreach (var category in categories)
                {
                    <option value="@category" selected="@(category == selectedCategory ? "selected" : null)">
                        @category
                    </option>
                }
            </select>
        </div>
    </div>
</form>

<div class="row">
    @foreach (var item in Model)
    {
        var artistName = item.Artist?.ArtistProfile?.FullName
        ?? $"{item.Artist?.FirstName} {item.Artist?.LastName}"
        ?? item.Artist?.UserName
        ?? item.Artist?.Email
        ?? "Unknown Artist";

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-gold bg-dark text-light">
                <div class="card-body">
                    <h5 class="card-title">@item.Service?.Name</h5>
                    <p class="card-text">
                        @(item.CustomDescription ?? item.Service?.Description)
                    </p>

                    <p><strong>Category:</strong> @item.Service?.Category?.Name</p>
                    <p><strong>Price:</strong> R @item.Price.ToString("F2")</p>
                    <p><strong>Artist:</strong> @artistName</p>
                    <a href="@Url.Action("Details", "Services", new { id = item.Id })" class="btn btn-danger btn-sm">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
