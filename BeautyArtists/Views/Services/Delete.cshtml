@model BeautyArtists.Models.UserService
@{
    ViewData["Title"] = "Delete Service";
}

<h2>Delete Service</h2>

<h4>Are you sure you want to delete this service?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-2">Service</dt>
        <dd class="col-sm-10">@Model.Service?.Name</dd>

        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.Price.ToString("C")</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.CustomDescription</dd>
    </dl>

    <form asp-action="DeleteConfirmed">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
