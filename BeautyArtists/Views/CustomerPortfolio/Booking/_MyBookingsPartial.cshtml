@model IEnumerable<BeautyArtists.Models.Booking>




@Html.AntiForgeryToken()

<div class="table-responsive mt-3">
    <table class="table table-dark table-hover border-gold shadow-lg" style="border-radius:12px; overflow:hidden;">
        <thead>
            <tr class="text-center heading-row">
                <th>Service</th>
                <th>Artist</th>
                <th>Date</th>
                <th>Status</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var b in Model)
            {
                <tr class="text-center align-middle">
                    <td class="text-gold fw-bold">@b.UserService.Service.Name</td>
                    <td>@b.UserService.Artist.UserName</td>
                    <td>@b.AppointmentDate.ToString("yyyy-MM-dd")</td>

                    <td>
                        <span class="status-badge @(b.Status)">
                            @b.Status
                        </span>
                    </td>

                    <td class="fw-bold text-gold">R @b.TotalAmount.ToString("F2")</td>

                    <td>
                        @if (b.Status != BeautyArtists.Models.Booking.BookingStatus.Cancelled &&
                                            b.Status != BeautyArtists.Models.Booking.BookingStatus.Completed)
                        {
                            <button class="btn-action cancel" onclick="cancelBooking(@b.Id)">
                                Cancel
                            </button>

                            <button class="btn-action reschedule" onclick="openReschedule(@b.Id)">
                                Reschedule
                            </button>
                        }
                        else
                        {
                            <span class="text-muted">No Actions</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    /* Gold + Red Theme */
    :root {
        --gold: #FFD700;
        --red: #FF0000;
        --dark-bg: #0d0d0d;
        --table-border: rgba(255, 215, 0, 0.35);
    }

    .border-gold {
        border: 1px solid var(--table-border) !important;
    }

    .text-gold {
        color: var(--gold) !important;
    }

    .heading-row {
        background: linear-gradient(90deg, var(--red), var(--gold)) !important;
        color: #000 !important;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Status Badges */
    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .Pending {
        background: #ffcc00;
        color: #000;
        box-shadow: 0 0 10px rgba(255, 204, 0, 0.7);
    }

    .Confirmed {
        background: #00ff66;
        color: #000;
        box-shadow: 0 0 10px rgba(0, 255, 102, 0.6);
    }

    .Cancelled {
        background: #ff4444;
        color: #fff;
        box-shadow: 0 0 10px rgba(255, 68, 68, 0.6);
    }

    .Completed {
        background: #777;
        color: #000;
        box-shadow: 0 0 10px rgba(180, 180, 180, 0.5);
    }

    /* ACTION BUTTONS */
    .btn-action {
        padding: 6px 14px;
        border-radius: 25px;
        font-weight: 700;
        font-size: 0.9rem;
        border: none;
        margin: 2px;
        transition: 0.3s;
    }

        .btn-action.cancel {
            background: linear-gradient(90deg, #ff0000, #ff4500);
            color: #fff;
            box-shadow: 0 0 10px rgba(255, 0, 0, 0.6);
        }

            .btn-action.cancel:hover {
                transform: scale(1.05);
                box-shadow: 0 0 15px rgba(255, 0, 0, 1);
            }

        .btn-action.reschedule {
            background: linear-gradient(90deg, var(--gold), var(--red));
            color: #000;
            box-shadow: 0 0 10px rgba(255, 215, 0, 0.6);
        }

            .btn-action.reschedule:hover {
                transform: scale(1.05);
                box-shadow: 0 0 18px rgba(255, 215, 0, 1);
            }
</style>

