@model BeautyArtists.Models.ViewModels.ArtistEarningsViewModel
@{
    ViewData["Title"] = "Earnings";
    Layout = "~/Views/Shared/_ArtistLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            --gold: #f0c808;
            --red: #e50914;
            --dark-card: #121212;
            --glass: rgba(255,255,255,0.05);
        }

        body {
            background: #000;
            color: #f0f0f0;
            font-family: 'Segoe UI', sans-serif;
        }

        .dashboard-header {
            background: linear-gradient(90deg, var(--red), var(--gold));
            padding: 24px 30px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(229,9,20,0.3);
            margin-bottom: 28px;
        }

            .dashboard-header h1 {
                color: #000;
                font-weight: 900;
                text-transform: uppercase;
                margin: 0;
                letter-spacing: 2px;
                font-size: 1.6rem;
            }

            .dashboard-header p {
                color: #000;
                font-weight: 700;
                margin: 4px 0 0;
                font-size: 0.85rem;
            }

        /* ─── FILTER TOGGLE PILL ─── */
        .filter-toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .filter-toggle-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            border-radius: 999px;
            background: rgba(255,215,0,0.08);
            border: 1px solid rgba(255,215,0,0.3);
            color: #FFD700;
            font-weight: 700;
            font-size: 0.78rem;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.25s;
            text-transform: uppercase;
            white-space: nowrap;
        }

            .filter-toggle-btn:hover {
                background: rgba(255,215,0,0.15);
                border-color: #FFD700;
            }

            .filter-toggle-btn .badge {
                background: #FFD700;
                color: #000;
                font-size: 0.6rem;
                font-weight: 900;
                padding: 1px 7px;
                border-radius: 50%;
                min-width: 20px;
                text-align: center;
            }

            .filter-toggle-btn .arrow {
                transition: transform 0.3s ease;
                display: inline-block;
                font-size: 0.6rem;
            }

            .filter-toggle-btn.open .arrow {
                transform: rotate(180deg);
            }

        /* ─── FILTER CONTAINER (COLLAPSIBLE) ─── */
        .filter-container {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(240,200,8,0.2);
            border-radius: 15px;
            padding: 0 20px;
            margin-bottom: 24px;
            overflow: hidden;
            max-height: 0;
            opacity: 0;
            transition: max-height 0.4s ease, opacity 0.3s ease, padding 0.3s ease;
        }

            .filter-container.open {
                max-height: 600px;
                padding: 20px;
                opacity: 1;
            }

        .filter-title {
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            border-bottom: 1px solid rgba(240,200,8,0.15);
            padding-bottom: 10px;
        }

        .filter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 12px;
            align-items: end;
        }

        .filter-field {
            display: flex;
            flex-direction: column;
            gap: 5px;
            min-width: 0;
        }

        .filter-label {
            font-size: 0.6rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(240,200,8,0.6);
            white-space: nowrap;
        }

        .filter-select, .filter-input {
            background: rgba(0,0,0,0.6) !important;
            border: 1px solid rgba(240,200,8,0.3) !important;
            border-radius: 8px !important;
            color: #fff !important;
            padding: 8px 12px !important;
            font-size: 0.82rem;
            width: 100%;
        }

        .quick-pills {
            display: flex;
            gap: 6px;
            overflow-x: auto;
            padding-bottom: 4px;
            scrollbar-width: none;
        }

            .quick-pills::-webkit-scrollbar {
                display: none;
            }

        .quick-pill {
            padding: 7px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 1px;
            text-transform: uppercase;
            border: 1.5px solid rgba(240,200,8,0.4);
            color: rgba(240,200,8,0.7);
            background: transparent;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

            .quick-pill:hover, .quick-pill.active {
                background: var(--gold);
                color: #000;
                border-color: var(--gold);
            }

        .filter-actions {
            display: flex;
            gap: 8px;
            flex-wrap: nowrap;
        }

        .btn-apply, .btn-reset {
            flex: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px 12px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 0.75rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .btn-apply {
            background: var(--gold);
            color: #000;
            border: none;
        }

            .btn-apply:hover {
                background: #fff;
            }

        .btn-reset {
            background: transparent;
            color: rgba(255,80,80,0.7);
            border: 1.5px solid rgba(255,80,80,0.3);
        }

            .btn-reset:hover {
                background: rgba(255,50,50,0.1);
                color: #ff6666;
                border-color: #ff6666;
            }

        /* ─── ACTIVE FILTER PILLS ─── */
        .active-filters {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }

        .filter-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            background: rgba(255,215,0,0.1);
            border: 1px solid rgba(255,215,0,0.2);
            color: rgba(255,215,0,0.8);
        }

        /* ── STAT CARDS ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 24px;
        }

        @@media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
            }
        }

        @@media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr;
                gap: 8px;
            }
        }

        .stat-card {
            background: var(--dark-card);
            border-left: 4px solid var(--red);
            border-radius: 14px;
            padding: 16px;
            transition: 0.3s ease;
            height: 100%;
        }

            .stat-card:hover {
                border-left-color: var(--gold);
                transform: translateY(-4px);
            }

        .stat-value {
            color: var(--gold);
            font-size: 1.4rem;
            font-weight: 800;
            display: block;
            word-break: break-all;
        }

        .stat-label {
            color: #888;
            text-transform: uppercase;
            font-size: 0.6rem;
            font-weight: 700;
        }

        .stat-sub {
            color: rgba(255,255,255,0.2);
            font-size: 0.65rem;
            margin-top: 2px;
        }

        /* ── PAYMENT BREAKDOWN BAR ── */
        .payment-breakdown {
            background: var(--dark-card);
            border-radius: 14px;
            padding: 16px 20px;
            border: 1px solid rgba(255,255,255,0.05);
            margin-bottom: 24px;
        }

        .breakdown-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        @@media (max-width: 768px) {
            .breakdown-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 480px) {
            .breakdown-grid {
                grid-template-columns: 1fr 1fr;
                gap: 6px;
            }
        }

        .breakdown-item {
            text-align: center;
            padding: 4px 0;
        }

            .breakdown-item .label {
                font-size: 0.55rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: rgba(255,255,255,0.3);
                display: block;
            }

            .breakdown-item .value {
                font-size: 1.2rem;
                font-weight: 800;
            }

                .breakdown-item .value.gold {
                    color: var(--gold);
                }

                .breakdown-item .value.info {
                    color: #17a2b8;
                }

                .breakdown-item .value.success {
                    color: #28a745;
                }

                .breakdown-item .value.warning {
                    color: #ffc107;
                }

        .section-box {
            background: var(--dark-card);
            border-radius: 18px;
            padding: 22px;
            border: 1px solid #1e1e1e;
        }

        .btn-reports {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 22px;
            border-radius: 999px;
            border: 2px solid var(--gold);
            color: var(--gold);
            font-weight: 800;
            font-size: 0.78rem;
            background: transparent;
            cursor: pointer;
            transition: all 0.2s;
        }

        .payment-badge {
            font-size: 0.65rem;
            padding: 3px 10px;
            border-radius: 50px;
            font-weight: 700;
        }

            .payment-badge.fully-paid {
                background: rgba(40,167,69,0.15);
                color: #28a745;
                border: 1px solid #28a745;
            }

            .payment-badge.deposit-only {
                background: rgba(255,193,7,0.15);
                color: #ffc107;
                border: 1px solid #ffc107;
            }

            .payment-badge.unpaid {
                background: rgba(108,117,125,0.15);
                color: #6c757d;
                border: 1px solid #6c757d;
            }

        /* ── TABLE ── */
        .table {
            font-size: 0.78rem;
        }

            .table thead th {
                font-size: 0.6rem;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: rgba(240,200,8,0.4);
                border-bottom: 1px solid rgba(255,215,0,0.1);
            }

            .table td {
                vertical-align: middle;
                padding: 8px 10px;
            }

        @@media (max-width: 768px) {
            .table {
                font-size: 0.7rem;
            }

                .table td, .table th {
                    padding: 6px 6px;
                }

            .stat-value {
                font-size: 1.1rem;
            }

            .breakdown-item .value {
                font-size: 1rem;
            }

            .filter-grid {
                grid-template-columns: 1fr 1fr;
            }

            .filter-actions {
                grid-column: span 2;
            }
        }

        @@media (max-width: 480px) {
            .stat-value {
                font-size: 0.95rem;
            }

            .breakdown-item .value {
                font-size: 0.85rem;
            }

            .filter-grid {
                grid-template-columns: 1fr;
            }

            .filter-actions {
                grid-column: span 1;
            }
        }
    </style>
}

<div class="container-fluid px-4 py-4">

    @* HEADER *@
    <div class="dashboard-header">
        <h1><i class="fas fa-gem me-2"></i>Artist Command Center</h1>
        <p>Track your hustle. Secure your bag.</p>
    </div>

    @* ─── FILTER TOGGLE ─── *@
    @{
        var hasFilters = !string.IsNullOrEmpty(ViewBag.SelectedStatus) ||
        !string.IsNullOrEmpty(ViewBag.SelectedService) ||
        !string.IsNullOrEmpty(ViewBag.SelectedClient) ||
        !string.IsNullOrEmpty(ViewBag.FromDate) ||
        !string.IsNullOrEmpty(ViewBag.ToDate);
        var activeFilterCount = 0;
        if (!string.IsNullOrEmpty(ViewBag.SelectedStatus) && ViewBag.SelectedStatus != "All Statuses") activeFilterCount++;
        if (!string.IsNullOrEmpty(ViewBag.SelectedService)) activeFilterCount++;
        if (!string.IsNullOrEmpty(ViewBag.SelectedClient)) activeFilterCount++;
        if (!string.IsNullOrEmpty(ViewBag.FromDate)) activeFilterCount++;
        if (!string.IsNullOrEmpty(ViewBag.ToDate)) activeFilterCount++;
    }

    <div class="filter-toggle-wrapper">
        <button class="filter-toggle-btn" id="filterToggleBtn">
            <i class="fas fa-sliders-h"></i>
            <span>Filters</span>
            @if (activeFilterCount > 0)
            {
                <span class="badge">@activeFilterCount</span>
            }
            <span class="arrow">▼</span>
        </button>
        <span style="color:rgba(255,255,255,0.3);font-size:0.75rem;">
            <span style="color:#FFD700;font-weight:800;">@Model.History.Count</span> transactions
        </span>
    </div>

    @* ─── ACTIVE FILTER PILLS ─── *@
    @if (hasFilters)
    {
        <div class="active-filters">
            @if (!string.IsNullOrEmpty(ViewBag.SelectedStatus) && ViewBag.SelectedStatus != "All Statuses")
            {
                <span class="filter-pill"><i class="bi bi-circle-fill"></i> @ViewBag.SelectedStatus</span>
            }
            @if (!string.IsNullOrEmpty(ViewBag.SelectedService))
            {
                <span class="filter-pill"><i class="bi bi-tag"></i> @ViewBag.SelectedService</span>
            }
            @if (!string.IsNullOrEmpty(ViewBag.SelectedClient))
            {
                <span class="filter-pill"><i class="bi bi-person"></i> @ViewBag.SelectedClient</span>
            }
            @if (!string.IsNullOrEmpty(ViewBag.FromDate))
            {
                <span class="filter-pill"><i class="bi bi-calendar"></i> From @DateTime.ParseExact(ViewBag.FromDate, "yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture).ToString("dd MMM yyyy")</span>
            }
            @if (!string.IsNullOrEmpty(ViewBag.ToDate))
            {
                <span class="filter-pill"><i class="bi bi-calendar"></i> To @DateTime.ParseExact(ViewBag.ToDate, "yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture).ToString("dd MMM yyyy")</span>
            }
        </div>
    }

    @* ─── FILTER BAR (COLLAPSIBLE) ─── *@
    <div class="filter-container" id="filterBar">
        <div class="filter-title">
            <i class="fas fa-filter"></i> Filter Your Hustle
        </div>
        <form id="filterForm" method="get" asp-action="Earnings">
            <div class="filter-grid">
                <div class="filter-field">
                    <span class="filter-label">Quick Range</span>
                    <div class="quick-pills">
                        <button type="button" class="quick-pill" data-from="" data-to="">All</button>
                        <button type="button" class="quick-pill" data-from="month" data-to="">Month</button>
                        <button type="button" class="quick-pill" data-from="30days" data-to="">30 Days</button>
                    </div>
                </div>
                <div class="filter-field">
                    <span class="filter-label">Status</span>
                    <select name="statusFilter" id="statusFilter" class="filter-select">
                        <option value="">All Statuses</option>
                        <option value="Completed" selected="@(ViewBag.SelectedStatus == "Completed" ? "selected" : null)">Completed</option>
                        <option value="Pending" selected="@(ViewBag.SelectedStatus == "Pending" ? "selected" : null)">Pending</option>
                        <option value="Confirmed" selected="@(ViewBag.SelectedStatus == "Confirmed" ? "selected" : null)">Confirmed</option>
                        <option value="Cancelled" selected="@(ViewBag.SelectedStatus == "Cancelled" ? "selected" : null)">Cancelled</option>
                    </select>
                </div>
                <div class="filter-field">
                    <span class="filter-label">Service</span>
                    <select name="serviceFilter" id="serviceFilter" class="filter-select">
                        <option value="">All Services</option>
                        @if (Model.TopServices != null && Model.TopServices.Any())
                        {
                            @foreach (var service in Model.TopServices)
                            {
                                <option value="@service.Key" selected="@(ViewBag.SelectedService == service.Key ? "selected" : null)">
                                    @service.Key (@service.Value.JobCount jobs)
                                </option>
                            }
                        }
                        else
                        {
                            @foreach (var item in Model.History.Select(h => h.ServiceName).Distinct())
                            {
                                <option value="@item" selected="@(ViewBag.SelectedService == item ? "selected" : null)">@item</option>
                            }
                        }
                    </select>
                </div>
                <div class="filter-field">
                    <span class="filter-label">Client</span>
                    <input type="text" name="clientFilter" id="clientFilter" value="@ViewBag.SelectedClient" placeholder="Search clients..." class="filter-input" maxlength="50" />
                </div>
                <div class="filter-field">
                    <span class="filter-label">From Date</span>
                    <input type="date" name="fromDate" id="fromDate" value="@ViewBag.FromDate" class="filter-select" />
                </div>
                <div class="filter-field">
                    <span class="filter-label">To Date</span>
                    <input type="date" name="toDate" id="toDate" value="@ViewBag.ToDate" class="filter-select" />
                </div>
                <div class="filter-field" style="display:flex; gap:8px;">
                    <button type="submit" class="btn-apply"><i class="fas fa-search"></i> Apply</button>
                    <button type="button" class="btn-reset" id="resetBtn"><i class="fas fa-times"></i> Reset</button>
                </div>
            </div>
        </form>
    </div>

    @* ─── STAT CARDS ─── *@
    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-label">Net Cleared</span>
            <span class="stat-value">R @Model.TotalLifetimeEarnings.ToString("N2")</span>
            <div class="stat-sub">Lifetime after fees</div>
        </div>
        <div class="stat-card" style="border-left-color:var(--gold)">
            <span class="stat-label">Completed</span>
            <span class="stat-value">@Model.CompletedBookingsCount</span>
            <div class="stat-sub">Avg R @Model.AvgJobValue.ToString("N0")</div>
        </div>
        <div class="stat-card" style="border-left-color:#00c853">
            <span class="stat-label">Month Revenue</span>
            <span class="stat-value">R @Model.ThisMonthEarnings.ToString("N2")</span>
            <div class="stat-sub">This month cleared</div>
        </div>
        <div class="stat-card" style="border-left-color:var(--red)">
            <span class="stat-label">Pending</span>
            <span class="stat-value" style="color:#888;">R @Model.PendingEarnings.ToString("N2")</span>
            <div class="stat-sub">Awaiting clearance</div>
        </div>
    </div>

    @* ─── PAYMENT BREAKDOWN BAR ─── *@
    <div class="payment-breakdown">
        <div class="breakdown-grid">
            <div class="breakdown-item">
                <span class="label">Total Deposits</span>
                <span class="value info">R @Model.TotalDeposits.ToString("N2")</span>
            </div>
            <div class="breakdown-item">
                <span class="label">Total Final</span>
                <span class="value success">R @Model.TotalFinalPayments.ToString("N2")</span>
            </div>
            <div class="breakdown-item">
                <span class="label">Fully Paid</span>
                <span class="value warning">@Model.History.Count(h => h.IsFullyPaid)</span>
            </div>
            <div class="breakdown-item">
                <span class="label">Your Earnings</span>
                <span class="value gold">R @Model.TotalLifetimeEarnings.ToString("N2")</span>
            </div>
        </div>
    </div>

    @* TOP SERVICES *@
    @if (Model.TopServices != null && Model.TopServices.Any())
    {
        <div class="section-box mt-4 mb-4">
            <h5 class="text-white fw-bold mb-4" style="font-size:0.85rem;letter-spacing:2px;text-transform:uppercase;">
                <i class="fas fa-chart-bar me-2" style="color:var(--gold)"></i>Top Services
            </h5>
            <div class="row g-3">
                @foreach (var service in Model.TopServices.Take(6))
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="stat-card p-4 h-100" style="border-left-color:var(--gold)">
                            <span class="stat-label">@service.Key</span>
                            <span class="stat-value">R @service.Value.TotalEarnings.ToString("N0")</span>
                            <small class="text-muted d-block">@service.Value.JobCount jobs</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ── TRANSACTION HISTORY ── *@
    <div class="section-box">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="text-white fw-bold mb-0" style="font-size:0.85rem;letter-spacing:2px;text-transform:uppercase;">
                <i class="fas fa-history me-2" style="color:var(--gold)"></i>Transaction History
            </h5>
            <span style="font-size:0.72rem;color:rgba(255,255,255,0.25);">
                @Model.History.Count record@(Model.History.Count != 1 ? "s" : "")
            </span>
        </div>

        @if (!Model.History.Any())
        {
            <div style="padding:40px;text-align:center;color:rgba(255,255,255,0.2);font-size:0.85rem;">
                <i class="fas fa-history" style="font-size:2rem;display:block;margin-bottom:12px;color:rgba(240,200,8,0.1)"></i>
                No transactions yet.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr style="font-size:0.65rem;letter-spacing:2px;text-transform:uppercase;color:rgba(240,200,8,0.5)">
                            <th>Date</th>
                            <th>Client</th>
                            <th>Service</th>
                            <th class="text-end">Service Price</th>
                            <th class="text-end">Deposit</th>
                            <th class="text-end">Final</th>
                            <th class="text-end">Earnings</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.History)
                        {
                            <tr>
                                <td style="color:rgba(255,255,255,0.4)">@item.Date.ToString("dd MMM yyyy")</td>
                                <td style="color:#fff;font-weight:600">@item.ClientName</td>
                                <td style="color:rgba(255,255,255,0.6)">@item.ServiceName</td>
                                <td class="text-end fw-bold" style="color:#fff;">R @item.OriginalPrice.ToString("N2")</td>
                                <td class="text-end" style="color:#17a2b8;">R @item.DepositPaid.ToString("N2")</td>
                                <td class="text-end" style="color:#28a745;">R @item.FinalPaymentPaid.ToString("N2")</td>
                                <td class="text-end fw-bold" style="color:var(--gold)">R @item.YourEarnings.ToString("N2")</td>
                                <td class="text-center">
                                    @if (item.IsFullyPaid)
                                    {
                                        <span class="payment-badge fully-paid">✅ Fully Paid</span>
                                    }
                                    else if (item.DepositPaid > 0)
                                    {
                                        <span class="payment-badge deposit-only">💰 Deposit</span>
                                    }
                                    else
                                    {
                                        <span class="payment-badge unpaid">⏳ Unpaid</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="border-top:1px solid rgba(240,200,8,0.15)">
                            <td colspan="6" style="padding:12px;font-size:0.7rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.3)">Total</td>
                            <td class="text-end" style="color:var(--gold);font-size:0.9rem;font-weight:900;padding:12px;">
                                R @Model.History.Sum(h => h.YourEarnings).ToString("N2")
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

@* REPORT MODAL *@
<div class="modal fade" id="reportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:#0a0a0a;border:2px solid var(--gold);border-radius:20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color:var(--gold);font-size:0.8rem;letter-spacing:3px;text-transform:uppercase;">
                    <i class="fas fa-file-export me-2"></i>Export Data
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="d-grid gap-3">
                    <a asp-action="DownloadCsv"
                       asp-route-fromDate="@ViewBag.FromDate"
                       asp-route-toDate="@ViewBag.ToDate"
                       asp-route-statusFilter="@ViewBag.SelectedStatus"
                       asp-route-serviceFilter="@ViewBag.SelectedService"
                       asp-route-clientFilter="@ViewBag.SelectedClient"
                       class="btn btn-outline-warning py-3 fw-bold">
                        <i class="fas fa-file-csv me-2"></i>CSV — Opens in Excel / Google Sheets
                    </a>
                </div>
                <small class="text-muted mt-3 d-block text-center">
                    Report includes all currently filtered records
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('filterToggleBtn');
            const filterBar = document.getElementById('filterBar');

            @if (hasFilters)
            {
                    <text>
                        filterBar.classList.add('open');
                        toggleBtn.classList.add('open');
                    </text>
            }

            toggleBtn.addEventListener('click', function() {
                filterBar.classList.toggle('open');
                toggleBtn.classList.toggle('open');
            });

            document.querySelectorAll('.quick-pill').forEach(btn => {
                btn.addEventListener('click', function () {
                    document.querySelectorAll('.quick-pill').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    const from = this.dataset.from;
                    if (from === 'month') {
                        const today = new Date();
                        const start = new Date(today.getFullYear(), today.getMonth(), 1);
                        document.getElementById('fromDate').value = start.toISOString().split('T')[0];
                        document.getElementById('toDate').value = '';
                    } else if (from === '30days') {
                        const today = new Date();
                        const ago = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000);
                        document.getElementById('fromDate').value = ago.toISOString().split('T')[0];
                        document.getElementById('toDate').value = '';
                    } else {
                        document.getElementById('fromDate').value = '';
                        document.getElementById('toDate').value = '';
                    }
                });
            });

            document.getElementById('resetBtn').addEventListener('click', function () {
                document.getElementById('fromDate').value = '';
                document.getElementById('toDate').value = '';
                document.getElementById('statusFilter').value = '';
                document.getElementById('serviceFilter').value = '';
                document.getElementById('clientFilter').value = '';
                document.querySelectorAll('.quick-pill').forEach(b => b.classList.remove('active'));
                document.getElementById('filterForm').submit();
            });
        });
    </script>
}