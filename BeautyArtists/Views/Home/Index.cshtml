@model BeautyArtists.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Welcome";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="hero d-flex align-items-center justify-content-center text-center text-light" style="background: url('@Url.Content("~/uploads/hero/hero.jpg")') center/cover no-repeat; height: 80vh;">
    <div>
        <h1 class="display-3">BeautyArtists Salon</h1>
        <p class="lead">Book your perfect look today.</p>
        <a href="@Url.Action("Book", "Booking")" class="btn btn-danger btn-lg">Book Now</a>
    </div>
</section>

<!-- Featured Services -->
<section class="py-5">
    <div class="container">
        <h2 class="text-gold mb-4">Featured Services</h2>
        <div class="row">
            @foreach (var s in Model.FeaturedServices)
            {
                <div class="col-md-4 mb-4">
                    <div class="card bg-dark text-light h-100 border border-gold">
                        <img src="@Url.Content("~/" + (string.IsNullOrEmpty(s.ImagePath) ? "images/default-service.jpg" : s.ImagePath))"
                             class="card-img-top" alt="@s.Name" style="object-fit: cover; height: 200px;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@s.Name</h5>
                            <p class="card-text">@s.Description</p>
                            <a asp-controller="Services" asp-action="Details" asp-route-id="@s.Id" class="btn btn-danger mt-auto">Learn More</a>
                        </div>
                        <div class="card-footer bg-dark text-gold">
                            Duration: @s.Duration mins | From R@s.BasePrice
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Testimonials Carousel -->
@if (Model.Testimonials?.Any() == true)
{
    <section class="py-5 bg-dark">
        <div class="container">
            <h2 class="text-gold mb-4">What Our Clients Say</h2>
            <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Testimonials.Count; i++)
                    {
                        var t = Model.Testimonials[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="text-center text-light">
                                <blockquote class="blockquote"><p>"@t.Message"</p></blockquote>
                                <footer class="blockquote-footer text-gold">@t.CustomerName</footer>
                            </div>
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>
    </section>
}
