@model BeautyArtists.Models.ViewModels.ServiceListViewModel

<section class="py-5 bg-dark text-light">
    <div class="container">
        <h2 class="text-center text-gold mb-5 fw-bold">@Model.Title</h2>
        <div class="row">
            @if (Model.Services != null && Model.Services.Any())
            {
                foreach (var s in Model.Services)
                {
                    var image = string.IsNullOrWhiteSpace(s.ImagePath) ? "/images/default-service.jpg" : s.ImagePath;

                    // 🔥 Generate star HTML
                    var fullStars = (int)Math.Floor(s.AverageRating);
                    var hasHalfStar = (s.AverageRating - fullStars) >= 0.5;
                    var emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);

                    <div class="col-md-4 col-sm-6 mb-4">
                        <div class="featured-card shadow-lg h-100">
                            <img src="@Url.Content(image)" alt="@s.ServiceName" class="service-img" />
                            <div class="card-body p-3 d-flex flex-column">
                                <div class="title text-gold fw-bold fs-5">@s.ServiceName</div>

                                @if (!string.IsNullOrEmpty(s.Description))
                                {
                                    <div class="desc small text-muted mt-1">@s.Description</div>
                                }

                                <div class="fw-bold text-gold mt-2">Provided by: @s.ArtistName</div>

                                @if (!string.IsNullOrEmpty(s.City) || !string.IsNullOrEmpty(s.Province))
                                {
                                    <div class="text-muted small">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        @if (!string.IsNullOrEmpty(s.City) && !string.IsNullOrEmpty(s.Province))
                                        {
                                            @($"{s.City}, {s.Province}")
                                        }
                                        else if (!string.IsNullOrEmpty(s.City))
                                        {
                                            @s.City
                                        }
                                        else
                                        {
                                            @s.Province
                                        }

                                        ArtistLocation = !string.IsNullOrEmpty(us.Artist?.ArtistProfile?.City)
                                        ? $"{us.Artist.ArtistProfile.City}, {us.Artist.ArtistProfile.Province}"
                                        : us.Artist?.ArtistProfile?.Province ?? ""
                                    </div>
                                }

                                <div class="fw-bold text-white mt-1">Price: R @s.Price.ToString("N0")</div>

                                <!-- 🔥 STARS AND REVIEW COUNT -->
                                <div class="mt-2 d-flex align-items-center gap-2">
                                    <div class="stars">
                                        @for (int i = 0; i < fullStars; i++)
                                        {
                                            <span class="star filled">★</span>
                                        }
                                        @if (hasHalfStar)
                                        {
                                            <span class="star half">★</span>
                                        }
                                        @for (int i = 0; i < emptyStars; i++)
                                        {
                                            <span class="star empty">★</span>
                                        }
                                    </div>
                                    <span class="text-muted small">(@s.ReviewCount reviews)</span>
                                    @if (s.ReviewCount > 0)
                                    {
                                        <span class="text-muted small">• @s.AverageRating.ToString("0.0") ⭐</span>
                                    }
                                </div>

                                <!-- 🔥 BOOK NOW BUTTON -->
                                <div class="mt-3">
                                    <a asp-controller="Booking"
                                       asp-action="BookService"
                                       asp-route-userServiceId="@s.UserServiceId"
                                       class="btn-gradient w-100 text-center">
                                        Book Now
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="fas fa-search" style="font-size: 3rem; color: rgba(255,255,255,0.1);"></i>
                    <p class="text-muted mt-3">No services available yet.</p>
                </div>
            }
        </div>
    </div>
</section>

<style>
    /* === UNIVERSAL SERVICE LIST THEME FIX === */

    .featured-card {
        background: #0b0b0b !important;
        border: 1px solid rgba(255, 215, 0, 0.25);
        border-radius: 16px;
        box-shadow: 0 0 20px rgba(255, 0, 0, 0.15);
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .featured-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 215, 0, 0.2);
        }

    .service-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-bottom: 2px solid rgba(255, 215, 0, 0.1);
    }

    .featured-card .card-body {
        background: #0b0b0b;
        color: #ffffff;
        padding: 1rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .featured-card .title {
        color: #FFD700 !important;
        text-shadow: 0 0 8px rgba(255, 215, 0, 0.4);
        font-weight: 700;
        font-size: 1.1rem;
        line-height: 1.3;
    }

    .featured-card .desc {
        color: #b0b0b0 !important;
        font-size: 0.85rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
    }

    .featured-card .price {
        color: #FFD700;
        font-weight: bold;
        font-size: 1.1rem;
    }

    /* 🔥 STAR STYLES */
    .stars {
        display: inline-flex;
        gap: 2px;
    }

    .star {
        font-size: 0.95rem;
        line-height: 1;
    }

        .star.filled {
            color: #FFD700;
        }

        .star.half {
            color: #FFD700;
            background: linear-gradient(90deg, #FFD700 50%, #555 50%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .star.empty {
            color: #555;
        }

    /* 🔥 BUTTON */
    .btn-gradient {
        display: inline-block;
        background: linear-gradient(135deg, #b30000, #FFD700);
        border: none;
        color: #000;
        font-weight: 700;
        font-size: 0.85rem;
        border-radius: 30px;
        padding: 10px 16px;
        transition: all 0.3s ease;
        text-decoration: none;
        text-align: center;
        cursor: pointer;
    }

        .btn-gradient:hover {
            background: linear-gradient(135deg, #FFD700, #b30000);
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.6);
            transform: translateY(-2px);
            color: #000;
            text-decoration: none;
        }

    /* 🔥 RESPONSIVE */
    @@media (max-width: 768px) {
        .service-img {
            height: 180px;
        }

        .featured-card .title {
            font-size: 1rem;
        }

        .btn-gradient {
            font-size: 0.8rem;
            padding: 8px 12px;
        }
    }

    @@media (max-width: 576px) {
        .service-img {
            height: 160px;
        }
    }
</style>